---
import '@styles/global.css'
import { Font } from 'astro:assets'
import Footer from '@components/Footer.astro'
import Menu from '@components/Menu.astro'
import { COLOR_KEYS, COLORS_RGB } from '@scripts/flow-field.ts'
---

<!doctype html>
<html lang="en" class="h-full m-0">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-ibm-plex-sans" />
    <Font cssVariable="--font-lateef" />
    <title>Pixel Agency</title>
    {
      /* Pick a random flow-field accent colour on every page load.
        Keys sourced from flow-field.ts at build time via define:vars.
        Inline so it runs synchronously before any deferred scripts. */
    }
    <script define:vars={{ colorKeys: COLOR_KEYS, colorsRGB: COLORS_RGB }} is:inline>
      var key = colorKeys[Math.floor(Math.random() * colorKeys.length)]
      document.documentElement.dataset.accentColor = key
      document.documentElement.style.setProperty('--accent-bgc', colorsRGB[key])
    </script>
  </head>
  <body class="m-0 min-h-screen bg-pixel-off-white">
    <Menu />
    <slot />
    <Footer />
  </body>
</html>
