---
import '@styles/global.css'
import { Font } from 'astro:assets'
import Footer from '@components/Footer.astro'
import Menu from '@components/Menu.astro'
import { COLOR_KEYS, COLORS_RGB } from '@scripts/flow-field.ts'

interface Props {
  title?: string
  description?: string
  /** Skip the menu spacer for pages with full-height heroes */
  noMenuSpacer?: boolean
  /** Override the random logo colour pair. Pass { p: '#hex', a: '#hex' }. */
  logoColors?: { p: string; a: string }
  published?: boolean
}

const {
  title = 'Pixel Agency',
  description = 'Pixel Agency — digital strategy, design, and development studio based in Melbourne, Australia.',
  noMenuSpacer = false,
  logoColors,
  published = true
} = Astro.props

const pageTitle = title === 'Pixel Agency' ? title : `${title} | Pixel Agency`
---

<!doctype html>
<html lang="en" class="h-full m-0">
  <head>
    <meta charset="UTF-8" />
    {!published && <meta name="robots" content="noindex, nofollow" />}
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Pixel Agency" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <Font cssVariable="--font-ibm-plex-sans" />
    <Font cssVariable="--font-lateef" />
    <title>{pageTitle}</title>
    {
      /* Pick a random flow-field accent colour on every page load.
        Keys sourced from flow-field.ts at build time via define:vars.
        Inline so it runs synchronously before any deferred scripts. */
    }
    <script define:vars={{ colorKeys: COLOR_KEYS, colorsRGB: COLORS_RGB }} is:inline>
      var key = colorKeys[Math.floor(Math.random() * colorKeys.length)]
      document.documentElement.dataset.accentColor = key
      document.documentElement.style.setProperty('--accent-bgc', colorsRGB[key])
    </script>
  </head>
  <body class="m-0 min-h-screen bg-pixel-platinum-lte">
    <Menu logoColors={logoColors} />
    {!noMenuSpacer && <div class="h-[70px] lg:h-[128px]" aria-hidden="true" />}
    <slot />
    <Footer />
  </body>
</html>
