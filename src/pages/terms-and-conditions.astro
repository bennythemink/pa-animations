<style>
  @reference "../styles/global.css";

  .prose-legal h1 {
    @apply text-4xl lg:text-6xl leading-[0.9] tracking-[-0.03em] mb-8;
  }
  .prose-legal h2 {
    @apply font-sans font-semibold text-xl lg:text-2xl mt-10 mb-3;
  }
  .prose-legal p {
    @apply font-sans text-base lg:text-lg leading-relaxed mb-4;
  }
  .prose-legal ul {
    @apply font-sans text-base lg:text-lg leading-relaxed mb-4 list-disc pl-6 flex flex-col gap-2;
  }
  .prose-legal a {
    @apply underline underline-offset-2 hover:opacity-70 transition-opacity;
  }
</style>
