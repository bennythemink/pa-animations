---
import Layout from '../layouts/Layout.astro'
import PixelAssistChatbot from '../components/PixelAssistChatbot.astro'
import plusSvg from '../assets/plus.svg?url'
import equalsSvg from '../assets/equals.svg?url'
import vectorSvg from '../assets/vector.svg?url'

const assistConversation = [
  { role: 'user' as const, text: 'What exactly is Pixel Assist?' },
  {
    role: 'ai' as const,
    text: 'Pixel Assist is an AI-powered assistant that lives on your website. It learns your content and answers visitor questions instantly — 24/7, no waiting.'
  },
  { role: 'user' as const, text: 'Can it handle complex, technical questions?' },
  {
    role: 'ai' as const,
    text: 'Yes. It can understand and respond to a wide range of questions, from simple FAQs to complex product, technical, and conformance inquiries. It’s like having a technical and support assistant on your website at all times.'
  },
  { role: 'user' as const, text: 'How does it help convert visitors into customers?' },
  {
    role: 'ai' as const,
    text: 'It guides visitors to the right information at the right moment — answering objections, recommending products, and nudging them toward enquiry forms or checkout. Think of it as a knowledgeable sales assistant that never sleeps.'
  },
  { role: 'user' as const, text: 'Great, love this! Thank you very much!' }
]
---

<Layout>
  <div id="hero-wrapper" class="relative h-screen overflow-hidden">
    <div id="hero-track" class="flex h-screen relative items-center">
      <div id="hero-text" class="pointer-events-none shrink-0 whitespace-nowrap pl-32 flex items-center gap-8">
        <h1 class="text-5xl sm:text-10xl">
          Clear promises
          <img src={plusSvg} alt="plus" class="inline-block h-[1.25em] mx-2 align-middle" />
          Careful craft
          <img src={equalsSvg} alt="equals" class="inline-block h-[1.25em] mx-2 align-middle" />
          Proud outcomes
          <img src={vectorSvg} alt="vector" class="inline-block h-[1.25em] mx-2 align-middle" />
        </h1>
      </div>
      <div id="hero-h2" class="pointer-events-none shrink-0 w-screen flex items-center justify-center z-10">
        <h2 class="text-4xl sm:text-6xl whitespace-normal max-w-screen text-center px-16">
          We are Pixel Agency, a practitioner-led, refreshing 🍊 digital partner.
        </h2>
      </div>
      <div id="track-flow" class="h-full shrink-0">
        <div id="flow-container" class="w-full h-full">
          <canvas id="flow" class="block w-full h-full"></canvas>
        </div>
      </div>
      <div id="track-bg-2" class="h-full shrink-0"></div>
    </div>
  </div>

  <!-- ══════ PROBLEM — vertical scroll section ══════ -->
  <section id="problem" class="min-h-screen flex flex-col justify-center px-16 py-24">
    <div class="max-w-4xl mx-auto space-y-12">
      <h2 class="text-4xl sm:text-7xl">The problem with digital right now</h2>
      <p class="text-xl sm:text-2xl leading-relaxed">
        Most agencies sell big promises and hand the work to juniors. Timelines slip, budgets balloon, and what gets
        delivered rarely matches what was sold. You end up managing the agency instead of your business.
      </p>
      <p class="text-xl sm:text-2xl leading-relaxed">
        Meanwhile, your customers expect instant, intelligent experiences — and they're not getting them. Support queues
        grow, conversion stalls, and your team burns out answering the same questions over and over.
      </p>
      <p class="text-xl sm:text-2xl leading-relaxed">It doesn't have to be this way.</p>
    </div>
  </section>

  <!-- ══════ PIXEL ASSIST — horizontal scroll ══════ -->
  <div id="assist-wrapper" class="relative h-screen overflow-hidden">
    <div id="assist-track" class="flex h-screen relative items-center">
      <!-- Panel 1: intro text -->

      <div class="shrink-0 w-[50vw] sm:w-[55vw] pl-8 sm:pl-32 flex items-center h-full">
        <div id="assist-intro">
          <h2 class="text-3xl sm:text-4xl mb-8">Our AI service</h2>
          <h3 class="text-6xl sm:text-9xl mb-10 sm:mb-12">Introducing Pixel Assist.</h3>
        </div>
      </div>

      <!-- Panel 2: yellow card -->
      <div id="assist-card-1" class="shrink-0 h-full flex items-center">
        <div class="w-64 sm:w-96 aspect-square bg-pixel-yellow flex items-start pt-[38%] p-6">
          <p class="text-2xl sm:text-3xl leading-tight">Your customers<br />have questions.</p>
        </div>
      </div>

      <!-- Panel 3: blue card -->
      <div id="assist-card-2" class="shrink-0 h-full flex items-center ml-6">
        <div class="w-64 sm:w-96 aspect-square bg-pixel-blue flex items-start pt-[38%] p-6">
          <p class="text-2xl sm:text-3xl leading-tight">
            Right now,<br />they're not getting<br />instant answers.
          </p>
        </div>
      </div>

      <!-- Panel 4: hero heading -->
      <div id="assist-heading" class="shrink-0 h-full flex items-center px-16">
        <h2 class="text-5xl sm:text-8xl leading-none whitespace-nowrap">Pixel assist<br />changes that.</h2>
      </div>

      <!-- Panel 5: chatbot demo -->
      <div id="assist-chatbot-panel" class="shrink-0 h-full flex items-center justify-center">
        <div class="w-72 h-96">
          <PixelAssistChatbot id="assist-chatbot" conversation={assistConversation} placeholder="Ask a question" />
        </div>
      </div>

      <!-- Panel 6: description text -->
      <div id="assist-description" class="shrink-0 h-full flex items-center px-16 ml-4">
        <div class="max-w-sm space-y-4">
          <p class="text-2xl sm:text-3xl">
            Our managed, AI-powered assistant learns your content and answers customer questions instantly, helping
            people make faster decisions while reducing repetitive support work for your team.
          </p>
          <p class="text-2xl sm:text-3xl">It's like having a digital expert and sales person on your website, 24/7.</p>
          <a href="#" class="text-sm sm:text-base font-bold underline inline-flex items-center gap-1"> Learn more </a>
        </div>
      </div>

      <!-- Trailing spacer -->
      <div id="assist-end" class="shrink-0 h-full"></div>
    </div>
  </div>
</Layout>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'
  import '../scripts/flow-field.js'

  gsap.registerPlugin(ScrollTrigger)

  const lenis = new Lenis()

  lenis.on('scroll', ScrollTrigger.update)

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000)
  })
  gsap.ticker.lagSmoothing(0)

  // ── HERO horizontal scroll sizing ──
  function sizeHeroTrack() {
    const heroText = document.getElementById('hero-text')!
    const heroH2 = document.getElementById('hero-h2')!
    const textWidth = heroText.scrollWidth
    const h2Width = heroH2.scrollWidth
    const vw = window.innerWidth
    const flowWidth = vw * 1
    const extraTrack = vw

    const totalWidth = textWidth + h2Width + flowWidth + extraTrack

    const trackFlow = document.getElementById('track-flow')!
    const trackBg2 = document.getElementById('track-bg-2')!
    const heroTrack = document.getElementById('hero-track')!

    trackFlow.style.width = `${flowWidth}px`
    trackBg2.style.width = `${extraTrack}px`
    heroTrack.style.width = `${totalWidth}px`
  }

  // ── PIXEL ASSIST horizontal scroll sizing ──
  function sizeAssistTrack() {
    const vw = window.innerWidth
    const assistEnd = document.getElementById('assist-end')!
    const assistTrack = document.getElementById('assist-track')!

    assistEnd.style.width = `${vw}px`

    const children = assistTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    assistTrack.style.width = `${totalWidth}px`
  }

  function sizeAllTracks() {
    sizeHeroTrack()
    sizeAssistTrack()
  }

  const heroH2 = document.getElementById('hero-h2')!

  function initScrollTriggers() {
    // ── HERO horizontal scroll ──
    gsap.to('#hero-track', {
      x: () => -(document.querySelector('#hero-track')!.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero-wrapper',
        pin: true,
        scrub: true,
        end: () => `+=${document.querySelector('#hero-track')!.scrollWidth - window.innerWidth}`,
        onUpdate(self) {
          const totalScroll = document.querySelector('#hero-track')!.scrollWidth - window.innerWidth
          const trackX = -self.progress * totalScroll
          const vw = window.innerWidth

          const h2Left = heroH2.offsetLeft
          const h2ScreenLeft = h2Left + trackX

          if (h2ScreenLeft <= 0) {
            heroH2.style.transform = `translateX(${-h2ScreenLeft}px)`
          } else {
            heroH2.style.transform = ''
          }
        }
      }
    })

    // ── PIXEL ASSIST horizontal scroll (timeline with chatbot pause) ──
    const assistTrack = document.querySelector('#assist-track')! as HTMLElement
    const chatPanel = document.getElementById('assist-chatbot-panel')!
    const vwNow = window.innerWidth

    // Total distance the track needs to travel
    const totalTravel = assistTrack.scrollWidth - vwNow

    // Distance to scroll so the chatbot panel is centered on screen
    const chatCenterOffset = chatPanel.offsetLeft + chatPanel.offsetWidth / 2
    const xToChatCenter = Math.min(totalTravel, Math.max(0, chatCenterOffset - vwNow / 2))

    // Remaining distance after the chatbot center
    const xAfterChat = totalTravel - xToChatCenter

    // Proportion of the horizontal travel for each phase
    const phasePre = totalTravel > 0 ? xToChatCenter / totalTravel : 0
    const phasePost = totalTravel > 0 ? xAfterChat / totalTravel : 0

    // Extra scroll distance allocated to the chatbot conversation pause
    const chatPauseDist = vwNow * 8

    // Total scroll distance = horizontal travel + chatbot pause
    const assistScrollDist = totalTravel + chatPauseDist

    // Timeline durations proportional to scroll distance
    const durPre = totalTravel > 0 ? xToChatCenter / assistScrollDist : 0
    const durPause = chatPauseDist / assistScrollDist
    const durPost = totalTravel > 0 ? xAfterChat / assistScrollDist : 0

    const assistTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#assist-wrapper',
        pin: true,
        scrub: 1,
        end: () => `+=${assistScrollDist}`
      }
    })

    // Phase 1: scroll track to center chatbot on screen
    if (xToChatCenter > 0) {
      assistTl.to('#assist-track', {
        x: -xToChatCenter,
        ease: 'none',
        duration: durPre
      })
    }

    // Phase 2: hold track still — the chatbot conversation plays here
    // We add a dummy tween (0 movement) to consume timeline duration
    assistTl.to('#assist-track', {
      x: -xToChatCenter,
      ease: 'none',
      duration: durPause
    })

    // Phase 3: resume scrolling to the end
    if (xAfterChat > 0) {
      assistTl.to('#assist-track', {
        x: -totalTravel,
        ease: 'none',
        duration: durPost
      })
    }

    // Drive chatbot progress from the pause phase (phase 2)
    const pauseStart = durPre
    const pauseEnd = durPre + durPause

    ScrollTrigger.create({
      trigger: '#assist-wrapper',
      scrub: 1,
      start: 'top top',
      end: () => `+=${assistScrollDist}`,
      onUpdate(self) {
        const p = self.progress
        // Map pause phase to chatbot 0→1
        if (p >= pauseStart && p <= pauseEnd && durPause > 0) {
          const chatP = (p - pauseStart) / durPause
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(chatP)
        } else if (p < pauseStart) {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(0)
        } else {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(1)
        }
      }
    })
  }

  document.fonts.ready.then(() => {
    sizeAllTracks()
    initScrollTriggers()
    ScrollTrigger.refresh()
    lenis.resize()
  })
  window.addEventListener('resize', () => {
    sizeAllTracks()
    ScrollTrigger.refresh()
    lenis.resize()
  })
</script>
