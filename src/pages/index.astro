              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div><!-- end #site-content -->
</Layout>

<style>
  .process-rect {
    opacity: 0;
  }
  .process-rect[data-color='red'] {
    background-color: var(--color-pixel-red);
  }
  .process-rect[data-color='dark-red'] {
    background-color: var(--color-pixel-dark-red);
  }
  .process-rect[data-color='blue'] {
    background-color: var(--color-pixel-blue);
  }
  .process-rect[data-color='dark-blue'] {
    background-color: var(--color-pixel-dark-blue);
  }
  .process-rect[data-color='green'] {
    background-color: var(--color-pixel-green);
  }
  .process-rect[data-color='dark-green'] {
    background-color: var(--color-pixel-dark-green);
  }
  .process-rect[data-color='orange'] {
    background-color: var(--color-pixel-orange);
  }
  .process-rect[data-color='light-orange'] {
    background-color: var(--color-pixel-light-orange);
  }
  .process-rect[data-color='yellow'] {
    background-color: var(--color-pixel-yellow);
  }
  .process-rect[data-color='light-yellow'] {
    background-color: var(--color-pixel-light-yellow);
  }
  .process-rect[data-color='pink'] {
    background-color: var(--color-pixel-pink);
  }
  .process-rect[data-color='dark-pink'] {
    background-color: var(--color-pixel-dark-red);
  }
  .process-rect[data-color='light-pink'] {
    background-color: var(--color-pixel-light-pink);
  }
  .process-rect[data-color='cream'] {
    background-color: var(--color-pixel-cream);
  }

  /* ── Puzzle loader ───────────────────────────────────────── */
  .puzzle-stage {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 9999;
    background: #f0efea;
    pointer-events: none;
  }
  #puzzle {
    position: relative;
  }
  :global(.puzzle-tile) {
    position: absolute;
    will-change: transform, opacity;
  }
  :global(.puzzle-tile img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: fill;
    pointer-events: none;
  }
  :global(.puzzle-tile.logo-link) {
    cursor: pointer;
  }
  #puzzle-skip {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 10000;
    pointer-events: auto;
    background: none;
    border: none;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #386b92;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s;
    letter-spacing: 0.04em;
  }
  #puzzle-skip:hover {
    opacity: 1;
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'
  import { initFlowField } from '../scripts/flow-field.js'

  gsap.registerPlugin(ScrollTrigger)

  const lenis = new Lenis()
  lenis.stop() // lock scroll during puzzle

  lenis.on('scroll', ScrollTrigger.update)

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000)
  })
  gsap.ticker.lagSmoothing(0)

  // ══════════════════════════════════════════════════════════
  // PUZZLE LOADER
  // ══════════════════════════════════════════════════════════

  const COLS = 6
  const ROWS = 2

  const TILE_DEFS = [
    { id: 'P', src: '/Letters/P.svg', solvedPos: 0 },
    { id: 'I', src: '/Letters/I.svg', solvedPos: 1 },
    { id: 'X', src: '/Letters/X.svg', solvedPos: 2 },
    { id: 'E', src: '/Letters/E.svg', solvedPos: 3 },
    { id: 'L', src: '/Letters/L.svg', solvedPos: 4 },
    // position 5 → EMPTY
    { id: 'A', src: '/Letters/A.svg', solvedPos: 6 },
    { id: 'G', src: '/Letters/G.svg', solvedPos: 7 },
    { id: 'E2', src: '/Letters/E-red.svg', solvedPos: 8 },
    { id: 'N', src: '/Letters/N.svg', solvedPos: 9 },
    { id: 'C', src: '/Letters/C.svg', solvedPos: 10 },
    { id: 'Y', src: '/Letters/Y.svg', solvedPos: 11 }
  ]

  const SOLVED_STATE: (number | null)[] = new Array(COLS * ROWS).fill(null)
  TILE_DEFS.forEach((def, idx) => {
    SOLVED_STATE[def.solvedPos] = idx
  })

  function gridToPixel(pos: number, tileSize: number, gap: number) {
    return {
      x: (pos % COLS) * (tileSize + gap),
      y: Math.floor(pos / COLS) * (tileSize + gap)
    }
  }

  function getAdjacentPositions(pos: number) {
    const row = Math.floor(pos / COLS)
    const col = pos % COLS
    const adj: number[] = []
    if (col > 0) adj.push(pos - 1)
    if (col < COLS - 1) adj.push(pos + 1)
    if (row > 0) adj.push(pos - COLS)
    if (row < ROWS - 1) adj.push(pos + COLS)
    return adj
  }

  const SHUFFLE_MOVES = 10

  function generateShuffle(numMoves: number) {
    const state = SOLVED_STATE.slice()
    const moves: { fromPos: number; toPos: number }[] = []
    let emptyPos = state.indexOf(null)
    let prevEmpty = -1

    for (let i = 0; i < numMoves; i++) {
      const candidates = getAdjacentPositions(emptyPos).filter((p) => p !== prevEmpty)
      const tilePos = candidates[Math.floor(Math.random() * candidates.length)]
      moves.push({ fromPos: tilePos, toPos: emptyPos })
      state[emptyPos] = state[tilePos]
      state[tilePos] = null
      prevEmpty = emptyPos
      emptyPos = tilePos
    }

    return { shuffledState: state, shuffleMoves: moves }
  }

  /**
   * Run the puzzle animation. Returns a master timeline that can be killed for skip.
   * Calls `onComplete` when the full sequence finishes (or skip calls it manually).
   */
  function runPuzzle(onComplete: () => void): gsap.core.Timeline {
    const GAP = Math.min(9, Math.max(3, Math.round(window.innerWidth * 0.006)))
    const PUZZLE_W = Math.min(Math.round(window.innerWidth * 0.95), 1080)
    const TILE_SIZE = Math.floor((PUZZLE_W - (COLS - 1) * GAP) / COLS)
    const PUZZLE_H = ROWS * TILE_SIZE + (ROWS - 1) * GAP

    const puzzleEl = document.getElementById('puzzle')!
    puzzleEl.style.width = PUZZLE_W + 'px'
    puzzleEl.style.height = PUZZLE_H + 'px'

    const tileEls = TILE_DEFS.map((def) => {
      const div = document.createElement('div')
      div.className = 'puzzle-tile'
      div.id = 'tile-' + def.id
      div.style.width = TILE_SIZE + 'px'
      div.style.height = TILE_SIZE + 'px'
      const img = document.createElement('img')
      img.src = def.src
      img.alt = def.id
      div.appendChild(img)
      puzzleEl.appendChild(div)
      return div
    })

    const { shuffledState, shuffleMoves } = generateShuffle(SHUFFLE_MOVES)
    const solvingMoves = shuffleMoves
      .slice()
      .reverse()
      .map((m) => ({ fromPos: m.toPos, toPos: m.fromPos }))

    // ── Sort tiles: bottom row (AGENCY) drops first, then top row (PIXEL) ──
    const bottomTargets: { el: HTMLElement; finalX: number; finalY: number; col: number }[] = []
    const topTargets: { el: HTMLElement; finalX: number; finalY: number; col: number }[] = []

    for (let pos = 0; pos < COLS * ROWS; pos++) {
      const tileIdx = shuffledState[pos]
      if (tileIdx === null) continue
      const p = gridToPixel(pos, TILE_SIZE, GAP)
      const target = { el: tileEls[tileIdx], finalX: p.x, finalY: p.y, col: pos % COLS }
      if (Math.floor(pos / COLS) === 1) bottomTargets.push(target)
      else topTargets.push(target)
    }

    bottomTargets.sort((a, b) => a.col - b.col)
    topTargets.sort((a, b) => a.col - b.col)
    const dropTargets = bottomTargets.concat(topTargets)

    // ── Animation constants ──
    const DROP_FROM = -(window.innerHeight + 300)
    const DROP_DUR = 1.37
    const DROP_STAGGER = 0.09
    const DROP_DELAY = 0.2

    // Master timeline wrapping all phases
    const master = gsap.timeline({ onComplete })

    // Set initial state
    gsap.set(tileEls, { opacity: 0.5 })
    dropTargets.forEach((dt) => {
      gsap.set(dt.el, { x: dt.finalX, y: DROP_FROM, force3D: true })
    })

    // ── Phase 1: Drop ──
    const dropTl = gsap.timeline({ delay: DROP_DELAY })
    dropTargets.forEach((dt, i) => {
      dropTl.to(dt.el, { y: dt.finalY, duration: DROP_DUR, ease: 'bounce.out' }, i * DROP_STAGGER)
    })

    // Landing squish
    dropTargets.forEach((dt, i) => {
      const fireAt = DROP_DELAY + i * DROP_STAGGER + 0.64 * DROP_DUR
      gsap.fromTo(
        dt.el,
        { scaleY: 1, scaleX: 1 },
        {
          scaleY: 0.82,
          scaleX: 1.1,
          duration: 0.085,
          yoyo: true,
          repeat: 1,
          ease: 'power2.inOut',
          delay: fireAt,
          transformOrigin: 'bottom center'
        }
      )
    })

    // Opacity fade on landing
    dropTargets.forEach((dt, i) => {
      const landTime = DROP_DELAY + i * DROP_STAGGER + 0.64 * DROP_DUR
      gsap.to(dt.el, { opacity: 1, duration: 0.5, delay: landTime, ease: 'power2.out' })
    })

    const absLastLands = DROP_DELAY + (dropTargets.length - 1) * DROP_STAGGER + DROP_DUR
    const SOLVE_PAUSE = 0.55
    const SOLVE_START = absLastLands + SOLVE_PAUSE
    const MOVE_DUR = 1.3 / SHUFFLE_MOVES

    // ── Phase 2: Solve ──
    const domGrid: (HTMLElement | null)[] = new Array(COLS * ROWS).fill(null)
    shuffledState.forEach((idx, pos) => {
      if (idx !== null) domGrid[pos] = tileEls[idx]
    })

    const solveTl = gsap.timeline({ delay: SOLVE_START })
    solvingMoves.forEach((move) => {
      const el = domGrid[move.fromPos]!
      const p = gridToPixel(move.toPos, TILE_SIZE, GAP)
      solveTl.to(el, { x: p.x, y: p.y, duration: MOVE_DUR, ease: 'power2.inOut' })
      domGrid[move.toPos] = el
      domGrid[move.fromPos] = null
    })

    // Completion pulse
    solveTl.to(puzzleEl, {
      scale: 1.025,
      duration: 0.325,
      ease: 'power2.out',
      yoyo: true,
      repeat: 1,
      delay: 0.2,
      transformOrigin: 'center center'
    })

    // ── Phase 3: P and A fly to top-left ──
    const puzzleLeft = (window.innerWidth - PUZZLE_W) / 2
    const puzzleTop = (window.innerHeight - PUZZLE_H) / 2
    const CORNER_PAD = 20
    const HALF_TILE = TILE_SIZE * 0.5
    const PA_GAP = 6
    const cornerX = CORNER_PAD - puzzleLeft
    const cornerY_P = CORNER_PAD - puzzleTop
    const cornerY_A = CORNER_PAD + HALF_TILE + PA_GAP - puzzleTop

    const tileP = document.getElementById('tile-P')!
    const tileA = document.getElementById('tile-A')!
    gsap.set([tileP, tileA], { zIndex: 100 })

    const remainingTiles = tileEls.filter((el) => el !== tileP && el !== tileA)

    // Fade out non-P/A tiles
    solveTl.to(remainingTiles, { opacity: 0, duration: 0.72, ease: 'power2.inOut' }, '>+1.0')

    // P flies to corner
    solveTl.to(
      tileP,
      {
        x: cornerX,
        y: cornerY_P,
        scale: 0.5,
        transformOrigin: 'top left',
        duration: 0.91,
        ease: 'power3.inOut'
      },
      '<+0.1'
    )

    // A flies to corner (same start as P)
    solveTl.to(
      tileA,
      {
        x: cornerX,
        y: cornerY_A,
        scale: 0.5,
        transformOrigin: 'top left',
        duration: 0.91,
        ease: 'power3.inOut'
      },
      '<'
    )

    // Nest the sub-timelines into the master
    master.add(dropTl, 0)
    master.add(solveTl, 0)

    // Store refs for skip handler
    ;(master as any)._puzzleRefs = { tileP, tileA, tileEls, TILE_SIZE, CORNER_PAD, HALF_TILE, PA_GAP, puzzleEl }

    return master
  }

  /** Reparent P and A tiles to body as fixed-position logo elements. */
  function reparentPA(refs: {
    tileP: HTMLElement
    tileA: HTMLElement
    TILE_SIZE: number
    CORNER_PAD: number
    HALF_TILE: number
    PA_GAP: number
  }) {
    const { tileP, tileA, TILE_SIZE, CORNER_PAD, HALF_TILE, PA_GAP } = refs
    const fixedSize = TILE_SIZE * 0.5

    ;[tileP, tileA].forEach((el, i) => {
      gsap.set(el, { clearProps: 'all' })
      el.style.position = 'fixed'
      el.style.left = CORNER_PAD + 'px'
      el.style.top = (i === 0 ? CORNER_PAD : CORNER_PAD + fixedSize + PA_GAP) + 'px'
      el.style.width = fixedSize + 'px'
      el.style.height = fixedSize + 'px'
      el.style.zIndex = '10000'
      el.style.pointerEvents = 'auto'
      el.classList.add('logo-link')
      el.addEventListener('click', () => {
        window.location.reload()
      })
      document.body.appendChild(el)
    })
  }

  /** Reveal the site: fade out stage, fade in content, start everything. */
  function revealSite() {
    const stageEl = document.querySelector('.puzzle-stage') as HTMLElement
    const skipBtn = document.getElementById('puzzle-skip')!
    const siteContent = document.getElementById('site-content')!

    // Hide skip button
    skipBtn.style.display = 'none'

    // Initialise layout and ScrollTrigger while content is still at opacity: 0
    // (opacity: 0 preserves layout, so all measurements are valid)
    initFlowField()
    sizeAllTracks()
    initScrollTriggers()
    ScrollTrigger.refresh()

    // Set hero-h2 initial position before it becomes visible
    const spacerLeft = heroH2Spacer.getBoundingClientRect().left
    gsap.set(heroH2, { x: spacerLeft > 0 ? spacerLeft : 0 })

    // Fade out stage background
    gsap.to(stageEl, {
      backgroundColor: 'rgba(240,239,234,0)',
      duration: 0.6,
      ease: 'power2.out',
      onComplete() {
        stageEl.style.display = 'none'
      }
    })

    // Fade in site content
    gsap.to(siteContent, {
      opacity: 1,
      duration: 0.8,
      ease: 'power2.out',
      onComplete() {
        lenis.start()
        lenis.resize()
      }
    })
  }

  // ── HERO horizontal scroll sizing ──
  function sizeHeroTrack() {
    const heroText = document.getElementById('hero-text')!
    const textWidth = heroText.scrollWidth
    const vw = window.innerWidth
    const h2Width = vw // spacer is 1 viewport wide
    const flowWidth = vw * 1
    const extraTrack = vw

    const totalWidth = textWidth + h2Width + flowWidth + extraTrack

    const trackFlow = document.getElementById('track-flow')!
    const trackBg2 = document.getElementById('track-bg-2')!
    const heroTrack = document.getElementById('hero-track')!

    trackFlow.style.width = `${flowWidth}px`
    trackBg2.style.width = `${extraTrack}px`
    heroTrack.style.width = `${totalWidth}px`
  }

  // ── PIXEL ASSIST horizontal scroll sizing ──
  function sizeAssistTrack() {
    const assistTrack = document.getElementById('assist-track')!

    const children = assistTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    assistTrack.style.width = `${totalWidth}px`
  }

  // ── OUR PROCESS horizontal scroll sizing ──
  function sizeProcessTrack() {
    const processTrack = document.getElementById('process-track')!
    const children = processTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    processTrack.style.width = `${totalWidth}px`
  }

  function sizeAllTracks() {
    sizeHeroTrack()
    sizeAssistTrack()
    sizeProcessTrack()
  }

  const heroH2 = document.getElementById('hero-h2')!
  const heroH2Spacer = document.getElementById('hero-h2-spacer')!

  function initScrollTriggers() {
    // ── HERO horizontal scroll ──
    gsap.to('#hero-track', {
      x: () => -(document.querySelector('#hero-track')!.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero-wrapper',
        pin: true,
        scrub: true,
        end: () => `+=${document.querySelector('#hero-track')!.scrollWidth - window.innerWidth}`,
        onUpdate() {
          // Use getBoundingClientRect for the spacer's actual screen position
          // (offsetLeft + manual trackX is unreliable on Chrome mobile)
          const spacerScreenLeft = heroH2Spacer.getBoundingClientRect().left

          // Position the absolutely-placed h2 to match the spacer;
          // cap at x: 0 once it reaches the left edge (the "pin")
          if (spacerScreenLeft <= 0) {
            gsap.set(heroH2, { x: 0 })
          } else {
            gsap.set(heroH2, { x: spacerScreenLeft })
          }
        }
      }
    })

    // ── PIXEL ASSIST horizontal scroll (timeline with chatbot pause) ──
    const assistTrack = document.querySelector('#assist-track')! as HTMLElement
    const chatPanel = document.getElementById('assist-chatbot-panel')!
    const vwNow = window.innerWidth

    // Total distance the track needs to travel
    const totalTravel = assistTrack.scrollWidth - vwNow

    // Distance to scroll so the chatbot panel is centered on screen
    const chatCenterOffset = chatPanel.offsetLeft + chatPanel.offsetWidth / 2
    const xToChatCenter = Math.min(totalTravel, Math.max(0, chatCenterOffset - vwNow / 2))

    // Remaining distance after the chatbot center
    const xAfterChat = totalTravel - xToChatCenter

    // Proportion of the horizontal travel for each phase
    const phasePre = totalTravel > 0 ? xToChatCenter / totalTravel : 0
    const phasePost = totalTravel > 0 ? xAfterChat / totalTravel : 0

    // Extra scroll distance allocated to the chatbot conversation pause
    const chatPauseDist = vwNow * 8

    // Total scroll distance = horizontal travel + chatbot pause
    const assistScrollDist = totalTravel + chatPauseDist

    // Timeline durations proportional to scroll distance
    const durPre = totalTravel > 0 ? xToChatCenter / assistScrollDist : 0
    const durPause = chatPauseDist / assistScrollDist
    const durPost = totalTravel > 0 ? xAfterChat / assistScrollDist : 0

    const assistTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#assist-wrapper',
        pin: true,
        scrub: 1,
        end: () => `+=${assistScrollDist}`
      }
    })

    // Phase 1: scroll track to center chatbot on screen
    if (xToChatCenter > 0) {
      assistTl.to('#assist-track', {
        x: -xToChatCenter,
        ease: 'none',
        duration: durPre
      })
    }

    // Phase 2: hold track still — the chatbot conversation plays here
    // We add a dummy tween (0 movement) to consume timeline duration
    assistTl.to('#assist-track', {
      x: -xToChatCenter,
      ease: 'none',
      duration: durPause
    })

    // Phase 3: resume scrolling to the end
    if (xAfterChat > 0) {
      assistTl.to('#assist-track', {
        x: -totalTravel,
        ease: 'none',
        duration: durPost
      })
    }

    // Drive chatbot progress from the pause phase (phase 2)
    const pauseStart = durPre
    const pauseEnd = durPre + durPause

    ScrollTrigger.create({
      trigger: '#assist-wrapper',
      scrub: 1,
      start: 'top top',
      end: () => `+=${assistScrollDist}`,
      onUpdate(self) {
        const p = self.progress
        // Map pause phase to chatbot 0→1
        if (p >= pauseStart && p <= pauseEnd && durPause > 0) {
          const chatP = (p - pauseStart) / durPause
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(chatP)
        } else if (p < pauseStart) {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(0)
        } else {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(1)
        }
      }
    })

    // ── OUR PROCESS horizontal scroll ──
    const processTrack = document.getElementById('process-track')!
    const processWrapper = document.getElementById('process-wrapper')!

    const processScrollTween = gsap.to(processTrack, {
      x: () => -(processTrack.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: processWrapper,
        pin: true,
        scrub: 1,
        end: () => `+=${processTrack.scrollWidth - window.innerWidth}`,
        invalidateOnRefresh: true
      }
    })

    // Helper to build from/to vars for a rect
    function buildRectVars(rect: HTMLElement) {
      const anim = rect.dataset.anim
      const w = rect.dataset.w + 'px'
      const h = rect.dataset.h + 'px'

      let fromVars: gsap.TweenVars = { opacity: 0 }
      let toVars: gsap.TweenVars = { opacity: 1, duration: 0.6, ease: 'power2.out' }

      switch (anim) {
        case 'grow-h':
          fromVars = { ...fromVars, height: 0, transformOrigin: 'bottom' }
          toVars = { ...toVars, height: h }
          break
        case 'grow-w':
          fromVars = { ...fromVars, width: 0, transformOrigin: 'left' }
          toVars = { ...toVars, width: w }
          break
        case 'grow-h-ttb':
          fromVars = { ...fromVars, height: 0, transformOrigin: 'top' }
          toVars = { ...toVars, height: h }
          break
        case 'grow-w-rtl':
          fromVars = { ...fromVars, width: 0, marginLeft: w }
          toVars = { ...toVars, width: w, marginLeft: '0px' }
          break
      }

      return { fromVars, toVars }
    }

    // Discover rects — animate on section entry (vertical scroll)
    const discoverContainer = document.getElementById('discover-rects')!
    const discoverRects = discoverContainer.querySelectorAll<HTMLElement>('.process-rect')

    discoverRects.forEach((rect, i) => {
      const { fromVars, toVars } = buildRectVars(rect)
      gsap.fromTo(rect, fromVars, {
        ...toVars,
        delay: i * 0.12,
        scrollTrigger: {
          trigger: processWrapper,
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      })
    })

    // All other rects — animate via horizontal containerAnimation
    const otherRects = document.querySelectorAll<HTMLElement>('.process-rect:not(#discover-rects .process-rect)')

    otherRects.forEach((rect) => {
      const { fromVars, toVars } = buildRectVars(rect)
      gsap.fromTo(rect, fromVars, {
        ...toVars,
        scrollTrigger: {
          trigger: rect,
          containerAnimation: processScrollTween,
          start: 'left 100%',
          toggleActions: 'play none none none'
        }
      })
    })
  }

  // ── LAUNCH ──
  document.fonts.ready.then(() => {
    let puzzleTl: gsap.core.Timeline | null = null
    let completed = false

    function onPuzzleComplete() {
      if (completed) return
      completed = true
      const refs = (puzzleTl as any)?._puzzleRefs
      if (refs) reparentPA(refs)
      revealSite()
    }

    puzzleTl = runPuzzle(onPuzzleComplete)

    // Skip button
    document.getElementById('puzzle-skip')!.addEventListener('click', () => {
      if (completed) return
      if (puzzleTl) puzzleTl.kill()
      // Kill any standalone tweens on puzzle tiles
      gsap.killTweensOf('.puzzle-tile')
      gsap.killTweensOf('#puzzle')
      onPuzzleComplete()
    })
  })

  window.addEventListener('resize', () => {
    // Only resize if site has been revealed (startSite has run)
    if (document.getElementById('site-content')!.style.opacity === '1') {
      sizeAllTracks()
      ScrollTrigger.refresh()
      lenis.resize()
    }
  })
</script>
