---
import Layout from '@layouts/Layout.astro'
import plusSvg from '@assets/plus.svg?url'
import equalsSvg from '@assets/equals.svg?url'
import vectorSvg from '@assets/vector.svg?url'
import Grid from '@components/Grid.astro'
import SectionCards from '@components/SectionCards.astro'
import ClientLogos from '@components/home/ClientLogos.astro'
import PixelAssistChatbot from '@components/home/PixelAssistChatbot.astro'
import CaseStudyDrawer from '@components/home/CaseStudyDrawer.astro'
import CTA from '@components/CTA.astro'

const assistConversation = [
  { role: 'user' as const, text: 'What is Pixel Assist and will it help convert visitors into customers?' },
  {
    role: 'ai' as const,
    text: 'It’s an AI assistant on your website that learns your content and gives instant answers 24/7. It captures leads and nudges visitors toward enquiry or checkout, turning more visits into qualified conversations and conversions.'
  }
]

/**
 * SectionCards variables
 */

const sectionCardsTitle = { text: 'Our services', colour: 'pixel-pink' }
const sectionText = {
  tagline: 'However you need to move forward, we have the right capability.',
  description: [
    'Whether you’re starting from scratch, improving something that exists, or navigating a complex digital challenge, there’s a service built for where you are right now.'
  ],
  colSpan: 3 as const
}

const sectionCards = [
  {
    title: 'Discovery + direction',
    description: [
      'Whether you’re starting from scratch, improving something that exists, or navigating a complex digital challenge, there’s a service built for where you are right now.'
    ],
    url: '/services/discovery',
    colour: '#63a3d2'
  },
  {
    title: 'Design',
    description: [
      'Digital experiences that work for your customers, not just impress them. Brand, website, and product design driven by outcomes and grounded in how real people use digital products.'
    ],
    url: '/services/design',
    colour: '#cab38f'
  },
  {
    title: 'Development',
    description: [
      'Websites, apps, and systems built to last, robust, maintainable, and fit for purpose. Not over-engineered, not fragile.'
    ],
    url: '/services/development',
    colour: '#e38093'
  },
  {
    title: 'AI',
    description: [
      'AI-powered solutions that enhance your digital experiences, automate processes, and provide insights to drive better decision-making.'
    ],
    url: '/services/ai',
    colour: '#00A180'
  },
  {
    title: 'Consulting',
    description: [
      'Senior guidance on strategy, delivery, and technical decisions, from people who have seen what good and bad looks like at scale, and will tell you the difference.'
    ],
    url: '/services/consulting',
    colour: '#f09339'
  }
]
---

<Layout noMenuSpacer>
  <div id="site-content">
    <!-- ══════ HERO — puzzle-first, scroll-driven ══════ -->

    <!-- Section 1: Puzzle + surrounding text (visible on load) -->
    <section id="hero-puzzle-section" class="relative h-screen flex items-center justify-center">
      <div id="hero-puzzle-content" class="text-center">
        <h2
          id="hero-tagline-top"
          class="text-2xl sm:text-4xl lg:text-5xl mb-6 sm:mb-8 font-sans font-normal tracking-[-0.03em] opacity-0"
        >
          We are
        </h2>
        <div id="hero-puzzle" class="relative mx-auto"></div>
        <p
          id="hero-tagline-bottom"
          class="text-2xl sm:text-4xl lg:text-5xl mt-6 sm:mt-8 font-sans font-normal tracking-[-0.03em] opacity-0"
        >
          a <span class="text-pixel-orange underline underline-offset-4">refreshing</span> digital partner<span
            id="hero-pixel-dot"
            class="inline-block w-[0.22em] h-[0.22em] bg-pixel-green ml-[0.08em] rounded-none"
            style="vertical-align: baseline;"></span>
        </p>

        <div id="hero-cta" class="mt-4 lg:mt-8 opacity-0">
          <CTA label="Let's talk" />
        </div>
      </div>
    </section>

    <!-- Section 2: Flow field (sits just below the fold, slides up via scroll) -->
    <section id="hero-ff-section" class="relative h-screen overflow-hidden">
      <div id="hero-flow-wrap" class="absolute inset-0 z-5" style="left:-40px;right:-40px;">
        <canvas id="hero-flow" class="block w-full h-full"></canvas>
      </div>
    </section>

    <!-- Section 3: H1 with word cycling (scrolls into view naturally) -->
    <section id="hero-h1-section" class="relative h-screen flex items-center justify-center">
      <div class="px-5 lg:px-20 max-w-360 w-full text-center">
        <h1 id="hero-h1" class="text-[8vw] xl:text-[120px]" style="visibility:hidden;">
          <span id="hero-word-container" class="inline-block align-baseline text-center">
            <span id="hero-word"></span><span
              id="hero-cursor"
              class="inline-block w-0.5 sm:w-1.5 h-[1.2em] bg-current align-middle ml-2 -translate-y-[14px]"></span>
          </span><br />
          without the sales<br />
          <span class="whitespace-nowrap"
            ><span id="hero-theatre-text">people</span><span
              id="hero-pixel-inline"
              class="inline-block w-2 h-2 sm:w-3 sm:h-3 lg:w-5 lg:h-5 xl:w-6 xl:h-6 bg-pixel-green ml-2 opacity-0"
              style="vertical-align: baseline;"></span></span
          >
        </h1>
      </div>
    </section>

    <section id="difference" class="mb-6 lg:mb-0">
      <Grid>
        <div id="difference-panel" class="col-span-full bg-pixel-green pt-7.5 lg:pt-28 pb-7.5 lg:pb-36 my-2 lg:my-6">
          <div id="difference-content" class="grid grid-cols-12 gap-5">
            <h3 class="col-span-full col-start-2 text-5xl lg:text-8xl">
              You talk to the people<span class="lg:hidden"> doing the work</span>
            </h3>
            <h3 class="col-span-full col-start-2 lg:col-start-6 text-5xl lg:text-8xl hidden lg:block">
              doing the work
            </h3>
            <div class="col-start-2 col-span-10 grid grid-cols-12 gap-5">
              <h2
                class="text-pixel-dark-green text-[18px] lg:text-[40px] lg:col-start-1 lg:col-span-3 lg:my-20 col-span-full"
              >
                Our difference
              </h2>
              <div class="col-start-1 col-span-full lg:col-start-6 lg:col-span-4 lg:my-20">
                <p>
                  At Pixel Agency, there are no account managers between you and the team making your product. The
                  people you speak to are the same people who think, design, and build.
                </p>
                <br />
                <p>
                  No hand-offs. No incentives to say yes when we should say no. Just clear thinking, honest advice, and
                  work we’re proud to stand behind.
                </p>
                <br />
                <p>
                  The result clearer decisions, stronger outcomes, and partnerships built on trust, not transactions.
                  All without the sales-theatre.
                </p>
              </div>
            </div>
          </div>
        </div>
      </Grid>
    </section>

    <SectionCards text={sectionText} cards={sectionCards} displayTextBackground={false} />

    <!-- ══════ PIXEL ASSIST — horizontal scroll ══════ -->
    <section id="pixel-assist">
      <div id="assist-wrapper" class="relative h-screen overflow-hidden mt-6 bg-[#eae7e4]">
        <div id="assist-track" class="flex h-screen relative items-center bg-[#eae7e4]">
          <!-- Panel 1: intro text -->

          <div
            class="shrink-0 w-[50vw] sm:w-[55vw] flex items-end h-full pl-5 sm:pl-0 pb-[calc((100vh-16rem)/2)] sm:pb-[calc((100vh-24rem)/2)]"
          >
            <div id="assist-intro">
              <h2 class="text-3xl sm:text-4xl mb-8 text-pixel-blue">Our AI service</h2>
              <h3 class="text-6xl sm:text-9xl">Introducing Pixel Assist.</h3>
            </div>
          </div>

          <!-- Panel 2: yellow card -->
          <div id="assist-card-1" class="shrink-0 h-full flex items-center ml-32 sm:ml-8">
            <div class="w-64 sm:w-96 aspect-square bg-pixel-yellow flex items-start pt-[38%] p-6">
              <p class="text-2xl sm:text-3xl leading-[0.76]">Your customers<br />have questions.</p>
            </div>
          </div>

          <!-- Panel 3: blue card -->
          <div id="assist-card-2" class="shrink-0 h-full flex items-center ml-6">
            <div class="w-64 sm:w-96 aspect-square bg-pixel-blue flex items-start pt-[38%] p-6">
              <p class="text-2xl sm:text-3xl leading-[0.76]">
                Right now,<br />they're not getting<br />instant answers.
              </p>
            </div>
          </div>

          <!-- Panel 4: hero heading -->
          <div
            id="assist-heading"
            class="shrink-0 h-full flex items-end px-16 pb-[calc((100vh-16rem)/2)] sm:pb-[calc((100vh-24rem)/2)]"
          >
            <h2 class="text-5xl sm:text-8xl leading-none whitespace-nowrap">Pixel Assist<br />changes that.</h2>
          </div>

          <!-- Panel 5: chatbot demo -->
          <div id="assist-chatbot-panel" class="shrink-0 h-full flex items-center justify-center">
            <div class="w-72 h-96">
              <PixelAssistChatbot id="assist-chatbot" conversation={assistConversation} placeholder="Ask a question" />
            </div>
          </div>

          <!-- Panel 6: description text -->
          <div
            id="assist-description"
            class="shrink-0 h-full flex items-end px-16 ml-4 leading-[0.76] pb-[calc((100vh-16rem)/2)] sm:pb-[calc((100vh-24rem)/2)]"
          >
            <div class="max-w-sm">
              <p class="text-2xl">
                Our managed, AI-powered assistant learns your content and answers customer questions instantly, helping
                people make faster decisions while reducing repetitive support work for your team.
              </p><br />
              <p class="text-2xl">It's like having a digital expert and sales person on your website, 24/7.</p><br />

              <CTA label="Learn more" />
            </div>
          </div>

          <!-- Trailing spacer -->
          <div id="assist-end" class="shrink-0 h-full w-0"></div>
        </div>
      </div>
    </section>

    <section id="experience" class="py-16 lg:py-24">
      <Grid>
        <p class="col-span-12 lg:col-start-2 lg:col-span-11 text-[40px] text-pixel-pink">Our experience</p>
        <h2 class="col-span-12 lg:col-start-2 lg:col-span-5 text-3xl lg:text-[80px] mt-8 lg:mt-0">
          We've been here before, whatever 'here' looks like for you.
        </h2>
        <div
          class="col-span-12 lg:col-start-8 lg:col-span-4 flex flex-col justify-start gap-6 mt-8 lg:mt-0 text-[18px] lg:text-2xl leading-[0.76]"
        >
          <p>
            From startups finding their footing to established businesses navigating complex digital change, and global
            organisations operating at scale, our team has worked across it all. Construction, education, farming,
            retail, automotive, fintech, and more. Projects of every size and complexity.
          </p>
          <p>
            That range means we adapt to your context without losing our standard of care. And it gives us the
            confidence to be selective, honest, and deeply involved rather than stretched thin or transactional.
          </p>
        </div>
      </Grid>

      <Grid>
        <div class="col-span-full col-start-1 lg:col-start-2 lg:col-span-10 my-6 mt-5 lg:mt-20">
          <CaseStudyDrawer />
        </div>
      </Grid>

      <ClientLogos />
    </section>

    <!-- ══════ OUR PROCESS — horizontal scroll ══════ -->
    <section id="process-wrapper" class="relative bg-pixel-light-cream">
      <div id="process-sticky" class="sticky top-0 h-screen overflow-hidden">
        <div id="process-track" class="flex h-screen relative items-center">
          <!-- Block 1: Our process — vertically centered -->
          <div class="shrink-0 w-[50vw] sm:w-[55vw] pl-8 sm:pl-32 flex items-center h-full">
            <div>
              <h2 class="text-3xl sm:text-4xl text-pixel-dark-green mb-8">Our process</h2>
              <h3 class="text-6xl sm:text-9xl mb-10 sm:mb-12">Clear, simple, safe.</h3>
              <p class="max-w-xs lg:max-w-lg text-[18px] sm:text-2xl leading-[0.76]">
                Our process reflects how proud outcomes are actually achieved: slow down just enough to clarify the
                promise and remove risk, apply care through design and build, and stay responsible beyond launch. Here's
                what that looks like in practice.
              </p>
            </div>
          </div>

          <!-- Block 2: 1. Discover & define — vertically centered -->
          <div class="shrink-0 w-auto pl-8 sm:pl-16 flex items-center h-full">
            <div class="flex items-center gap-0">
              <div
                id="discover-rects"
                class="relative shrink-0 w-[400px] sm:w-[800px] h-[60px] sm:h-[120px] -mt-5 sm:-mt-45"
              >
                <div
                  class="process-rect absolute top-0 left-0 w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                  data-color="blue"
                  data-anim="grow-h"
                  data-w="200"
                  data-h="80"
                >
                </div>
                <div
                  class="process-rect absolute top-[20px] sm:top-[40px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                  data-color="orange"
                  data-anim="grow-w"
                  data-w="200"
                  data-h="40"
                >
                </div>
                <div
                  class="process-rect absolute top-[40px] sm:top-[80px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                  data-color="pink"
                  data-anim="grow-h-ttb"
                  data-w="200"
                  data-h="40"
                >
                </div>
                <div
                  class="process-rect absolute top-[20px] sm:top-[40px] left-[200px] sm:left-[400px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                  data-color="light-orange"
                  data-anim="grow-w-rtl"
                  data-w="200"
                  data-h="40"
                >
                </div>
              </div>
              <div
                class="-ml-[100px] sm:-ml-[200px] -mt-[16px] sm:-mt-[32px] px-4 lg:px-7.5 flex flex-col justify-between gap-3 sm:gap-4 bg-pixel-green pt-3 lg:pt-6 w-45.5 lg:w-98"
              >
                <div>
                  <h4 class="text-[20px] lg:text-3xl mb-6 sm:mb-8 max-w-sm">1. Discover + define</h4>
                  <p class="max-w-sm text-[18px] sm:text-2xl font-serif font-light leading-[0.76] pb-4 lg:pb-8">
                    Before a line of design or code is written, you'll have full clarity on scope, timelines, cost, and
                    what success looks like. No ambiguity carried forward.
                  </p>
                </div>
              </div>
              <div class="relative shrink-0 w-[300px] sm:w-[600px] h-[100px] sm:h-[200px] ml-0">
                <div id="process-phase-2-rects" class="relative top-0">
                  <div
                    class="process-rect absolute top-[69px] sm:top-[138px] left-0 w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="dark-green"
                    data-anim="grow-w"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[129px] sm:top-[258px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="pink"
                    data-anim="grow-h"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[89px] sm:top-[178px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="blue"
                    data-anim="grow-h-ttb"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[89px] sm:top-[178px] left-[200px] sm:left-[400px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="red"
                    data-anim="grow-w-rtl"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                </div>
              </div>
              <div
                class="mt-[33px] sm:mt-[66px] px-4 lg:px-7.5 flex flex-col justify-between gap-3 sm:gap-4 bg-pixel-red pt-3 lg:pt-6 w-45.5 lg:w-98"
              >
                <div>
                  <h4 class="text-[20px] lg:text-3xl mb-6 sm:mb-8 max-w-sm">2. Design</h4>
                  <p class="max-w-sm text-[18px] sm:text-2xl font-serif font-light leading-[0.76] pb-4 lg:pb-8">
                    You'll see and sign off on designs that reflect your brand and your users before development begins.
                    No surprises later.
                  </p>
                </div>
              </div>
              <div
                class="relative shrink-0 w-[300px] sm:w-[600px] h-[180px] sm:h-[360px] ml-0 -mt-[111px] sm:-mt-[222px]"
              >
                <div id="process-phase-3-rects" class="relative top-0">
                  <div
                    class="process-rect absolute top-[120px] sm:top-[240px] left-0 w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="dark-red"
                    data-anim="grow-h"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[100px] sm:top-[200px] left-0 w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="cream"
                    data-anim="grow-w-rtl"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[60px] sm:top-[120px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="green"
                    data-anim="grow-h-ttb"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[20px] sm:top-[40px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="pink"
                    data-anim="grow-h"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-0 left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="light-yellow"
                    data-anim="grow-w"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-0 left-[200px] sm:left-[400px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="yellow"
                    data-anim="grow-w-rtl"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                </div>
              </div>
              <div
                class="-mt-[198px] sm:-mt-[396px] px-4 lg:px-7.5 flex flex-col justify-between gap-3 sm:gap-4 bg-pixel-yellow pt-3 lg:pt-6 w-45.5 lg:w-98"
              >
                <div>
                  <h4 class="text-[20px] lg:text-3xl mb-6 sm:mb-8 max-w-sm">3. Build + test</h4>
                  <p class="max-w-sm text-[18px] sm:text-2xl font-serif font-light leading-[0.76] pb-4 lg:pb-8">
                    You'll stay close to the work through regular previews, thorough testing, and your own review. We
                    build iteratively and share progress, no big reveals.
                  </p>
                </div>
              </div>
              <div
                class="relative shrink-0 w-[600px] sm:w-[1200px] h-[120px] sm:h-[240px] ml-0 -mt-[65px] sm:-mt-[130px]"
              >
                <div id="process-phase-4-rects" class="relative top-0">
                  <div
                    class="process-rect absolute top-[20px] sm:top-[40px] left-0 w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="dark-green"
                    data-anim="grow-w"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[40px] sm:top-[80px] left-0 w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="light-pink"
                    data-anim="grow-h"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-0 left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="red"
                    data-anim="grow-w-rtl"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[40px] sm:top-[80px] left-[100px] sm:left-[200px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="dark-blue"
                    data-anim="grow-h-ttb"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[20px] sm:top-[40px] left-[200px] sm:left-[400px] w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="blue"
                    data-anim="grow-h"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[60px] sm:top-[120px] left-[300px] sm:left-[600px] w-[100px] sm:w-[200px] h-[40px] sm:h-[80px]"
                    data-color="green"
                    data-anim="grow-h-ttb"
                    data-w="200"
                    data-h="80"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[40px] sm:top-[80px] left-[400px] sm:left-[800px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="light-yellow"
                    data-anim="grow-w"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[60px] sm:top-[120px] left-[400px] sm:left-[800px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="dark-dark-pink"
                    data-anim="grow-w-rtl"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                  <div
                    class="process-rect absolute top-[100px] sm:top-[200px] left-[400px] sm:left-[800px] w-[100px] sm:w-[200px] h-[20px] sm:h-[40px]"
                    data-color="pink"
                    data-anim="grow-h"
                    data-w="200"
                    data-h="40"
                  >
                  </div>
                </div>
              </div>
              <div
                class="-ml-[100px] sm:-ml-[200px] mt-[109px] sm:mt-[218px] px-4 lg:px-7.5 flex flex-col justify-between gap-3 sm:gap-4 bg-pixel-pink pt-3 lg:pt-6 w-45.5 lg:w-98"
              >
                <div>
                  <h4 class="text-[20px] lg:text-3xl mb-6 sm:mb-8 max-w-sm">4. Launch + beyond</h4>
                  <p class="max-w-sm text-[18px] sm:text-2xl font-serif font-light leading-[0.76] pb-4 lg:pb-8">
                    You'll launch with confidence, not crossed fingers. And after launch, we stay involved, supporting
                    and resolving issues until the solution performs as intended.
                  </p>
                </div>
              </div>
              <div class="shrink-0 h-full w-[25vw] sm:w-[18vw] lg:w-[12vw]"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="lets-talk">
      <Grid>
        <div
          class="col-span-full grid grid-cols-12 gap-5 pt-7.5 lg:pt-20 lg:pb-36 my-2 lg:my-6"
          style="background-color: var(--accent-bgc);"
        >
          <div class="col-start-2 lg:col-start-2 col-span-10 lg:col-span-5 mb-4 lg:mb-0">
            <h2 class="text-xl lg:text-[80px] leading-[1.04] tracking-[-0.04em]">
              Let&rsquo;s talk about what you&rsquo;re trying to&nbsp;achieve.
            </h2>
          </div>
          <div
            class="col-start-2 lg:col-start-8 col-span-10 lg:col-span-4 flex flex-col justify-start text-[18px] lg:text-2xl leading-[0.76] tracking-[-0.04em] mb-7.5 lg:mb-0"
          >
            <p class="">
              Whether you've got a detailed brief or just a rough idea, we're happy to have a conversation.
            </p>
            <p class="mt-4">
              No pitch, no pressure, just a straight talk about what you're working on and whether we're the
              right&nbsp;fit.
            </p>
            <a
              href="/contact"
              class="mt-6 font-sans font-normal text-[18px] inline-block w-fit bg-white/50 px-4 py-2 hover:underline"
              >Let&rsquo;s talk</a
            >
          </div>
        </div>
      </Grid>
    </section>
  </div><!-- end #site-content -->
</Layout>

<style>
  #assist-track {
    /* Tiny overscan prevents subpixel seam on the pinned right edge */
    padding-right: 2px;
  }

  @media (min-width: 1024px) {
    #assist-track {
      /* Match Grid col-start-2 while keeping the pinned wrapper full-bleed */
      padding-left: calc((100vw - min(100vw, 90rem)) / 2 + 20px + ((min(100vw, 90rem) - 40px - 11 * 20px) / 12) + 20px);
    }
  }

  .process-rect {
    opacity: 0;
    will-change: transform, opacity;
  }
  .process-rect[data-color='red'] {
    background-color: var(--color-pixel-red);
  }
  .process-rect[data-color='dark-red'] {
    background-color: var(--color-pixel-dark-red);
  }
  .process-rect[data-color='blue'] {
    background-color: var(--color-pixel-blue);
  }
  .process-rect[data-color='dark-blue'] {
    background-color: var(--color-pixel-dark-blue);
  }
  .process-rect[data-color='green'] {
    background-color: var(--color-pixel-green);
  }
  .process-rect[data-color='dark-green'] {
    background-color: var(--color-pixel-dark-green);
  }
  .process-rect[data-color='orange'] {
    background-color: var(--color-pixel-orange);
  }
  .process-rect[data-color='light-orange'] {
    background-color: var(--color-pixel-light-orange);
  }
  .process-rect[data-color='yellow'] {
    background-color: var(--color-pixel-yellow);
  }
  .process-rect[data-color='light-yellow'] {
    background-color: var(--color-pixel-light-yellow);
  }
  .process-rect[data-color='pink'] {
    background-color: var(--color-pixel-pink);
  }
  .process-rect[data-color='dark-pink'] {
    background-color: var(--color-pixel-dark-pink);
  }
  .process-rect[data-color='light-pink'] {
    background-color: var(--color-pixel-light-pink);
  }
  .process-rect[data-color='cream'] {
    background-color: var(--color-pixel-cream);
  }

  /* ── Hero animation ── */
  #hero-cursor {
    animation: hero-blink 0.7s step-end infinite;
  }
  @keyframes hero-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'
  import { initFlowField } from '@scripts/flow-field.ts'

  gsap.registerPlugin(ScrollTrigger)

  // Prevent the browser from restoring the previous scroll position on reload
  history.scrollRestoration = 'manual'
  window.scrollTo(0, 0)

  const lenis = new Lenis()

  lenis.on('scroll', ScrollTrigger.update)

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000)
  })
  gsap.ticker.lagSmoothing(0)

  // ══════════════════════════════════════════════════════════
  // PUZZLE — time-based auto-solve on load (2.5s)
  // ══════════════════════════════════════════════════════════

  const COLS = 6
  const ROWS = 2

  // Single source of truth for puzzle size.
  // Options: 'small' | 'medium' | 'large'
  const HERO_PUZZLE_SIZE: 'small' | 'medium' | 'large' = 'medium'
  const HERO_PUZZLE_SCALE: Record<'small' | 'medium' | 'large', number> = {
    small: 1,
    medium: 1.25,
    large: 1.5
  }

  // H1 animation style. Options: 'word-cycle' | 'reveal-rect'
  const HERO_H1_ANIMATION: 'word-cycle' | 'reveal-rect' = 'word-cycle'

  // Pixel colours pool for reveal-rect animation
  const REVEAL_RECT_COLOURS = [
    'var(--color-pixel-blue)',
    'var(--color-pixel-green)',
    'var(--color-pixel-red)',
    'var(--color-pixel-orange)',
    'var(--color-pixel-pink)',
    'var(--color-pixel-yellow)',
    'var(--color-pixel-dark-blue)',
    'var(--color-pixel-dark-green)',
    'var(--color-pixel-light-orange)',
    'var(--color-pixel-light-pink)'
  ]

  const REVEAL_DIRECTIONS = [
    {
      name: 'left-to-right',
      startClip: 'inset(0% 100% 0% 0%)',
      endClip: 'inset(0% 0% 0% 100%)'
    },
    {
      name: 'right-to-left',
      startClip: 'inset(0% 0% 0% 100%)',
      endClip: 'inset(0% 100% 0% 0%)'
    },
    {
      name: 'bottom-to-top',
      startClip: 'inset(100% 0% 0% 0%)',
      endClip: 'inset(0% 0% 100% 0%)'
    },
    {
      name: 'top-to-bottom',
      startClip: 'inset(0% 0% 100% 0%)',
      endClip: 'inset(100% 0% 0% 0%)'
    }
  ] as const

  const TILE_DEFS = [
    { id: 'P', src: '/Letters/P.svg', solvedPos: 0 },
    { id: 'I', src: '/Letters/I.svg', solvedPos: 1 },
    { id: 'X', src: '/Letters/X.svg', solvedPos: 2 },
    { id: 'E', src: '/Letters/E.svg', solvedPos: 3 },
    { id: 'L', src: '/Letters/L.svg', solvedPos: 4 },
    // position 5 → EMPTY
    { id: 'A', src: '/Letters/A.svg', solvedPos: 6 },
    { id: 'G', src: '/Letters/G.svg', solvedPos: 7 },
    { id: 'E2', src: '/Letters/E-red.svg', solvedPos: 8 },
    { id: 'N', src: '/Letters/N.svg', solvedPos: 9 },
    { id: 'C', src: '/Letters/C.svg', solvedPos: 10 },
    { id: 'Y', src: '/Letters/Y.svg', solvedPos: 11 }
  ]

  function getAdjacentPositions(pos: number) {
    const row = Math.floor(pos / COLS)
    const col = pos % COLS
    const adj: number[] = []
    if (col > 0) adj.push(pos - 1)
    if (col < COLS - 1) adj.push(pos + 1)
    if (row > 0) adj.push(pos - COLS)
    if (row < ROWS - 1) adj.push(pos + COLS)
    return adj
  }

  function initPuzzle() {
    const puzzleEl = document.getElementById('hero-puzzle')!
    const taglineTop = document.getElementById('hero-tagline-top')!
    const taglineBottom = document.getElementById('hero-tagline-bottom')!
    const heroCta = document.getElementById('hero-cta')!
    const vw = window.innerWidth
    const sizeScale = HERO_PUZZLE_SCALE[HERO_PUZZLE_SIZE]

    const baseGap = Math.min(9, Math.max(3, Math.round(vw * 0.006)))
    const GAP = Math.max(2, Math.round(baseGap * sizeScale))

    const basePuzzleW = Math.min(Math.round(vw * 0.55), 700)
    const maxPuzzleW = Math.floor(vw * 0.92)
    const PUZZLE_W = Math.min(Math.round(basePuzzleW * sizeScale), maxPuzzleW)
    const TILE_SIZE = Math.floor((PUZZLE_W - (COLS - 1) * GAP) / COLS)
    const PUZZLE_H = ROWS * TILE_SIZE + (ROWS - 1) * GAP

    puzzleEl.style.width = `${PUZZLE_W}px`
    puzzleEl.style.height = `${PUZZLE_H}px`

    // Keep heading/body/CTA spacing proportional to the selected puzzle size.
    const baseTextGap = vw >= 1024 ? 32 : 24
    const baseCtaGap = vw >= 1024 ? 32 : 16
    taglineTop.style.marginBottom = `${Math.round(baseTextGap * sizeScale)}px`
    taglineBottom.style.marginTop = `${Math.round(baseTextGap * sizeScale)}px`
    heroCta.style.marginTop = `${Math.round(baseCtaGap * sizeScale)}px`

    function gridToPixel(pos: number) {
      return {
        x: (pos % COLS) * (TILE_SIZE + GAP),
        y: Math.floor(pos / COLS) * (TILE_SIZE + GAP)
      }
    }

    // Build solved state
    const SOLVED_STATE: (number | null)[] = new Array(COLS * ROWS).fill(null)
    TILE_DEFS.forEach((def, idx) => {
      SOLVED_STATE[def.solvedPos] = idx
    })

    // Shuffle
    const SHUFFLE_MOVES = 10
    const shuffledState = SOLVED_STATE.slice()
    const shuffleMoves: { fromPos: number; toPos: number }[] = []
    let emptyPos = shuffledState.indexOf(null)
    let prevEmpty = -1

    for (let i = 0; i < SHUFFLE_MOVES; i++) {
      const candidates = getAdjacentPositions(emptyPos).filter((p) => p !== prevEmpty)
      const tilePos = candidates[Math.floor(Math.random() * candidates.length)]
      shuffleMoves.push({ fromPos: tilePos, toPos: emptyPos })
      shuffledState[emptyPos] = shuffledState[tilePos]
      shuffledState[tilePos] = null
      prevEmpty = emptyPos
      emptyPos = tilePos
    }

    // Reverse = solving moves
    const solvingMoves = shuffleMoves
      .slice()
      .reverse()
      .map((m) => ({ fromPos: m.toPos, toPos: m.fromPos }))

    // Create tile DOM elements (inline styles to avoid Astro scoping issues)
    const tileEls: HTMLElement[] = TILE_DEFS.map((def) => {
      const div = document.createElement('div')
      div.style.position = 'absolute'
      div.style.width = `${TILE_SIZE}px`
      div.style.height = `${TILE_SIZE}px`
      div.style.willChange = 'transform'
      const img = document.createElement('img')
      img.src = def.src
      img.alt = def.id
      img.draggable = false
      img.style.width = '100%'
      img.style.height = '100%'
      img.style.display = 'block'
      img.style.objectFit = 'fill'
      img.style.pointerEvents = 'none'
      div.appendChild(img)
      puzzleEl.appendChild(div)
      return div
    })

    // Position tiles at shuffled positions
    shuffledState.forEach((tileIdx, gridPos) => {
      if (tileIdx === null) return
      const pos = gridToPixel(gridPos)
      gsap.set(tileEls[tileIdx], { x: pos.x, y: pos.y })
    })

    // Auto-solve timeline (time-based, 1s total)
    const domGrid: (number | null)[] = shuffledState.slice()
    const SOLVE_DURATION = 1
    const moveDur = SOLVE_DURATION / solvingMoves.length
    const solveTl = gsap.timeline({ delay: 0.3 })

    solvingMoves.forEach((move, i) => {
      const tileIdx = domGrid[move.fromPos]!
      const pos = gridToPixel(move.toPos)
      solveTl.to(tileEls[tileIdx], { x: pos.x, y: pos.y, duration: moveDur, ease: 'power2.inOut' }, i * moveDur)
      domGrid[move.toPos] = domGrid[move.fromPos]
      domGrid[move.fromPos] = null
    })

    // Completion pulse
    solveTl.to(puzzleEl, {
      scale: 1.015,
      duration: 0.25,
      ease: 'power2.out',
      yoyo: true,
      repeat: 1,
      transformOrigin: 'center center'
    })

    // Fade in surrounding text + CTA after solve completes

    solveTl.to([taglineTop, taglineBottom], {
      opacity: 1,
      duration: 0.5,
      ease: 'power2.out'
    })
    solveTl.to(
      heroCta,
      {
        opacity: 1,
        duration: 0.4,
        ease: 'power2.out'
      },
      '-=0.25'
    )
  }

  // ══════════════════════════════════════════════════════════
  // HERO: Word cycling
  // ══════════════════════════════════════════════════════════

  const HERO_WORDS: { text: string; color: string }[] = [
    { text: 'Sites', color: 'var(--color-pixel-blue)' },
    { text: 'Apps', color: 'var(--color-pixel-green)' },
    { text: 'AI', color: 'var(--color-pixel-red)' },
    { text: 'Brands', color: 'var(--color-pixel-orange)' },
    { text: 'Consulting', color: 'var(--color-pixel-pink)' },
    { text: 'Solutions', color: 'var(--color-pixel-yellow)' }
  ]

  function alignPixelToText() {
    const h1 = document.getElementById('hero-h1')!
    const pixelEl = document.getElementById('hero-pixel-inline')!
    pixelEl.style.transform = ''
    const cs = getComputedStyle(h1)
    const fontSize = parseFloat(cs.fontSize)
    const canvas = document.createElement('canvas')
    const ctx = canvas.getContext('2d')!
    ctx.font = `${cs.fontWeight} ${fontSize}px ${cs.fontFamily}`
    const metrics = ctx.measureText('theatre')
    const descent = metrics.actualBoundingBoxDescent
    pixelEl.style.transform = `translateY(${descent}px)`
  }

  function initRevealRectAnimation() {
    const wordEl = document.getElementById('hero-word')!
    const container = document.getElementById('hero-word-container')!
    const h1 = document.getElementById('hero-h1')!

    // Create overlay rect
    const revealRect = document.createElement('div')
    revealRect.style.position = 'absolute'
    revealRect.style.pointerEvents = 'none'
    revealRect.style.zIndex = '10'
    container.appendChild(revealRect)

    // Measure max word size from the actual rendered element.
    // This avoids subtle mismatches from detached measurement nodes.
    let maxW = 0
    let maxH = 0
    const originalWordText = wordEl.textContent || ''
    for (const w of HERO_WORDS) {
      wordEl.textContent = w.text
      const rect = wordEl.getBoundingClientRect()
      maxW = Math.max(maxW, rect.width)
      maxH = Math.max(maxH, rect.height)
    }
    wordEl.textContent = originalWordText

    const rectBleed = 4
    const maxRectWidth = Math.ceil(maxW) + rectBleed * 2
    const maxRectHeight = Math.ceil(maxH) + rectBleed * 2

    const cursorEl = document.getElementById('hero-cursor')!
    // Hide cursor in reveal-rect mode
    cursorEl.style.display = 'none'

    const cursorCS = getComputedStyle(cursorEl)
    const cursorSpace =
      cursorEl.getBoundingClientRect().width + parseFloat(cursorCS.marginLeft) + parseFloat(cursorCS.marginRight)
    container.style.width = `${Math.ceil(maxRectWidth + cursorSpace + 4)}px`
    container.style.position = 'relative'

    alignPixelToText()
    h1.style.visibility = 'visible'

    let wordIdx = 0
    let colourIdx = 0
    let lastRevealDirectionIdx = -1

    function getNextColour(): string {
      const col = REVEAL_RECT_COLOURS[colourIdx % REVEAL_RECT_COLOURS.length]
      colourIdx++
      return col
    }

    function getRandomRevealDirection() {
      if (REVEAL_DIRECTIONS.length === 1) return REVEAL_DIRECTIONS[0]

      let nextIdx = lastRevealDirectionIdx
      while (nextIdx === lastRevealDirectionIdx) {
        nextIdx = Math.floor(Math.random() * REVEAL_DIRECTIONS.length)
      }

      lastRevealDirectionIdx = nextIdx
      return REVEAL_DIRECTIONS[nextIdx]
    }

    function cycle() {
      const { text, color } = HERO_WORDS[wordIdx]
      container.style.color = color
      wordEl.textContent = text

      // Keep rect centered on the word while using a fixed max size
      const rectTop = wordEl.offsetTop + (wordEl.offsetHeight - maxRectHeight) / 2
      const rectLeft = wordEl.offsetLeft + (wordEl.offsetWidth - maxRectWidth) / 2
      revealRect.style.top = `${Math.round(rectTop)}px`
      revealRect.style.left = `${Math.round(rectLeft)}px`
      revealRect.style.width = `${maxRectWidth}px`
      revealRect.style.height = `${maxRectHeight}px`

      const rectColour = getNextColour()
      revealRect.style.backgroundColor = rectColour

      const { startClip, endClip } = getRandomRevealDirection()

      // Start hidden from the selected direction
      revealRect.style.clipPath = startClip

      const tl = gsap.timeline()

      // Step 1: Rect grows to fully cover the word (0.6s)
      tl.to(
        revealRect,
        {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 0.6,
          ease: 'power2.out'
        },
        0
      )

      const nextWordIdx = (wordIdx + 1) % HERO_WORDS.length

      // Step 2: Word is fully covered, change to next word and color
      tl.call(
        () => {
          const { text, color } = HERO_WORDS[nextWordIdx]
          container.style.color = color
          wordEl.textContent = text
        },
        [],
        0.6
      )

      // Step 3: Rect shrinks in a random direction to reveal the new word (0.6s)
      tl.to(
        revealRect,
        {
          clipPath: endClip,
          duration: 0.6,
          ease: 'power2.in'
        },
        0.6
      )

      tl.eventCallback('onComplete', () => {
        wordIdx = nextWordIdx
        cycle()
      })
    }

    cycle()
  }

  function initWordCycling() {
    const wordEl = document.getElementById('hero-word')!
    const container = document.getElementById('hero-word-container')!
    const h1 = document.getElementById('hero-h1')!

    const cs = getComputedStyle(h1)
    const measureEl = document.createElement('span')
    measureEl.style.visibility = 'hidden'
    measureEl.style.position = 'absolute'
    measureEl.style.whiteSpace = 'nowrap'
    measureEl.style.pointerEvents = 'none'
    measureEl.style.fontSize = cs.fontSize
    measureEl.style.fontFamily = cs.fontFamily
    measureEl.style.fontWeight = cs.fontWeight
    measureEl.style.letterSpacing = cs.letterSpacing
    document.body.appendChild(measureEl)

    let maxW = 0
    for (const w of HERO_WORDS) {
      measureEl.textContent = w.text
      maxW = Math.max(maxW, measureEl.getBoundingClientRect().width)
    }
    document.body.removeChild(measureEl)

    const cursorEl = document.getElementById('hero-cursor')!
    const cursorCS = getComputedStyle(cursorEl)
    const cursorSpace =
      cursorEl.getBoundingClientRect().width + parseFloat(cursorCS.marginLeft) + parseFloat(cursorCS.marginRight)
    container.style.width = `${Math.ceil(maxW + cursorSpace + 4)}px`

    // Ensure cursor is visible in word-cycle mode
    cursorEl.style.display = ''

    alignPixelToText()
    h1.style.visibility = 'visible'

    let wordIdx = 0

    function typeWord(cb: () => void) {
      const { text, color } = HERO_WORDS[wordIdx]
      container.style.color = color
      let i = 0
      function next() {
        if (i <= text.length) {
          wordEl.textContent = text.slice(0, i)
          i++
          setTimeout(next, 70 + Math.random() * 40)
        } else {
          setTimeout(cb, 2000)
        }
      }
      next()
    }

    function deleteWord(cb: () => void) {
      const text = wordEl.textContent || ''
      let i = text.length
      function next() {
        if (i >= 0) {
          wordEl.textContent = text.slice(0, i)
          i--
          setTimeout(next, 40 + Math.random() * 20)
        } else {
          setTimeout(cb, 200)
        }
      }
      next()
    }

    function cycle() {
      typeWord(() => {
        deleteWord(() => {
          wordIdx = (wordIdx + 1) % HERO_WORDS.length
          cycle()
        })
      })
    }

    cycle()
  }

  // ══════════════════════════════════════════════════════════
  // HERO: Scroll-driven pixel drop + flow field
  // ══════════════════════════════════════════════════════════

  function initHeroScroll() {
    const puzzleSection = document.getElementById('hero-puzzle-section')!
    const puzzleContent = document.getElementById('hero-puzzle-content')!
    const pixelDot = document.getElementById('hero-pixel-dot')!
    const ffSection = document.getElementById('hero-ff-section')!
    const h1Section = document.getElementById('hero-h1-section')!
    const pixelInline = document.getElementById('hero-pixel-inline')!
    const differenceSection = document.getElementById('difference')!
    const differencePanel = document.getElementById('difference-panel')!
    const differenceContent = document.getElementById('difference-content')!

    const vh = window.innerHeight
    const vw = window.innerWidth

    // ── Capture pixel dot's position ──
    const dotRect = pixelDot.getBoundingClientRect()
    const pxStartLeft = dotRect.left
    const pxStartTop = dotRect.top
    const pxStartW = dotRect.width
    const pxStartH = dotRect.height

    // ── Create a fixed-position "falling pixel" clone ──
    const fallingPixel = document.createElement('div')
    fallingPixel.id = 'falling-pixel'
    fallingPixel.style.position = 'fixed'
    fallingPixel.style.left = `${pxStartLeft}px`
    fallingPixel.style.top = `${pxStartTop}px`
    fallingPixel.style.width = `${pxStartW}px`
    fallingPixel.style.height = `${pxStartH}px`
    fallingPixel.style.backgroundColor = 'var(--color-pixel-green)'
    fallingPixel.style.zIndex = '50'
    fallingPixel.style.pointerEvents = 'none'
    fallingPixel.style.opacity = '0'
    document.body.appendChild(fallingPixel)

    const pxEndW = vw < 640 ? 32 : 64

    // ── Init flow field ──
    const accentKey = (document.documentElement.dataset.accentColor || 'green') as any
    const flowCtrl = initFlowField({
      canvasId: 'hero-flow',
      color: accentKey,
      highlightColor: accentKey,
      spacing: 'tight',
      speed: 0.5,
      padding: { top: 80, bottom: 80 }
    })

    flowCtrl.addRepulsionElement(fallingPixel)

    // Difference section starts hidden and is revealed by the morph transition.
    gsap.set(differencePanel, { opacity: 0 })
    gsap.set(differenceContent, { opacity: 0 })

    // ── Pixel inline target position in h1 section ──
    function getPixelInlineRect() {
      return pixelInline.getBoundingClientRect()
    }

    // ══════ ScrollTrigger 1: Puzzle scrolls away — pixel detaches + drops to center ══════
    // No pin. As puzzle scrolls up naturally, pixel drops from text position
    // to center of viewport, grows, and stays there while FF scrolls past.
    const dropTl = gsap.timeline({
      scrollTrigger: {
        trigger: puzzleSection,
        scrub: 0.3,
        start: 'top top',
        end: 'bottom top'
      }
    })

    // Hide the original dot, show the fixed clone at the same position
    dropTl.set(pixelDot, { opacity: 0 }, 0)
    dropTl.set(fallingPixel, { opacity: 1 }, 0)

    // Puzzle content fades out
    dropTl.to(puzzleContent, { opacity: 0.25, duration: 1, ease: 'none' }, 0)

    // Pixel grows and drops to center of viewport
    dropTl.to(
      fallingPixel,
      {
        width: pxEndW,
        height: pxEndW,
        left: vw / 2 - pxEndW / 2,
        top: vh / 2 - pxEndW / 2,
        duration: 1,
        ease: 'power2.in'
      },
      0
    )

    // ══════ NO ScrollTrigger on FF — it scrolls naturally ══════
    // The pixel stays fixed at center viewport (end state of dropTl)
    // while the FF section scrolls past behind it. The flow field
    // reacts to the pixel via repulsion.

    // ══════ ScrollTrigger 2: H1 section — pixel lands on "theatre." ══════
    const h1ScrollDist = vh * 1.5

    const h1Tl = gsap.timeline({
      scrollTrigger: {
        trigger: h1Section,
        pin: true,
        scrub: 0.3,
        end: `+=${h1ScrollDist}`
      }
    })

    // Pixel shrinks and moves from viewport center to the inline position
    h1Tl.to(
      fallingPixel,
      {
        top: () => getPixelInlineRect().top,
        left: () => getPixelInlineRect().left,
        width: () => getPixelInlineRect().width,
        height: () => getPixelInlineRect().height,
        duration: 1,
        ease: 'power2.out'
      },
      0
    )

    // Once landed, hide fixed pixel — the inline one takes over
    h1Tl.to(fallingPixel, { opacity: 0, duration: 0.01 }, 1)
    h1Tl.set(pixelInline, { opacity: 1 }, 1)

    // Hold
    h1Tl.to({}, { duration: 0.5 }, 1)

    // ══════ ScrollTrigger 3: Pixel moves to center, then becomes Difference ══════
    function lerp(start: number, end: number, progress: number) {
      return start + (end - start) * progress
    }

    function lerpRect(
      startRect: { left: number; top: number; width: number; height: number },
      endRect: { left: number; top: number; width: number; height: number },
      progress: number
    ) {
      return {
        left: lerp(startRect.left, endRect.left, progress),
        top: lerp(startRect.top, endRect.top, progress),
        width: lerp(startRect.width, endRect.width, progress),
        height: lerp(startRect.height, endRect.height, progress)
      }
    }

    ScrollTrigger.create({
      trigger: differenceSection,
      scrub: 0.3,
      start: 'top bottom',
      end: 'top 35%',
      invalidateOnRefresh: true,
      onUpdate(self) {
        const progress = self.progress
        const startRect = getPixelInlineRect()
        const midSize = Math.max(64, startRect.width * 4)
        const midRect = {
          left: window.innerWidth / 2 - midSize / 2,
          top: window.innerHeight / 2 - midSize / 2,
          width: midSize,
          height: midSize
        }
        const endRect = differencePanel.getBoundingClientRect()

        let rect = startRect
        if (progress <= 0.4) {
          rect = lerpRect(startRect, midRect, progress / 0.4)
        } else if (progress <= 0.9) {
          rect = lerpRect(midRect, endRect, (progress - 0.4) / 0.5)
        } else {
          rect = endRect
        }

        const panelOpacity = progress <= 0.9 ? 0 : (progress - 0.9) / 0.06
        const contentOpacity = progress <= 0.97 ? 0 : (progress - 0.97) / 0.03
        const pixelOpacity = progress >= 0.96 ? 1 - (progress - 0.96) / 0.04 : 1

        gsap.set(pixelInline, { opacity: progress <= 0.02 ? 1 : 0 })
        gsap.set(fallingPixel, {
          opacity: Math.max(0, pixelOpacity),
          left: rect.left,
          top: rect.top,
          width: rect.width,
          height: rect.height
        })
        gsap.set(differencePanel, { opacity: Math.max(0, Math.min(1, panelOpacity)) })
        gsap.set(differenceContent, { opacity: Math.max(0, Math.min(1, contentOpacity)) })
      }
    })
  }

  // ══════════════════════════════════════════════════════════
  // TRACK SIZING (Assist + Process unchanged)
  // ══════════════════════════════════════════════════════════

  function sizeAssistTrack() {
    const assistTrack = document.getElementById('assist-track')!
    const children = assistTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    assistTrack.style.width = `${totalWidth}px`
  }

  function sizeProcessTrack() {
    const processTrack = document.getElementById('process-track')!
    const children = processTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    processTrack.style.width = `${totalWidth}px`
  }

  function sizeAllTracks() {
    sizeAssistTrack()
    sizeProcessTrack()
  }

  function initScrollTriggers() {
    // ── PIXEL ASSIST horizontal scroll (timeline with chatbot pause) ──
    const assistTrack = document.querySelector('#assist-track')! as HTMLElement
    const chatPanel = document.getElementById('assist-chatbot-panel')!
    const vwNow = window.innerWidth

    const totalTravel = assistTrack.scrollWidth - vwNow
    const chatCenterOffset = chatPanel.offsetLeft + chatPanel.offsetWidth / 2
    const xToChatCenter = Math.min(totalTravel, Math.max(0, chatCenterOffset - vwNow / 2))
    const xAfterChat = totalTravel - xToChatCenter
    const chatPauseDist = vwNow * 4.8
    const assistScrollDist = totalTravel + chatPauseDist
    const durPre = totalTravel > 0 ? xToChatCenter / assistScrollDist : 0
    const durPause = chatPauseDist / assistScrollDist
    const durPost = totalTravel > 0 ? xAfterChat / assistScrollDist : 0

    const assistTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#assist-wrapper',
        pin: true,
        scrub: 1,
        end: () => `+=${assistScrollDist}`
      }
    })

    if (xToChatCenter > 0) {
      assistTl.to('#assist-track', { x: -xToChatCenter, ease: 'none', duration: durPre })
    }
    assistTl.to('#assist-track', { x: -xToChatCenter, ease: 'none', duration: durPause })
    if (xAfterChat > 0) {
      assistTl.to('#assist-track', { x: -totalTravel, ease: 'none', duration: durPost })
    }

    const pauseStart = durPre
    const pauseEnd = durPre + durPause

    ScrollTrigger.create({
      trigger: '#assist-wrapper',
      scrub: 1,
      start: 'top top',
      end: () => `+=${assistScrollDist}`,
      onUpdate(self) {
        const p = self.progress
        if (p >= pauseStart && p <= pauseEnd && durPause > 0) {
          const chatP = (p - pauseStart) / durPause
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(chatP)
        } else if (p < pauseStart) {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(0)
        } else {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(1)
        }
      }
    })

    // ── OUR PROCESS horizontal scroll ──
    const processTrack = document.getElementById('process-track')!
    const processSticky = document.getElementById('process-sticky')!
    const processWrapper = document.getElementById('process-wrapper')!
    const getProcessScrollDist = () => Math.max(0, processTrack.scrollWidth - window.innerWidth)

    function updateProcessLayout() {
      const distNow = getProcessScrollDist()
      if (distNow <= 0) {
        processWrapper.style.height = `${window.innerHeight}px`
      } else {
        processWrapper.style.height = `${window.innerHeight + distNow}px`
      }
      processSticky.style.height = `${window.innerHeight}px`
    }

    gsap.set(processTrack, { x: 0 })

    function buildRectVars(rect: HTMLElement) {
      const anim = rect.dataset.anim
      let fromVars: gsap.TweenVars = { opacity: 0 }
      let toVars: gsap.TweenVars = { opacity: 1, duration: 0.35, ease: 'power2.out' }

      switch (anim) {
        case 'grow-h':
          fromVars = { ...fromVars, scaleY: 0, transformOrigin: 'bottom' }
          toVars = { ...toVars, scaleY: 1 }
          break
        case 'grow-w':
          fromVars = { ...fromVars, scaleX: 0, transformOrigin: 'left' }
          toVars = { ...toVars, scaleX: 1 }
          break
        case 'grow-h-ttb':
          fromVars = { ...fromVars, scaleY: 0, transformOrigin: 'top' }
          toVars = { ...toVars, scaleY: 1 }
          break
        case 'grow-w-rtl':
          fromVars = { ...fromVars, scaleX: 0, transformOrigin: 'right' }
          toVars = { ...toVars, scaleX: 1 }
          break
      }

      return { fromVars, toVars }
    }

    const processRects = Array.from(document.querySelectorAll<HTMLElement>('.process-rect'))
    const processRevealState: Array<{
      rect: HTMLElement
      fromVars: gsap.TweenVars
      toVars: gsap.TweenVars
      revealAt: number
      revealed: boolean
    }> = []

    function buildProcessRevealState() {
      processRevealState.length = 0
      const distNow = getProcessScrollDist()
      const revealEdge = window.innerWidth * 0.9
      const minRevealStart = 0.05

      // Measure with track at origin so thresholds are stable.
      gsap.set(processTrack, { x: 0 })
      const trackRect = processTrack.getBoundingClientRect()

      processRects.forEach((rect) => {
        const { fromVars, toVars } = buildRectVars(rect)
        gsap.set(rect, fromVars)

        const rectBox = rect.getBoundingClientRect()
        const rectLeftInTrack = rectBox.left - trackRect.left
        const revealAt = distNow > 0 ? gsap.utils.clamp(minRevealStart, 1, (rectLeftInTrack - revealEdge) / distNow) : 1

        processRevealState.push({
          rect,
          fromVars,
          toVars,
          revealAt,
          revealed: false
        })
      })
    }

    function syncProcessReveals(progress: number) {
      processRevealState.forEach((item) => {
        const shouldReveal = progress >= item.revealAt
        if (shouldReveal && !item.revealed) {
          item.revealed = true
          gsap.to(item.rect, { ...item.toVars, overwrite: 'auto' })
        } else if (!shouldReveal && item.revealed) {
          item.revealed = false
          gsap.to(item.rect, {
            ...item.fromVars,
            duration: 0.25,
            ease: 'power2.in',
            overwrite: 'auto'
          })
        }
      })
    }

    function updateProcessFromNativeScroll() {
      const distNow = getProcessScrollDist()
      if (distNow <= 0) {
        gsap.set(processTrack, { x: 0 })
        syncProcessReveals(0)
        return
      }

      const rect = processWrapper.getBoundingClientRect()
      const progress = gsap.utils.clamp(0, 1, -rect.top / distNow)
      gsap.set(processTrack, { x: -progress * distNow })
      syncProcessReveals(progress)
    }

    updateProcessLayout()
    buildProcessRevealState()
    updateProcessFromNativeScroll()
    gsap.ticker.add(updateProcessFromNativeScroll)

    window.addEventListener('resize', () => {
      updateProcessLayout()
      buildProcessRevealState()
      updateProcessFromNativeScroll()
    })

    // Dispatch event so Process.astro can initialise after pins are set up
    document.dispatchEvent(new CustomEvent('scrolltriggers:ready'))
  }

  // ── LAUNCH ──
  document.fonts.ready.then(() => {
    sizeAllTracks()
    initPuzzle()
    if (HERO_H1_ANIMATION === 'word-cycle') {
      initWordCycling()
    } else {
      initRevealRectAnimation()
    }
    initHeroScroll()
    initScrollTriggers()
    ScrollTrigger.refresh()
    lenis.start()
  })

  window.addEventListener('resize', () => {
    sizeAllTracks()
    alignPixelToText()
    ScrollTrigger.refresh()
    lenis.resize()
  })
</script>
