<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'
  import { initFlowField } from '@scripts/flow-field.ts'

  gsap.registerPlugin(ScrollTrigger)

  // Prevent the browser from restoring the previous scroll position on reload
  history.scrollRestoration = 'manual'
  window.scrollTo(0, 0)

  const lenis = new Lenis()

  lenis.on('scroll', ScrollTrigger.update)

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000)
  })
  gsap.ticker.lagSmoothing(0)

  /*
  // ══════════════════════════════════════════════════════════
  // PUZZLE LOADER (commented out for new hero)
  // ══════════════════════════════════════════════════════════

  const COLS = 6
  const ROWS = 2

  const TILE_DEFS = [
    { id: 'P', src: '/Letters/P.svg', solvedPos: 0 },
    { id: 'I', src: '/Letters/I.svg', solvedPos: 1 },
    { id: 'X', src: '/Letters/X.svg', solvedPos: 2 },
    { id: 'E', src: '/Letters/E.svg', solvedPos: 3 },
    { id: 'L', src: '/Letters/L.svg', solvedPos: 4 },
    // position 5 → EMPTY
    { id: 'A', src: '/Letters/A.svg', solvedPos: 6 },
    { id: 'G', src: '/Letters/G.svg', solvedPos: 7 },
    { id: 'E2', src: '/Letters/E-red.svg', solvedPos: 8 },
    { id: 'N', src: '/Letters/N.svg', solvedPos: 9 },
    { id: 'C', src: '/Letters/C.svg', solvedPos: 10 },
    { id: 'Y', src: '/Letters/Y.svg', solvedPos: 11 }
  ]

  const SOLVED_STATE: (number | null)[] = new Array(COLS * ROWS).fill(null)
  TILE_DEFS.forEach((def, idx) => {
    SOLVED_STATE[def.solvedPos] = idx
  })

  function gridToPixel(pos: number, tileSize: number, gap: number) {
    return {
      x: (pos % COLS) * (tileSize + gap),
      y: Math.floor(pos / COLS) * (tileSize + gap)
    }
  }

  function getAdjacentPositions(pos: number) {
    const row = Math.floor(pos / COLS)
    const col = pos % COLS
    const adj: number[] = []
    if (col > 0) adj.push(pos - 1)
    if (col < COLS - 1) adj.push(pos + 1)
    if (row > 0) adj.push(pos - COLS)
    if (row < ROWS - 1) adj.push(pos + COLS)
    return adj
  }

  const SHUFFLE_MOVES = 10

  function generateShuffle(numMoves: number) {
    const state = SOLVED_STATE.slice()
    const moves: { fromPos: number; toPos: number }[] = []
    let emptyPos = state.indexOf(null)
    let prevEmpty = -1

    for (let i = 0; i < numMoves; i++) {
      const candidates = getAdjacentPositions(emptyPos).filter((p) => p !== prevEmpty)
      const tilePos = candidates[Math.floor(Math.random() * candidates.length)]
      moves.push({ fromPos: tilePos, toPos: emptyPos })
      state[emptyPos] = state[tilePos]
      state[tilePos] = null
      prevEmpty = emptyPos
      emptyPos = tilePos
    }

    return { shuffledState: state, shuffleMoves: moves }
  }

  function runPuzzle(onComplete: () => void): gsap.core.Timeline {
    // ... puzzle animation code ...
    return gsap.timeline()
  }

  function reparentPA(refs: any) {
    // ... reparent P and A tiles ...
  }

  function revealSite() {
    // ... reveal site after puzzle ...
  }
  */

  // ── PIXEL ASSIST horizontal scroll sizing ──
  function sizeAssistTrack() {
    const assistTrack = document.getElementById('assist-track')!

    const children = assistTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    assistTrack.style.width = `${totalWidth}px`
  }

  // ── OUR PROCESS horizontal scroll sizing ──
  function sizeProcessTrack() {
    const processTrack = document.getElementById('process-track')!
    const children = processTrack.children
    let totalWidth = 0
    for (let i = 0; i < children.length; i++) {
      totalWidth += (children[i] as HTMLElement).offsetWidth
    }
    processTrack.style.width = `${totalWidth}px`
  }

  function sizeAllTracks() {
    // sizeHeroTrack()
    sizeAssistTrack()
    sizeProcessTrack()
  }

  /*
  // ── HERO horizontal scroll sizing (commented out for new hero) ──
  function sizeHeroTrack() {
    const heroText = document.getElementById('hero-text')!
    const textWidth = heroText.scrollWidth
    const vw = window.innerWidth
    const h2Width = vw
    const flowWidth = vw * 1
    const extraTrack = vw

    const totalWidth = textWidth + h2Width + flowWidth + extraTrack

    const trackFlow = document.getElementById('track-flow')!
    const trackBg2 = document.getElementById('track-bg-2')!
    const heroTrack = document.getElementById('hero-track')!

    trackFlow.style.width = `${flowWidth}px`
    trackBg2.style.width = `${extraTrack}px`
    heroTrack.style.width = `${totalWidth}px`
  }

  const heroH2 = document.getElementById('hero-h2')!
  const heroH2Spacer = document.getElementById('hero-h2-spacer')!
  */

  // ── HERO: Word list configuration ──
  const HERO_WORDS: { text: string; color: string }[] = [
    { text: 'Sites', color: 'var(--color-pixel-blue)' },
    { text: 'Apps', color: 'var(--color-pixel-green)' },
    { text: 'AI', color: 'var(--color-pixel-red)' },
    { text: 'Brands', color: 'var(--color-pixel-orange)' },
    { text: 'Consulting', color: 'var(--color-pixel-pink)' },
    { text: 'Solutions', color: 'var(--color-pixel-yellow)' }
  ]

  // ── HERO: Align pixel square with visual bottom of "theatre" text ──
  function alignPixelToText() {
    const h1 = document.getElementById('hero-h1')!
    const pixelEl = document.getElementById('hero-pixel-inline')!
    // Reset any previous transform
    pixelEl.style.transform = ''

    // The font metrics determine how far below baseline the glyphs extend.
    // Use a canvas to measure the actual descent of the font at the rendered size.
    const cs = getComputedStyle(h1)
    const fontSize = parseFloat(cs.fontSize)
    const canvas = document.createElement('canvas')
    const ctx = canvas.getContext('2d')!
    ctx.font = `${cs.fontWeight} ${fontSize}px ${cs.fontFamily}`
    const metrics = ctx.measureText('theatre')

    // actualBoundingBoxDescent = distance from baseline to bottom of glyphs (positive = below baseline)
    const descent = metrics.actualBoundingBoxDescent

    // The pixel is at vertical-align:baseline, so its bottom = baseline.
    // We need to move it down by `descent` to match the glyph bottoms.
    pixelEl.style.transform = `translateY(${descent}px)`
  }

  // ── HERO: Word cycling (time-based, auto-plays on load) ──
  function initWordCycling() {
    const wordEl = document.getElementById('hero-word')!
    const container = document.getElementById('hero-word-container')!
    const h1 = document.getElementById('hero-h1')!

    // Measure widest word to set fixed container width (prevents text shifting)
    const cs = getComputedStyle(h1)
    const measureEl = document.createElement('span')
    measureEl.style.visibility = 'hidden'
    measureEl.style.position = 'absolute'
    measureEl.style.whiteSpace = 'nowrap'
    measureEl.style.pointerEvents = 'none'
    measureEl.style.fontSize = cs.fontSize
    measureEl.style.fontFamily = cs.fontFamily
    measureEl.style.fontWeight = cs.fontWeight
    measureEl.style.letterSpacing = cs.letterSpacing
    document.body.appendChild(measureEl)

    let maxW = 0
    for (const w of HERO_WORDS) {
      measureEl.textContent = w.text
      maxW = Math.max(maxW, measureEl.getBoundingClientRect().width)
    }
    document.body.removeChild(measureEl)
    container.style.width = `${Math.ceil(maxW + 8)}px`

    // Align pixel bottom with visual bottom of "theatre" text
    alignPixelToText()

    // Show h1 now that container width is set
    h1.style.visibility = 'visible'

    let wordIdx = 0

    function typeWord(cb: () => void) {
      const { text, color } = HERO_WORDS[wordIdx]
      container.style.color = color
      let i = 0
      function next() {
        if (i <= text.length) {
          wordEl.textContent = text.slice(0, i)
          i++
          setTimeout(next, 70 + Math.random() * 40)
        } else {
          setTimeout(cb, 2000)
        }
      }
      next()
    }

    function deleteWord(cb: () => void) {
      const text = wordEl.textContent || ''
      let i = text.length
      function next() {
        if (i >= 0) {
          wordEl.textContent = text.slice(0, i)
          i--
          setTimeout(next, 40 + Math.random() * 20)
        } else {
          setTimeout(cb, 200)
        }
      }
      next()
    }

    function cycle() {
      typeWord(() => {
        deleteWord(() => {
          wordIdx = (wordIdx + 1) % HERO_WORDS.length
          cycle()
        })
      })
    }

    cycle()
  }

  // ── HERO: Scroll-driven animation (pixel detach → flow field → puzzle → reveal) ──
  function initHeroScroll() {
    const section = document.getElementById('hero-section')!
    const heading = document.getElementById('hero-heading')!
    const pixelInline = document.getElementById('hero-pixel-inline')!
    const pixelFloat = document.getElementById('hero-pixel-float')!
    const flowWrap = document.getElementById('hero-flow-wrap')!
    const puzzleWrap = document.getElementById('hero-puzzle-wrap')!
    const puzzleEl = document.getElementById('hero-puzzle')!
    const reveal = document.getElementById('hero-reveal')!

    const vw = window.innerWidth
    const vh = window.innerHeight

    // ── Pixel start / end positions ──
    const sectionRect = section.getBoundingClientRect()
    const pixelRect = pixelInline.getBoundingClientRect()
    const pxStartX = pixelRect.left - sectionRect.left
    const pxStartY = pixelRect.top - sectionRect.top
    const pxStartW = pixelRect.width
    const pxStartH = pixelRect.height

    const pxEndW = vw < 640 ? 48 : 80
    const pxCenterX = vw / 2 - pxEndW / 2
    const pxCenterY = vh / 2 - pxEndW / 2

    // ── Puzzle grid ──
    const COLS = 6
    const ROWS = 2
    const TILE_DEFS = [
      { id: 'P', src: '/Letters/P.svg', solvedPos: 0 },
      { id: 'I', src: '/Letters/I.svg', solvedPos: 1 },
      { id: 'X', src: '/Letters/X.svg', solvedPos: 2 },
      { id: 'E', src: '/Letters/E.svg', solvedPos: 3 },
      { id: 'L', src: '/Letters/L.svg', solvedPos: 4 },
      { id: 'A', src: '/Letters/A.svg', solvedPos: 6 },
      { id: 'G', src: '/Letters/G.svg', solvedPos: 7 },
      { id: 'E2', src: '/Letters/E-red.svg', solvedPos: 8 },
      { id: 'N', src: '/Letters/N.svg', solvedPos: 9 },
      { id: 'C', src: '/Letters/C.svg', solvedPos: 10 },
      { id: 'Y', src: '/Letters/Y.svg', solvedPos: 11 }
    ]

    const GAP = Math.min(9, Math.max(3, Math.round(vw * 0.006)))
    const PUZZLE_W = Math.min(Math.round(vw * 0.85), 900)
    const TILE_SIZE = Math.floor((PUZZLE_W - (COLS - 1) * GAP) / COLS)
    const PUZZLE_H = ROWS * TILE_SIZE + (ROWS - 1) * GAP

    puzzleEl.style.width = `${PUZZLE_W}px`
    puzzleEl.style.height = `${PUZZLE_H}px`

    function gridToPixel(pos: number) {
      return {
        x: (pos % COLS) * (TILE_SIZE + GAP),
        y: Math.floor(pos / COLS) * (TILE_SIZE + GAP)
      }
    }

    function getAdjacentPositions(pos: number) {
      const row = Math.floor(pos / COLS)
      const col = pos % COLS
      const adj: number[] = []
      if (col > 0) adj.push(pos - 1)
      if (col < COLS - 1) adj.push(pos + 1)
      if (row > 0) adj.push(pos - COLS)
      if (row < ROWS - 1) adj.push(pos + COLS)
      return adj
    }

    const SOLVED_STATE: (number | null)[] = new Array(COLS * ROWS).fill(null)
    TILE_DEFS.forEach((def, idx) => {
      SOLVED_STATE[def.solvedPos] = idx
    })

    // ── Shuffle from solved → shuffled ──
    const SHUFFLE_MOVES = 10
    const shuffledState = SOLVED_STATE.slice()
    const shuffleMoves: { fromPos: number; toPos: number }[] = []
    let emptyPos = shuffledState.indexOf(null)
    let prevEmpty = -1

    for (let i = 0; i < SHUFFLE_MOVES; i++) {
      const candidates = getAdjacentPositions(emptyPos).filter((p) => p !== prevEmpty)
      const tilePos = candidates[Math.floor(Math.random() * candidates.length)]
      shuffleMoves.push({ fromPos: tilePos, toPos: emptyPos })
      shuffledState[emptyPos] = shuffledState[tilePos]
      shuffledState[tilePos] = null
      prevEmpty = emptyPos
      emptyPos = tilePos
    }

    // Reverse shuffle = solving moves
    const solvingMoves = shuffleMoves
      .slice()
      .reverse()
      .map((m) => ({ fromPos: m.toPos, toPos: m.fromPos }))

    // ── Create tile DOM elements ──
    const tileEls: HTMLElement[] = TILE_DEFS.map((def) => {
      const div = document.createElement('div')
      div.className = 'hero-puzzle-tile'
      div.style.width = `${TILE_SIZE}px`
      div.style.height = `${TILE_SIZE}px`
      const img = document.createElement('img')
      img.src = def.src
      img.alt = def.id
      img.draggable = false
      div.appendChild(img)
      puzzleEl.appendChild(div)
      return div
    })

    // Position tiles at shuffled positions
    shuffledState.forEach((tileIdx, gridPos) => {
      if (tileIdx === null) return
      const pos = gridToPixel(gridPos)
      gsap.set(tileEls[tileIdx], { x: pos.x, y: pos.y })
    })

    // N tile (pos 9) screen coordinates relative to section
    const nGrid = gridToPixel(9)
    const puzzleScreenX = vw / 2 - PUZZLE_W / 2
    const puzzleScreenY = vh / 2 - PUZZLE_H / 2
    const nTileX = puzzleScreenX + nGrid.x
    const nTileY = puzzleScreenY + nGrid.y

    // ── Init flow field on hero canvas ──
    const accentKey = (document.documentElement.dataset.accentColor || 'green') as any
    const flowCtrl = initFlowField({
      canvasId: 'hero-flow',
      color: accentKey,
      highlightColor: accentKey,
      spacing: 'tight',
      speed: 0.5
    })

    // ── Set initial float pixel state ──
    gsap.set(pixelFloat, {
      left: pxStartX,
      top: pxStartY,
      width: pxStartW,
      height: pxStartH,
      opacity: 0
    })

    // ── Master scroll timeline ──
    const scrollDist = vh * 6

    const heroTl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        pin: true,
        scrub: 1,
        end: `+=${scrollDist}`,
        onUpdate(self) {
          // Only repel flow field vectors when pixel is visible in that phase
          if (self.progress > 0.08 && self.progress < 0.45) {
            flowCtrl.addRepulsionElement(pixelFloat)
          } else {
            flowCtrl.removeRepulsionElement(pixelFloat)
          }
        }
      }
    })

    // Phase 1: H1 fades and moves up (0 → 2)
    heroTl.to(heading, { y: -vh * 0.8, opacity: 0.7, duration: 2, ease: 'power2.in' }, 0)

    // Phase 2: Pixel detaches, grows, moves to center (1 → 3)
    heroTl.to(pixelInline, { opacity: 0, duration: 0.3 }, 1)
    heroTl.to(pixelFloat, { opacity: 1, duration: 0.3 }, 1)
    heroTl.to(
      pixelFloat,
      {
        left: pxCenterX,
        top: pxCenterY,
        width: pxEndW,
        height: pxEndW,
        duration: 2,
        ease: 'power2.inOut'
      },
      1
    )

    // Phase 3: Flow field fades in (2 → 3)
    heroTl.to(flowWrap, { opacity: 1, duration: 1 }, 2)

    // Phase 4: Pixel travels to N-tile position (3 → 6)
    heroTl.to(
      pixelFloat,
      {
        left: nTileX,
        top: nTileY,
        width: TILE_SIZE,
        height: TILE_SIZE,
        duration: 3,
        ease: 'none'
      },
      3
    )

    // Phase 5: Puzzle fades in + flow field fades out (5.5 → 6.5)
    heroTl.to(puzzleWrap, { opacity: 1, duration: 1 }, 5.5)
    heroTl.to(flowWrap, { opacity: 0, duration: 1 }, 5.5)

    // Phase 6: Pixel fades out (6 → 6.5)
    heroTl.to(pixelFloat, { opacity: 0, duration: 0.5 }, 6)

    // Phase 7: Puzzle solves (7 → 9)
    const domGrid: (number | null)[] = shuffledState.slice()
    const moveDur = 2 / solvingMoves.length
    solvingMoves.forEach((move, i) => {
      const tileIdx = domGrid[move.fromPos]!
      const pos = gridToPixel(move.toPos)
      heroTl.to(
        tileEls[tileIdx],
        {
          x: pos.x,
          y: pos.y,
          duration: moveDur,
          ease: 'power2.inOut'
        },
        7 + i * moveDur
      )
      domGrid[move.toPos] = domGrid[move.fromPos]
      domGrid[move.fromPos] = null
    })

    // Phase 8: Completion pulse (9.2 → 9.8)
    heroTl.to(
      puzzleEl,
      {
        scale: 1.025,
        duration: 0.3,
        yoyo: true,
        repeat: 1,
        ease: 'power2.out',
        transformOrigin: 'center center'
      },
      9.2
    )

    // Phase 9: Puzzle fades out + reveal fades in (10 → 11.5)
    heroTl.to(puzzleWrap, { opacity: 0, duration: 1 }, 10)
    heroTl.to(reveal, { opacity: 1, duration: 1 }, 10.5)

    // Phase 10: Hold before unpin (11.5 → 12.5)
    heroTl.to({}, { duration: 1 }, 11.5)
  }

  function initScrollTriggers() {
    /*
    // ── HERO horizontal scroll (commented out for new hero) ──
    gsap.to('#hero-track', {
      x: () => -(document.querySelector('#hero-track')!.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero-wrapper',
        pin: true,
        scrub: true,
        end: () => `+=${document.querySelector('#hero-track')!.scrollWidth - window.innerWidth}`,
        onUpdate() {
          const spacerScreenLeft = heroH2Spacer.getBoundingClientRect().left
          if (spacerScreenLeft <= 0) {
            gsap.set(heroH2, { x: 0 })
          } else {
            gsap.set(heroH2, { x: spacerScreenLeft })
          }
        }
      }
    })
    */

    // ── PIXEL ASSIST horizontal scroll (timeline with chatbot pause) ──
    const assistTrack = document.querySelector('#assist-track')! as HTMLElement
    const chatPanel = document.getElementById('assist-chatbot-panel')!
    const vwNow = window.innerWidth

    // Total distance the track needs to travel
    const totalTravel = assistTrack.scrollWidth - vwNow

    // Distance to scroll so the chatbot panel is centered on screen
    const chatCenterOffset = chatPanel.offsetLeft + chatPanel.offsetWidth / 2
    const xToChatCenter = Math.min(totalTravel, Math.max(0, chatCenterOffset - vwNow / 2))

    // Remaining distance after the chatbot center
    const xAfterChat = totalTravel - xToChatCenter

    // Extra scroll distance allocated to the chatbot conversation pause
    const chatPauseDist = vwNow * 8

    // Total scroll distance = horizontal travel + chatbot pause
    const assistScrollDist = totalTravel + chatPauseDist

    // Timeline durations proportional to scroll distance
    const durPre = totalTravel > 0 ? xToChatCenter / assistScrollDist : 0
    const durPause = chatPauseDist / assistScrollDist
    const durPost = totalTravel > 0 ? xAfterChat / assistScrollDist : 0

    const assistTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#assist-wrapper',
        pin: true,
        scrub: 1,
        end: () => `+=${assistScrollDist}`
      }
    })

    // Phase 1: scroll track to center chatbot on screen
    if (xToChatCenter > 0) {
      assistTl.to('#assist-track', {
        x: -xToChatCenter,
        ease: 'none',
        duration: durPre
      })
    }

    // Phase 2: hold track still — the chatbot conversation plays here
    assistTl.to('#assist-track', {
      x: -xToChatCenter,
      ease: 'none',
      duration: durPause
    })

    // Phase 3: resume scrolling to the end
    if (xAfterChat > 0) {
      assistTl.to('#assist-track', {
        x: -totalTravel,
        ease: 'none',
        duration: durPost
      })
    }

    // Drive chatbot progress from the pause phase (phase 2)
    const pauseStart = durPre
    const pauseEnd = durPre + durPause

    ScrollTrigger.create({
      trigger: '#assist-wrapper',
      scrub: 1,
      start: 'top top',
      end: () => `+=${assistScrollDist}`,
      onUpdate(self) {
        const p = self.progress
        if (p >= pauseStart && p <= pauseEnd && durPause > 0) {
          const chatP = (p - pauseStart) / durPause
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(chatP)
        } else if (p < pauseStart) {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(0)
        } else {
          const chatEl = document.getElementById('assist-chatbot') as any
          if (chatEl?.setProgress) chatEl.setProgress(1)
        }
      }
    })

    // ── OUR PROCESS horizontal scroll ──
    const processTrack = document.getElementById('process-track')!
    const processWrapper = document.getElementById('process-wrapper')!

    const processScrollTween = gsap.to(processTrack, {
      x: () => -(processTrack.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: processWrapper,
        pin: true,
        scrub: 1,
        end: () => `+=${processTrack.scrollWidth - window.innerWidth}`,
        invalidateOnRefresh: true
      }
    })

    // Helper to build from/to vars for a rect
    function buildRectVars(rect: HTMLElement) {
      const anim = rect.dataset.anim
      const w = rect.dataset.w + 'px'
      const h = rect.dataset.h + 'px'

      let fromVars: gsap.TweenVars = { opacity: 0 }
      let toVars: gsap.TweenVars = { opacity: 1, duration: 0.6, ease: 'power2.out' }

      switch (anim) {
        case 'grow-h':
          fromVars = { ...fromVars, height: 0, transformOrigin: 'bottom' }
          toVars = { ...toVars, height: h }
          break
        case 'grow-w':
          fromVars = { ...fromVars, width: 0, transformOrigin: 'left' }
          toVars = { ...toVars, width: w }
          break
        case 'grow-h-ttb':
          fromVars = { ...fromVars, height: 0, transformOrigin: 'top' }
          toVars = { ...toVars, height: h }
          break
        case 'grow-w-rtl':
          fromVars = { ...fromVars, width: 0, marginLeft: w }
          toVars = { ...toVars, width: w, marginLeft: '0px' }
          break
      }

      return { fromVars, toVars }
    }

    // Discover rects — animate on section entry (vertical scroll)
    const discoverContainer = document.getElementById('discover-rects')!
    const discoverRects = discoverContainer.querySelectorAll<HTMLElement>('.process-rect')

    discoverRects.forEach((rect, i) => {
      const { fromVars, toVars } = buildRectVars(rect)
      gsap.fromTo(rect, fromVars, {
        ...toVars,
        delay: i * 0.12,
        scrollTrigger: {
          trigger: processWrapper,
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      })
    })

    // All other rects — animate via horizontal containerAnimation
    const otherRects = document.querySelectorAll<HTMLElement>('.process-rect:not(#discover-rects .process-rect)')

    otherRects.forEach((rect) => {
      const { fromVars, toVars } = buildRectVars(rect)
      gsap.fromTo(rect, fromVars, {
        ...toVars,
        scrollTrigger: {
          trigger: rect,
          containerAnimation: processScrollTween,
          start: 'left 100%',
          toggleActions: 'play none none none'
        }
      })
    })

    // Dispatch event so Process.astro can initialise after pins are set up
    document.dispatchEvent(new CustomEvent('scrolltriggers:ready'))
  }

  // ── LAUNCH ──
  document.fonts.ready.then(() => {
    sizeAllTracks()
    initWordCycling()
    initHeroScroll()
    initScrollTriggers()
    ScrollTrigger.refresh()
    lenis.start()
  })

  window.addEventListener('resize', () => {
    sizeAllTracks()
    alignPixelToText()
    ScrollTrigger.refresh()
    lenis.resize()
  })
</script>
