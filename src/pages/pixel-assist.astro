---
import ContactForm from '@components/ContactForm.astro'
import EqualSign from '@components/signs/Equals.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'

const includes = [
  'Setup and training on your content',
  'Australian-based hosting',
  'Ongoing optimisation and tuning',
  'Monitoring and maintenance, support and improvements',
  'Monthly reporting on trends and insights from your knowledge base',
  'Privacy first approach to PII and sensitive data'
]
---

<Layout
  title="Pixel Assist | AI Knowledge Assistant for Websites"
  description="Turn your website into an expert. Pixel Assist is a managed, AI-powered knowledge assistant that answers customer questions instantly, reduces support load, and speeds up decisions."
>
  {/* ── Hero: pinned scroll section with parallax chat bubbles ── */}
  <section id="pa-hero" class="relative h-screen overflow-hidden bg-pixel-off-white">

    {/* ── Back bubble layer (z-1, behind text) ── */}
    <div
      class="pa-bubble pa-bubble--back hidden lg:block"
      data-speed="0.6"
      style="top: 35%; left: 5%; background-color: #c9b97a;"
    >What is the warranty period?</div>

    <div
      class="pa-bubble pa-bubble--back"
      data-speed="0.4"
      style="top: 14%; right: 8%; background-color: #e8c728;"
    >What's the difference between these products?</div>

    {/* ── Text layer (z-2, centred) ── */}
    <div class="absolute inset-0 flex flex-col items-center justify-center z-2 px-6 pointer-events-none">
      <h1 id="pa-h1" class="font-sans text-base lg:text-xl underline underline-offset-4 mb-4 text-center">Introducing Pixel Assist</h1>
      <div class="relative w-full max-w-[1000px]">
        <h2
          id="pa-phrase-1"
          class="pa-phrase text-center leading-[0.9] tracking-[-0.03em]"
          style="font-size: clamp(2.2rem, 7vw, 6.5rem);"
        >Your customers have questions.</h2>
        <h2
          id="pa-phrase-2"
          class="pa-phrase absolute inset-0 text-center leading-[0.9] tracking-[-0.03em] opacity-0"
          style="font-size: clamp(2.2rem, 7vw, 6.5rem);"
        >But hard to find answers result in customer drop-offs and lost business.</h2>
        <h2
          id="pa-phrase-3"
          class="pa-phrase absolute inset-0 text-center leading-[0.9] tracking-[-0.03em] opacity-0"
          style="font-size: clamp(2.2rem, 7vw, 6.5rem);"
        >What if we could offer instant answers &amp; convert those customers?</h2>
      </div>
    </div>

    {/* ── Front bubble layer (z-3, in front of text) ── */}
    <div
      class="pa-bubble pa-bubble--front"
      data-speed="1.0"
      style="top: 55%; left: 8%; background-color: #7ea0c4;"
    >Does this meet compliance requirements?</div>

    <div
      class="pa-bubble pa-bubble--front"
      data-speed="0.8"
      style="top: 72%; right: 8%; background-color: #4d9e8e;"
    >Which option is right for my situation?</div>

    {/* ── Typing indicator (fades in during phase 2) ── */}
    <div
      id="pa-typing"
      class="pa-bubble pa-bubble--front opacity-0"
      data-speed="0.7"
      style="top: 80%; right: 15%; background-color: #d4d0cb;"
    >
      <span class="flex gap-1 items-center">
        <span class="w-2 h-2 rounded-full bg-black/40"></span>
        <span class="w-2 h-2 rounded-full bg-black/50"></span>
        <span class="w-2 h-2 rounded-full bg-black/60"></span>
      </span>
    </div>

    {/* ── Late-entering elements (phase 3) ── */}
    <div
      id="pa-bubble-late"
      class="pa-bubble pa-bubble--front opacity-0"
      data-speed="0.5"
      style="top: 90%; right: 12%; background-color: #c9b97a;"
    >For a new.....</div>

    {/* Decorative squares */}
    <div
      id="pa-square-teal"
      class="pa-square pa-bubble--front opacity-0"
      data-speed="0.9"
      style="top: 78%; right: 3%; background-color: #4d9e8e;"
    ></div>
    <div
      id="pa-square-tan"
      class="pa-square pa-bubble--front opacity-0"
      data-speed="0.6"
      style="top: 88%; right: 22%; background-color: #c9b97a;"
    ></div>
  </section>

  <section class="py-6">
    <Grid>
      <div id="price" class="col-span-full lg:col-start-2 lg:col-span-5 lg:row-start-2">
        <p class="col-span-full lg:col-start-2 font-sans text-base lg:text-4xl text-pixel-blue pb-4 lg:pb-7">Pricing</p>
        <h2 class="leading-[0.9] tracking-[-0.03em] mb-6 text-3xl lg:text-7xl">Simple, predictable pricing</h2>
        <p class="flex gap-3 font-sans text-xl lg:text-3xl mb-10 lg:mt-10">
          <EqualSign size={28} desktopSize={50} />From $599 per month + onboarding
        </p>
      </div>

      <div
        id="includes"
        class="bg-pixel-cream col-span-full lg:col-span-5 lg:col-start-7 lg:row-start-2 flex flex-col px-5 lg:px-11 py-7 lg:pt-14 lg:pb-16"
      >
        <div class="px-5 py-4 bg-pixel-cream">
          <p class="font-sans text-xl lg:text-4xl text-white">Every implementation includes:</p>
        </div>

        <ul class="flex flex-col font-sans px-5 text-xl lg:text-3xl">
          {
            includes.map((item, i) => (
              <li class={`py-4 ${i < includes.length - 1 ? 'border-b border-white/80' : ''}`}>{item}</li>
            ))
          }
        </ul>
        <p class="font-sans text-xs text-black leading-[1.4] mt-3 px-5">
          Onboarding is scoped based on the size and complexity of your knowledge base. Designed to cost less than even
          a few hours of support time each month.
        </p>
      </div>
    </Grid>
  </section>

  <Grid>
    <ContactForm
      title="Make your knowledge easier to access"
      description="Your team already has the answers. Pixel Assist simply makes them instantly available to everyone who needs them.<br/><br/>If you’d like to explore whether it’s a fit for your organisation, we’d love to chat."
    />
  </Grid>
</Layout>

<style>
  .pa-bubble {
    position: absolute;
    font-family: var(--font-ibm-plex-sans);
    font-size: 0.85rem;
    line-height: 1.3;
    padding: 10px 14px;
    border-radius: 12px;
    max-width: 200px;
    will-change: transform;
  }
  .pa-bubble--back { z-index: 1; }
  .pa-bubble--front { z-index: 3; }
  .pa-square {
    position: absolute;
    width: 20px;
    height: 20px;
    will-change: transform;
  }
  .pa-phrase {
    will-change: opacity;
  }
  /* Centre the absolute phrases relative to the first (flow) phrase */
  .pa-phrase:not(:first-child) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'

  gsap.registerPlugin(ScrollTrigger)

  // ── Lenis smooth scroll ──
  const lenis = new Lenis()
  lenis.on('scroll', ScrollTrigger.update)
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000)
  })
  gsap.ticker.lagSmoothing(0)

  // ── Scoped context for cleanup ──
  const ctx = gsap.context(() => {
    const hero = document.getElementById('pa-hero')!
    const h1 = document.getElementById('pa-h1')!
    const phrase1 = document.getElementById('pa-phrase-1')!
    const phrase2 = document.getElementById('pa-phrase-2')!
    const phrase3 = document.getElementById('pa-phrase-3')!
    const typing = document.getElementById('pa-typing')!
    const bubbleLate = document.getElementById('pa-bubble-late')!
    const squareTeal = document.getElementById('pa-square-teal')!
    const squareTan = document.getElementById('pa-square-tan')!

    // Collect all bubbles for parallax
    const allBubbles = hero.querySelectorAll<HTMLElement>('[data-speed]')

    // ── Master timeline ──
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: hero,
        start: 'top top',
        end: '+=300%',
        pin: true,
        scrub: 1,
      }
    })

    // ── Bubble parallax (runs across entire timeline) ──
    allBubbles.forEach((bubble) => {
      const speed = parseFloat(bubble.dataset.speed || '0.5')
      tl.to(bubble, {
        y: () => -window.innerHeight * speed * 1.5,
        ease: 'none',
      }, 0)
    })

    // ── Phase 1 → Phase 2 text transition (~25–35%) ──
    // Fade out h1
    tl.to(h1, {
      opacity: 0,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.18)

    // Fade out phrase 1
    tl.to(phrase1, {
      opacity: 0,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.25)

    // Fade in phrase 2
    tl.to(phrase2, {
      opacity: 1,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.30)

    // Typing indicator fades in
    tl.to(typing, {
      opacity: 1,
      duration: 0.06,
      ease: 'power1.inOut',
    }, 0.35)

    // ── Phase 2 → Phase 3 text transition (~58–68%) ──
    // Fade out phrase 2
    tl.to(phrase2, {
      opacity: 0,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.58)

    // Fade in phrase 3
    tl.to(phrase3, {
      opacity: 1,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.63)

    // Late-entering elements fade in
    tl.to(bubbleLate, {
      opacity: 1,
      duration: 0.10,
      ease: 'power1.inOut',
    }, 0.55)

    tl.to(squareTeal, {
      opacity: 1,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.58)

    tl.to(squareTan, {
      opacity: 1,
      duration: 0.08,
      ease: 'power1.inOut',
    }, 0.60)

    // Typing indicator fades out in phase 3
    tl.to(typing, {
      opacity: 0,
      duration: 0.06,
      ease: 'power1.inOut',
    }, 0.65)

    // ── Mobile adjustments ──
    ScrollTrigger.matchMedia({
      '(max-width: 1023px)': () => {
        // Reposition bubbles for mobile
        gsap.set('[data-speed]', { clearProps: 'left,right,top' })
        // Positions tuned for mobile screenshots
        const bubbles = hero.querySelectorAll<HTMLElement>('.pa-bubble, .pa-square')
        bubbles.forEach((b) => {
          const text = b.textContent?.trim() || ''
          if (text.startsWith('What is the warranty')) {
            b.style.display = 'none' // hidden on mobile
          }
          if (text.startsWith("What's the difference")) {
            b.style.top = '8%'
            b.style.right = '5%'
            b.style.left = 'auto'
          }
          if (text.startsWith('Does this meet')) {
            b.style.top = '50%'
            b.style.left = '5%'
          }
          if (text.startsWith('Which option')) {
            b.style.top = '65%'
            b.style.left = '30%'
            b.style.right = 'auto'
          }
        })
      }
    })
  })

  // Clean up on Astro page transitions
  document.addEventListener('astro:before-swap', () => {
    ctx.revert()
    lenis.destroy()
  }, { once: true })
</script>
