---
import { Image } from 'astro:assets'
import ContactForm from '@components/ContactForm.astro'
import EqualSign from '@components/signs/Equals.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import fletcherImg from '@assets/fletcher-pixel-assist.webp'
import Plus from '@components/signs/Plus.astro'
import Equals from '@components/signs/Equals.astro'

const includes = [
  'Setup and training on your content',
  'Australian-based hosting',
  'Ongoing optimisation and tuning',
  'Monitoring and maintenance, support and improvements',
  'Monthly reporting on trends and insights from your knowledge base',
  'Privacy first approach to PII and sensitive data'
]
---

<Layout
  title="Pixel Assist | AI Knowledge Assistant for Websites"
  description="Turn your website into an expert. Pixel Assist is a managed, AI-powered knowledge assistant that answers customer questions instantly, reduces support load, and speeds up decisions."
  position="fixed"
>
  {/* ── Hero: pinned scroll section with parallax chat bubbles ── */}
  <section id="pa-hero" class="relative h-screen overflow-hidden bg-pixel-off-white">
    {/* ── Back bubble layer (z-1, behind text) ── */}
    <div
      class="pa-bubble pa-bubble--back hidden lg:block"
      data-speed="0.6"
      style="top: 35%; left: 5%; background-color: #c9b97a;"
    >
      What is the warranty period?
    </div>

    <div class="pa-bubble pa-bubble--back" data-speed="0.4" style="top: 14%; right: 8%; background-color: #e8c728;">
      What's the difference between these products?
    </div>

    {/* ── Text layer (z-2, centred) ── */}
    <div
      class="fixed inset-0 flex flex-col items-center justify-center z-2 px-6 pointer-events-none"
      id="pa-text-layer"
    >
      <h1 id="pa-h1" class="font-sans text-base lg:text-xl underline underline-offset-4 mb-4 text-center">
        Introducing Pixel Assist
      </h1>
      <div class="relative w-full max-w-[1000px]">
        <h2
          id="pa-phrase-1"
          class="pa-phrase text-center leading-[0.9] tracking-[-0.03em]"
          style="font-size: clamp(2.2rem, 7vw, 6.5rem);"
        >
          Your customers have questions.
        </h2>
        <h2
          id="pa-phrase-2"
          class="pa-phrase absolute inset-0 text-center leading-[0.9] tracking-[-0.03em] opacity-0"
          style="font-size: clamp(2.2rem, 7vw, 6.5rem);"
        >
          But hard to find answers result in customer drop-offs and lost business.
        </h2>
        <h2
          id="pa-phrase-3"
          class="pa-phrase absolute inset-0 text-center leading-[0.9] tracking-[-0.03em] opacity-0"
          style="font-size: clamp(2.2rem, 7vw, 6.5rem);"
        >
          <span
            >What if we could offer <span class="pa-highlight" id="pa-hl-1">instant answers</span> &amp; <span
              class="pa-highlight"
              id="pa-hl-2">convert</span
            > those <span class="pa-highlight" id="pa-hl-3">customers</span>?</span
          >
        </h2>
      </div>

      {/* ── Phase 4 text — left-aligned ── */}
      <div id="pa-phase-4" class="absolute inset-0 flex items-center opacity-0 px-6 lg:px-[10%]">
        <h2 class="leading-[0.9] tracking-[-0.03em]" style="font-size: clamp(2.5rem, 8vw, 7rem);">
          Meet<br /><span style="color: var(--accent-bgc);">Pixel Assist</span>
        </h2>
      </div>
    </div>

    {/* ── Front bubble layer (z-3, in front of text) ── */}
    <div class="pa-bubble pa-bubble--front" data-speed="1.0" style="top: 55%; left: 8%; background-color: #7ea0c4;">
      Does this meet compliance requirements?
    </div>

    <div class="pa-bubble pa-bubble--front" data-speed="0.8" style="top: 72%; right: 8%; background-color: #4d9e8e;">
      Which option is right for my situation?
    </div>

    {/* ── Typing indicator (fades in during phase 2) ── */}
    <div
      id="pa-typing"
      class="pa-bubble pa-bubble--front opacity-0"
      data-speed="0.7"
      style="top: 80%; right: 15%; background-color: #d4d0cb;"
    >
      <span class="flex gap-1 items-center">
        <span class="w-2 h-2 rounded-full bg-black/40"></span>
        <span class="w-2 h-2 rounded-full bg-black/50"></span>
        <span class="w-2 h-2 rounded-full bg-black/60"></span>
      </span>
    </div>

    {/* ── Late-entering elements (phase 3) ── */}
    <div
      id="pa-bubble-late"
      class="pa-bubble pa-bubble--front opacity-0"
      data-speed="0.5"
      style="top: 90%; right: 12%; background-color: #c9b97a;"
    >
      For a new.....
    </div>

    {/* ── Phase 4: Chatbot conversation UI ── */}
    <div id="pa-chatbot" class="absolute z-4 opacity-0" style="right: 16%; top: 30%; width: min(340px, 80vw);">
      {/* User message row */}
      <div class="flex items-start gap-2.5 justify-end mb-3">
        <div
          class="rounded-xl px-3.5 py-2.5 font-sans text-[0.8125rem] leading-[1.45] bg-pixel-light-pink"
          style="color: #1f2937;"
        >
          What is Pixel Assist?
        </div>
        <div class="w-7 h-7 shrink-0 mt-0.5 bg-pixel-pink"></div>
      </div>
      {/* AI response row */}
      <div class="flex items-start gap-2.5">
        <div class="w-7 h-7 shrink-0 mt-0.5 bg-pixel-blue"></div>
        <div
          id="pa-ai-bubble"
          class="rounded-xl px-3.5 py-2.5 font-sans text-[0.8125rem] leading-[1.45] bg-pixel-light-blue"
          style="color: #1f2937;"
        >
          <span id="pa-ai-dots" class="flex items-center gap-[0.3rem] h-5 px-0.5">
            <span class="pa-dot"></span>
            <span class="pa-dot" style="animation-delay: 0.16s;"></span>
            <span class="pa-dot" style="animation-delay: 0.32s;"></span>
          </span>
          <span id="pa-ai-text" class="hidden"></span>
        </div>
      </div>
    </div>

    {/* ── Scrolling bubbles — varied speeds for parallax, staggered positions ── */}
    {/* Phase 1 */}
    <div class="pa-bubble pa-bubble--back" data-speed="1.5" style="top: 110%; left: 6%; background-color: #c9b97a;">
      Where can I find the spec sheet?
    </div>
    <div class="pa-bubble pa-bubble--front" data-speed="1.3" style="top: 120%; right: 12%; background-color: #7ea0c4;">
      Do you ship internationally?
    </div>

    {/* Early Phase 2 */}
    <div class="pa-bubble pa-bubble--back" data-speed="1.3" style="top: 140%; left: 15%; background-color: #e8c728;">
      How do I get started?
    </div>
    <div class="pa-bubble pa-bubble--front" data-speed="1.4" style="top: 175%; right: 5%; background-color: #4d9e8e;">
      Can I integrate with my CRM?
    </div>
    <div class="pa-bubble pa-bubble--back" data-speed="1.2" style="top: 190%; left: 3%; background-color: #7ea0c4;">
      What are the payment options?
    </div>

    {/* Mid Phase 2 */}
    <div class="pa-bubble pa-bubble--front" data-speed="1.2" style="top: 230%; right: 20%; background-color: #c9b97a;">
      Is my data secure?
    </div>
    <div class="pa-bubble pa-bubble--back" data-speed="1.3" style="top: 190%; left: 75%; background-color: #e8c728;">
      What languages do you support?
    </div>
    <div class="pa-bubble pa-bubble--front" data-speed="1.1" style="top: 260%; left: 2%; background-color: #4d9e8e;">
      Can it handle technical questions?
    </div>
    <div class="pa-bubble pa-bubble--back" data-speed="1.15" style="top: 240%; right: 13%; background-color: #e8c728;">
      What reporting is included?
    </div>
    <div class="pa-bubble pa-bubble--front bg-pixel-orange" data-speed="1.05" style="top: 275%; left: 15%; ">
      Can I customise the responses?
    </div>
    <div class="pa-bubble pa-bubble--back" data-speed="1.25" style="top: 210%; right: 30%; background-color: #7ea0c4;">
      How does onboarding work?
    </div>
    <div class="pa-bubble pa-bubble--back bg-pixel-blue" data-speed="1.1" style="top: 250%; left: 42%;">
      What's the uptime guarantee?
    </div>
    <div class="pa-bubble pa-bubble--back" data-speed="1.2" style="top: 290%; right: 5%; background-color: #e8c728;">
      Who manages the knowledge base?
    </div>

    {/* Late Phase 2 → Phase 3 */}
    <div class="pa-bubble pa-bubble--back" data-speed="1.1" style="top: 340%; right: 8%; background-color: #7ea0c4;">
      How accurate are the answers?
    </div>
    <div class="pa-bubble pa-bubble--back" data-speed="1.2" style="top: 330%; left: 35%; background-color: #c9b97a;">
      Does it learn over time?
    </div>

    {/* Phase 3 */}
    <div class="pa-bubble pa-bubble--front" data-speed="1.1" style="top: 370%; left: 8%; background-color: #4d9e8e;">
      Can visitors ask follow-ups?
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <Grid>
      <div
        class="col-span-12 text-center py-7.5 lg:py-24 bg-pixel-off-cream font-sans text-xl lg:text-3xl leading-[1.2] lg:leading-[1.04] tracking-[-0.04em]"
      >
        <p class="">
          Most websites store knowledge.<br />
          Very few make it easy to use.
        </p>
        <p class="mt-8 lg:mt-12">
          Product details live in PDFs.<br />
          Policies sit across multiple pages.<br />
          Support teams answer the same questions<br />
          every day.
        </p>
        <p class="mt-8 lg:mt-12">
          When information is hard to access,<br />
          people slow down — or leave.<br />
          Decisions get delayed.
        </p>
        <p class="mt-8 lg:mt-12">
          Support costs increase.<br />
          Opportunities are lost.
        </p>
        <p class="mt-8 lg:mt-12">
          Your website should remove friction,<br />
          not create it.
        </p>
      </div>
    </Grid>
  </section>

  <section id="who" class="py-16 lg:py-24">
    <Grid>
      {/* Left: Who is Pixel Assist for */}
      <div class="col-span-12 lg:col-start-2 lg:col-span-5">
        <h2 class="font-sans font-normal lg:text-4xl text-pixel-red pb-4 lg:pb-7">Who is Pixel Assist for?</h2>
        <div class="text-[16px] lg:text-[24px] tracking-[-0.01em] font-sans text-base leading-[1.5]">
          <p>
            Common examples include manufacturers and wholesalers, education and training providers, professional
            services firms, SaaS and technology platforms, and internal knowledge bases and portals.
          </p>
          <p class="mt-5 lg:mt-7">If your team repeatedly answers the same questions, this is likely a fit.</p>
        </div>
      </div>

      {/* Right: Pixel Assist is ideal for */}
      <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-10 lg:mt-0">
        <p
          class="font-sans font-normal text-[20px] lg:text-[30px] leading-[1.2] lg:leading-[1.28] tracking-[-0.04em] mb-6 lg:mb-10"
        >
          Pixel Assist is ideal for organisations with:
        </p>
        <ul class="flex flex-col gap-5 lg:gap-7">
          {
            [
              'Large knowledge bases',
              'Detailed or technical products',
              'Compliance or policy documentation',
              'Complex services',
              'Frequent support questions'
            ].map((item) => (
              <li class="flex items-center gap-3 font-sans font-normal text-[20px] lg:text-[30px] leading-[1.2] lg:leading-[1.28] tracking-[-0.04em]">
                <span class="shrink-0 w-[12px] h-[12px] bg-pixel-red" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </Grid>
  </section>

  <!-- bg-pixel-off-cream -->

  <section id="case-study" class="py-16 lg:py-24">
    <Grid>
      <div class="col-span-full py-10 lg:py-14 grid grid-cols-12 gap-5 mb-9 sm:mb-12 bg-pixel-off-cream">
        {/* Left: Case study label + heading + description */}
        <div class="col-span-12 lg:col-start-2 lg:col-span-3">
          <p class="font-sans font-normal lg:text-4xl text-pixel-light-orange pb-4 lg:pb-7">Case study</p>
          <h2 class="font-sans font-normal text-4xl lg:text-6xl leading-[0.95] tracking-[-0.03em] mb-6 lg:mb-10">
            Fletcher Insulation
          </h2>
          <p class="font-sans text-sm lg:text-base leading-[1.5] tracking-[-0.01em]">
            Fletcher Insulation manages a large catalogue of technical products supported by datasheets, compliance
            documentation, and specifications. For trades, architects, and project teams, finding the right information
            often meant searching across multiple pages or contacting support.
          </p>
        </div>

        {/* Middle: Branded example image */}
        <div class="col-span-12 lg:col-span-4 flex items-end justify-center">
          <Image src={fletcherImg} alt="Fletcher Insulation — Pixel Assist chatbot UI" />
        </div>

        {/* Right: Results copy */}
        <div class="col-span-12 lg:col-span-3 flex flex-col items-center justify-end">
          <p class="font-sans text-sm lg:text-base leading-[1.5] tracking-[-0.01em]">
            We implemented Pixel Assist to answer product and compliance questions instantly
            <Plus size={20} desktopSize={30} />
            make technical information easier to access, reduce repetitive support requests, and help customers choose products
            with confidence.
          </p>
          <p class="font-sans text-sm lg:text-base leading-[1.5] tracking-[-0.01em] mt-4">
            The result <Equals size={20} desktopSize={30} /> is a faster, smoother experience for users — and a website that
            actively supports decision-making rather than simply hosting information. The same approach can be configured
            for any organisation with complex knowledge.
          </p>
        </div>
      </div>
    </Grid>
  </section>

  <section id="pricing" class="py-6">
    <Grid>
      <div id="price" class="col-span-full lg:col-start-2 lg:col-span-5 lg:row-start-2">
        <p class="col-span-full lg:col-start-2 font-sans font-normal lg:text-4xl text-pixel-blue pb-4 lg:pb-7">
          Pricing
        </p>
        <h2 class="leading-[0.9] tracking-[-0.03em] mb-6 text-3xl lg:text-7xl">Simple, predictable pricing</h2>
        <p class="flex gap-3 font-sans text-xl lg:text-3xl mb-10 lg:mt-10">
          <EqualSign size={28} desktopSize={50} />From $599 per month + onboarding
        </p>
      </div>

      <div
        id="includes"
        class="bg-pixel-cream col-span-full lg:col-span-5 lg:col-start-7 lg:row-start-2 flex flex-col px-5 lg:px-11 py-7 lg:pt-14 lg:pb-16"
      >
        <div class="px-5 py-4 bg-pixel-cream">
          <p class="font-sans text-xl lg:text-4xl text-white">Every implementation includes:</p>
        </div>

        <ul class="flex flex-col font-sans px-5 text-xl lg:text-3xl">
          {
            includes.map((item, i) => (
              <li class={`py-4 ${i < includes.length - 1 ? 'border-b border-white/80' : ''}`}>{item}</li>
            ))
          }
        </ul>
        <p class="font-sans text-xs text-black leading-[1.4] mt-3 px-5">
          Onboarding is scoped based on the size and complexity of your knowledge base. Designed to cost less than even
          a few hours of support time each month.
        </p>
      </div>
    </Grid>
  </section>

  <Grid>
    <ContactForm
      title="Make your knowledge easier to access"
      description="Your team already has the answers. Pixel Assist simply makes them instantly available to everyone who needs them.<br/><br/>If you’d like to explore whether it’s a fit for your organisation, we’d love to chat."
    />
  </Grid>
</Layout>

<style>
  .pa-bubble {
    position: absolute;
    font-family: var(--font-ibm-plex-sans);
    font-size: 0.85rem;
    line-height: 1.3;
    padding: 10px 14px;
    border-radius: 12px;
    max-width: 200px;
    will-change: transform;
  }
  .pa-bubble--back {
    z-index: 1;
  }
  .pa-bubble--front {
    z-index: 3;
  }
  .pa-square {
    position: absolute;
    width: 20px;
    height: 20px;
    will-change: transform;
  }
  .pa-phrase {
    will-change: opacity;
  }
  /* Centre the absolute phrases relative to the first (flow) phrase */
  .pa-phrase:not(:first-child) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pa-highlight {
    background: linear-gradient(var(--accent-bgc) 0 0) no-repeat;
    background-size: 0% 1.15em;
    background-position: 0 95%;
    padding: 0 0.1em;
  }
  .pa-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #60a5fa;
    animation: pa-dot-bounce 1.4s infinite ease-in-out both;
  }
  @keyframes pa-dot-bounce {
    0%,
    80%,
    100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-5px);
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'

  gsap.registerPlugin(ScrollTrigger)

  // ── Lenis smooth scroll ──
  const lenis = new Lenis()
  lenis.on('scroll', ScrollTrigger.update)
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000)
  })
  gsap.ticker.lagSmoothing(0)

  // ── Scoped context for cleanup ──
  const ctx = gsap.context(() => {
    const hero = document.getElementById('pa-hero')!
    const textLayer = document.getElementById('pa-text-layer')!
    const h1 = document.getElementById('pa-h1')!
    const phrase1 = document.getElementById('pa-phrase-1')!
    const phrase2 = document.getElementById('pa-phrase-2')!
    const phrase3 = document.getElementById('pa-phrase-3')!
    const typing = document.getElementById('pa-typing')!
    const bubbleLate = document.getElementById('pa-bubble-late')!
    const squareTeal = document.getElementById('pa-square-teal')!
    const squareTan = document.getElementById('pa-square-tan')!
    const phase4 = document.getElementById('pa-phase-4')!
    const chatbot = document.getElementById('pa-chatbot')!
    const aiDots = document.getElementById('pa-ai-dots')!
    const aiText = document.getElementById('pa-ai-text')!
    const hl1 = document.getElementById('pa-hl-1')!
    const hl2 = document.getElementById('pa-hl-2')!
    const hl3 = document.getElementById('pa-hl-3')!

    const AI_RESPONSE =
      'A managed, AI-powered knowledge assistant for your website. It learns your content \u2014 products, documentation, specifications, policies, FAQs, and internal knowledge \u2014 and uses it to answer questions in plain language, in real time.'

    // Push chatbot below viewport initially
    gsap.set(chatbot, { y: window.innerHeight * 1.5 })

    // Collect all bubbles for parallax
    const allBubbles = hero.querySelectorAll<HTMLElement>('[data-speed]')

    // ── Master timeline ──
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: hero,
        start: 'top top',
        end: '+=400%',
        pin: true,
        scrub: 1,
        onLeave: () => {
          // Keep phase 4 text visible: only hide phases 1-3 elements
          h1.style.display = 'none'
          phrase1.style.display = 'none'
          phrase2.style.display = 'none'
          phrase3.style.display = 'none'
        },
        onEnterBack: () => {
          h1.style.display = ''
          phrase1.style.display = ''
          phrase2.style.display = ''
          phrase3.style.display = ''
        }
      }
    })

    // ── Bubble parallax (runs across ENTIRE timeline) ──
    allBubbles.forEach((bubble) => {
      const speed = parseFloat(bubble.dataset.speed || '0.5')
      tl.to(
        bubble,
        {
          y: () => -window.innerHeight * speed * 5,
          duration: 1,
          ease: 'none'
        },
        0
      )
    })

    // ── Phase 1 → Phase 2 text transition (~0.15–0.22) ──
    // Fade out h1
    tl.to(
      h1,
      {
        opacity: 0,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.13
    )

    // Fade out phrase 1
    tl.to(
      phrase1,
      {
        opacity: 0,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.17
    )

    // Fade in phrase 2
    tl.to(
      phrase2,
      {
        opacity: 1,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.21
    )

    // Typing indicator fades in
    tl.to(
      typing,
      {
        opacity: 1,
        duration: 0.04,
        ease: 'power1.inOut'
      },
      0.26
    )

    // ── Phase 2 → Phase 3 text transition (~0.37–0.44) ──
    // Fade out phrase 2
    tl.to(
      phrase2,
      {
        opacity: 0,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.37
    )

    // Fade in phrase 3
    tl.to(
      phrase3,
      {
        opacity: 1,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.42
    )

    // Highlight sweeps — scroll-scrubbed, staggered
    tl.fromTo(
      hl1,
      { backgroundSize: '0% 1.15em' },
      { backgroundSize: '100% 1.15em', duration: 0.04, ease: 'none' },
      0.44
    )
    tl.fromTo(
      hl2,
      { backgroundSize: '0% 1.15em' },
      { backgroundSize: '100% 1.15em', duration: 0.04, ease: 'none' },
      0.49
    )
    tl.fromTo(
      hl3,
      { backgroundSize: '0% 1.15em' },
      { backgroundSize: '100% 1.15em', duration: 0.04, ease: 'none' },
      0.53
    )

    // Late-entering elements fade in
    tl.to(
      bubbleLate,
      {
        opacity: 1,
        duration: 0.08,
        ease: 'power1.inOut'
      },
      0.38
    )

    tl.to(
      squareTeal,
      {
        opacity: 1,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.4
    )

    tl.to(
      squareTan,
      {
        opacity: 1,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.42
    )

    // Typing indicator fades out in phase 3
    tl.to(
      typing,
      {
        opacity: 0,
        duration: 0.04,
        ease: 'power1.inOut'
      },
      0.46
    )

    // ── Phase 3 → Phase 4 transition ──
    // Chatbot enters from below (0.45 → 0.65)
    tl.to(chatbot, { opacity: 1, duration: 0.02, ease: 'power1.in' }, 0.45)
    tl.to(chatbot, { y: 0, duration: 0.2, ease: 'none' }, 0.45)

    // Fade out phrase 3
    tl.to(
      phrase3,
      {
        opacity: 0,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.57
    )

    // Fade in phase 4 text
    tl.to(
      phase4,
      {
        opacity: 1,
        duration: 0.06,
        ease: 'power1.inOut'
      },
      0.62
    )

    // AI typing dots → text streaming (0.70 → 0.90)
    tl.to(
      {},
      {
        duration: 0.2,
        ease: 'none',
        onUpdate: function () {
          const p = this.progress()
          if (p > 0) {
            aiDots.style.display = 'none'
            aiText.classList.remove('hidden')
            aiText.textContent = AI_RESPONSE.substring(0, Math.ceil(p * AI_RESPONSE.length))
          } else {
            aiDots.style.display = ''
            aiText.classList.add('hidden')
            aiText.textContent = ''
          }
        }
      },
      0.7
    )

    // ── Mobile adjustments ──
    ScrollTrigger.matchMedia({
      '(max-width: 1023px)': () => {
        // Reposition bubbles for mobile
        gsap.set('[data-speed]', { clearProps: 'left,right,top' })
        // Positions tuned for mobile screenshots
        const bubbles = hero.querySelectorAll<HTMLElement>('.pa-bubble, .pa-square')
        bubbles.forEach((b) => {
          const text = b.textContent?.trim() || ''
          if (text.startsWith('What is the warranty')) {
            b.style.display = 'none' // hidden on mobile
          }
          if (text.startsWith("What's the difference")) {
            b.style.top = '8%'
            b.style.right = '5%'
            b.style.left = 'auto'
          }
          if (text.startsWith('Does this meet')) {
            b.style.top = '50%'
            b.style.left = '5%'
          }
          if (text.startsWith('Which option')) {
            b.style.top = '65%'
            b.style.left = '30%'
            b.style.right = 'auto'
          }
        })
      }
    })
  })

  // Clean up on Astro page transitions
  document.addEventListener(
    'astro:before-swap',
    () => {
      ctx.revert()
      lenis.destroy()
    },
    { once: true }
  )
</script>
