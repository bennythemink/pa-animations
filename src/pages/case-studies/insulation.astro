---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import CaseStudySectionText from '@components/case-studies/case-study/CaseStudySectionText.astro'
import CaseStudyResults from '@components/case-studies/case-study/CaseStudyResults.astro'
import CaseStudyHeader from '@components/case-studies/case-study/CaseStudyHeader.astro'
import CaseStudyToggleButton from '@components/case-studies/case-study/CaseStudyToggleButton.astro'
import CaseStudyMetaData from '@components/case-studies/case-study/CaseStudyMetaData.astro'
import CaseStudyShout from '@components/case-studies/case-study/CaseStudyShout.astro'
import CaseStudyNav from '@components/case-studies/case-study/CaseStudyNav.astro'
import CaseStudyImages from '@components/case-studies/case-study/CaseStudyImages.astro'
import { getCaseStudyNav } from '@data/caseStudies'

import hero from '@assets/case-studies/insulation/hero.webp'
import squareOne from '@assets/case-studies/insulation/squareOne.svg'
import squareTwo from '@assets/case-studies/insulation/squareTwo.webp'
import wideOne from '@assets/case-studies/insulation/wideOne.webp'
import wideTwo from '@assets/case-studies/insulation/wideTwo.webp'

const { previous, next } = getCaseStudyNav('insulation')
---

<Layout
  title="Fletcher Insulation"
  description="How Pixel Agency rebuilt Fletcher Insulation's website, driving a 40% lift in visitors and 300%+ increase
in session time — while cutting support requests by 30%."
>
  <article id="case-study-page">
    <CaseStudyHeader>
      <span slot="title">Fletcher Insulation</span>
      <span slot="industry">Construction, Manufacturing</span>
      <span slot="services">Discovery + direction, Design, Development</span>
      <span slot="duration">3 months</span>
    </CaseStudyHeader>

    <CaseStudyToggleButton />

    <!-- Single shell: all images + summary (left pane) / all case study text (right pane) -->
    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <CaseStudyImages
              heroImage={{ src: hero }}
              summary="A discovery-led approach that helped Australia's insulation leader build a digital presence worthy of their reputation."
              squareImages={[{ src: squareOne }, { src: squareTwo }]}
              wideImages={[{ src: wideOne }, { src: wideTwo }]}
            />
          </div>

          <div class="case-study-right-pane min-w-0">
            <CaseStudyShout>Making insulation distinctive + memorable.</CaseStudyShout>

            <CaseStudySectionText title="The client" noTopMargin={true}>
              <p>
                Fletcher Insulation is one of Australia's leading suppliers of insulation products, operating in a B2B
                environment and serving trades, architects, builders, and project teams across the country. They own one
                of the most authoritative domains in their category, insulation.com.au, and have built a reputation for
                quality that their previous digital presence simply didn't reflect.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The problem">
              <p>
                When Fletcher Insulation approached Pixel Agency, their website was dated and undifferentiated. In a
                competitive B2B market where trust and authority matter, their digital presence was blending into the
                background rather than reinforcing their position as a category leader. Their information was hard to
                find, the experience wasn't mobile-friendly, and the site wasn't keeping pace with a new brand direction
                they were already investing in through a separate branding agency.
              </p><br />
              <p>
                Their internal IT team was experienced in infrastructure and hardware, but translating a new brand
                strategy into a cohesive, high-quality web presence required a different kind of expertise. Without the
                right digital partner, they risked launching a new brand with a website that undermined it.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The approach">
              <p>
                We started where we always start: understanding the business before touching a design tool. We ran a
                structured in-person discovery workshop with twelve of Fletcher Insulation's key stakeholders, spanning
                marketing, product, IT, operations, finance, and their branding agency, to surface what the website
                needed to do, for whom, and why.
              </p><br />
              <p>
                That workshop gave us a clear picture of their website visitors, the questions those visitors needed
                answered, the information that needed to be front and centre, and the internal processes that would
                shape how the site was maintained after launch. We followed up with targeted virtual sessions with each
                department to go deeper before presenting a proposed solution, cost, and timeline.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The solution">
              <p>
                Working closely with their branding agency, we translated the new brand identity into a digital
                experience designed to perform, not just look the part. The result was a website that matched the
                quality Fletcher Insulation was known for: clear, authoritative, and easy to use.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The results">
              <p>The impact was clear and it came quickly:</p>
              <CaseStudyResults
                results={[
                  {
                    title: '40% increase',
                    description: 'in website visitors following launch',
                    backgroundColour: 'pixel-yellow'
                  },
                  {
                    title: '300%+ increase',
                    description: 'in average session time',
                    backgroundColour: 'pixel-celestial'
                  },
                  {
                    title: '30%+ reduction',
                    description: 'in support requests',
                    backgroundColour: 'pixel-rosy'
                  }
                ]}
              />
              <p class="mt-6">
                Qualitative user feedback highlighted a dramatically improved experience: information was easier to
                find, the site was properly mobile-friendly, and it was distinctive.
              </p><br />

              <div class="mt-6 lg:mt-12"></div>

              <CaseStudyShout>
                For Fletcher Insulation, a site that reduces support load while increasing engagement is more than a
                better website. It's a sales and service asset that's always available.
              </CaseStudyShout>
            </CaseStudySectionText>

            <CaseStudyMetaData
              client={{ name: 'Fletcher Insulation', url: 'https://www.insulation.com.au' }}
              industry={['Construction', 'Manufacturing']}
              serviceNames={['Discovery + direction', 'Design', 'Development']}
            />
          </div>
        </div>
      </Grid>
    </section>

    {/* Navigation section */}
    <CaseStudyNav previousCaseStudy={previous} nextCaseStudy={next} />

    <ContactForm title="Discuss a similar challenge" displayDescription={false} />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: var(--color-pixel-placeholder-grey);
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
