---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import mbImage from '@assets/mb.png'
import CaseStudySectionText from '@components/case-studies/case-study/CaseStudySectionText.astro'
import CaseStudyResults from '@components/case-studies/case-study/CaseStudyResults.astro'
import CaseStudyHeader from '@components/case-studies/case-study/CaseStudyHeader.astro'
import CaseStudyToggleButton from '@components/case-studies/case-study/CaseStudyToggleButton.astro'
import CaseStudyMetaData from '@components/case-studies/case-study/CaseStudyMetaData.astro'
import CaseStudyShout from '@components/case-studies/case-study/CaseStudyShout.astro'
import CaseStudyNav from '@components/case-studies/case-study/CaseStudyNav.astro'
import CaseStudyImages from '@components/case-studies/case-study/CaseStudyImages.astro'
import { getCaseStudyNav } from '@data/caseStudies'

import hero from '@assets/case-studies/dare/hero.webp'
import squareOne from '@assets/case-studies/dare/squareOne.svg'
import squareTwo from '@assets/case-studies/dare/squareTwo.webp'
import wideOne from '@assets/case-studies/dare/wideOne.webp'
import wideTwo from '@assets/case-studies/dare/wideTwo.webp'

const { previous, next } = getCaseStudyNav('dare')
---

<Layout
  title="Dare Iced Coffee Case Study"
  description="How Pixel Agency transformed Dare Iced Coffee's digital presence, delivering a 200%+ increase in time on site and a meaningful reduction in support load."
>
  <article id="case-study-page">
    <CaseStudyHeader>
      <span slot="title">Dare Iced Coffee</span>
      <span slot="industry">Food & Beverage</span>
      <span slot="services">Discovery + direction, Design, Development</span>
      <span slot="duration">3 months</span>
    </CaseStudyHeader>

    <CaseStudyToggleButton />

    <!-- Single shell: all images + summary (left pane) / all case study text (right pane) -->
    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <CaseStudyImages
              heroImage={{ src: hero }}
              summary="How a discovery-led portal helped connect overlooked talent with local businesses. And placed over 80 students into employment."
              squareImages={[{ src: squareOne }, { src: squareTwo }]}
              wideImages={[{ src: wideOne }, { src: wideTwo }]}
            />
          </div>

          <div class="case-study-right-pane min-w-0">
            <CaseStudyShout>Connecting overlooked talent with local businesses.</CaseStudyShout>

            <CaseStudySectionText title="The client" noTopMargin={true}>
              <p class="">
                Dare Iced Coffee, owned by Bega, is one of Australia's most recognised iced coffee brands and a
                fridge-door staple for millions of Australians. From tradies grabbing one on the way to site to families
                picking up a multipack at the supermarket, Dare has earned its place in Australian culture through
                decades of bold branding and consistent product quality.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The problem" textColour="text-pixel-red">
              <p>
                Despite strong brand recognition in the real world, Dare's digital presence hadn't kept pace. The
                existing website was dated, difficult to navigate, and not something the team felt confident linking to
                when running promotions, competitions, or advertising campaigns. For a brand that regularly drives
                traffic through above-the-line marketing, the website was the weak link: the place where momentum
                stalled rather than converted into engagement.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The approach" textColour="text-pixel-orange">
              <p>
                We started with a discovery phase and market research to understand how Dare's audience interacted with
                the brand online: what they were looking for, where they were dropping off, and what the website needed
                to do beyond simply existing. That research shaped everything that followed.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The solution" textColour="text-pixel-green">
              <p>
                Working within Dare's strict brand guidelines, and navigating a challenging set of existing assets, we
                designed and built a WordPress website that matched the energy of the brand itself. The solution had two
                clear goals: a bold, engaging experience for Dare's audience, and a practical content management system
                that gave the internal team real control over their digital presence.
              </p><br />
              <p>
                Beyond the initial redesign, we built dedicated web pages for promotions and competitions as they
                launched, kept the site updated with fresh content, and upskilled the Dare team so they could handle
                day-to-day content updates independently. What started as a website project became an ongoing digital
                partnership that ran for several years.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The results" textColour="text-pixel-blue">
              <p>The impact on Dare's digital presence was significant:</p>
              <CaseStudyResults
                results={[
                  {
                    title: '200%+ increase in average time on site',
                    description: 'visitors were engaging with the brand rather than bouncing',
                    backgroundColour: '#e8c42f'
                  },
                  {
                    title: '18% reduction in support enquiries',
                    description: 'new site structure helped people find what they needed',
                    backgroundColour: '#6498c9'
                  },
                  {
                    title: 'Proud digital presence',
                    description: 'that the team could confidently showcase',
                    backgroundColour: '#F37992'
                  },
                  {
                    title: 'Full content independence',
                    description: 'for the internal team on day-to-day updates',
                    backgroundColour: '#599e83'
                  }
                ]}
              />

              <div class="mt-6 lg:mt-12"></div>

              <CaseStudyShout>
                For a consumer brand that drives traffic through national campaigns, a website that converts attention
                into engagement isn't a nice-to-have. It's the difference between a campaign that lands and one that
                doesn't.
              </CaseStudyShout>
            </CaseStudySectionText>

            <CaseStudyMetaData
              client={{ name: 'Dare Iced Coffee', url: 'https://dareicedcoffee.com.au/' }}
              industry={['Food & Beverage']}
              serviceNames={['Discovery + direction', 'Design', 'Development']}
            />
          </div>
        </div>
      </Grid>
    </section>

    {/* Navigation section */}
    <CaseStudyNav previousCaseStudy={previous} nextCaseStudy={next} />

    <ContactForm
      title="Discuss a similar challenge"
      backgroundColor="var(--color-pixel-pink)"
      displayDescription={false}
    />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: #d9d9d9;
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
