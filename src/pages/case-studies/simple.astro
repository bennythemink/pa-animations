---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import mbImage from '@assets/mb.png'
import CaseStudySectionText from '@components/case-studies/case-study/CaseStudySectionText.astro'
import CaseStudyResults from '@components/case-studies/case-study/CaseStudyResults.astro'
import CaseStudyHeader from '@components/case-studies/case-study/CaseStudyHeader.astro'
import CaseStudyToggleButton from '@components/case-studies/case-study/CaseStudyToggleButton.astro'
import CaseStudyMetaData from '@components/case-studies/case-study/CaseStudyMetaData.astro'
import CaseStudyShout from '@components/case-studies/case-study/CaseStudyShout.astro'
import CaseStudyNav from '@components/case-studies/case-study/CaseStudyNav.astro'
import CaseStudyImages from '@components/case-studies/case-study/CaseStudyImages.astro'

import hero from '@assets/case-studies/simple/hero.webp'
import squareOne from '@assets/case-studies/simple/squareOne.svg'
import squareTwo from '@assets/case-studies/simple/squareTwo.webp'
import wideOne from '@assets/case-studies/simple/wideOne.webp'
import wideTwo from '@assets/case-studies/simple/wideTwo.webp'
---

<Layout
  title="Simple.io"
  description="Agency redesigned Simple.io's website, increasing leads by 26% and time on site by 76% — helping a MarTech
SaaS stand out in a competitive enterprise market."
>
  <article id="case-study-page">
    <CaseStudyHeader>
      <span slot="title">Simple.io</span>
      <span slot="industry">SaaS</span>
      <span slot="services">Discovery + direction, Design, Development</span>
      <span slot="duration">3 months</span>
    </CaseStudyHeader>

    <CaseStudyToggleButton />

    <!-- Single shell: all images + summary (left pane) / all case study text (right pane) -->
    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <CaseStudyImages
              heroImage={{ src: hero }}
              summary="A discovery-led redesign that helped an Australian SaaS platform cut through conservative branding, find its personality, and lift website leads by 26%."
              squareImages={[{ src: squareOne }, { src: squareTwo }]}
              wideImages={[{ src: wideOne }, { src: wideTwo }]}
            />
          </div>

          <div class="case-study-right-pane min-w-0">
            <CaseStudyShout>Making SaaS distinctive + memorable.</CaseStudyShout>

            <CaseStudySectionText title="The client" noTopMargin={true}>
              <p>
                Simple.io is an Australian-based marketing technology company that provides a cloud-based Marketing
                Operations Management platform. They help enterprise marketing teams, creative agencies, and retail
                brands streamline their marketing lifecycle, from initial planning and briefing through to final asset
                approval and storage. Their client list includes household names like RACV, Woolworths, Hesta, Bendigo
                Bank, and NIB.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The problem" textColour="text-pixel-red">
              <p>
                Simple had a strong product and a strong client base, but their website was holding them back.
                Overloaded with information and difficult to navigate, the site made the user journey feel unnecessarily
                complex. Visitors struggled to find the calls-to-action they needed, and the site wasn't converting
                traffic into the demos and leads the sales team depended on. For a SaaS business where the website is
                the primary sales engine, underperformance wasn't only a design problem. It was a revenue problem.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The approach" textColour="text-pixel-orange">
              <p>
                We started with discovery and market research to understand how Simple's audience was navigating the
                existing site, where they were dropping off, and what was getting in the way of conversion. That
                research shaped both the structure and the personality of the new site.
              </p><br />
              <p>
                One of the most significant outcomes of discovery was a shift in creative direction. Simple's existing
                branding was conservative and corporate: functional, but forgettable in a crowded MarTech market.
                Through the discovery process, we made the case for introducing a distinctive illustration-led visual
                language that would give the brand personality and warmth without undermining its enterprise
                credibility. It was a conversation that required trust on both sides. The client needed convincing, and
                we needed to demonstrate that standing out would serve them better than blending in.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The solution" textColour="text-pixel-green">
              <p>
                We redesigned the full website with a streamlined structure built around a single clear goal: getting
                the right visitors to the right information and making it easy to book a demo. CTAs were placed where
                they made sense within the user's journey rather than interrupting it. Each product area was given
                clear, focused messaging so visitors could quickly understand what was relevant to them.
              </p><br />
              <p>
                Mid-project, Simple restructured some of their service offerings, which meant revisiting the site
                architecture and messaging we'd already built. We adapted quickly, reshaping the structure to reflect
                the new direction without losing momentum or compromising the quality of the final result.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The results" textColour="text-pixel-blue">
              <p>The impact on Simple's lead generation was immediate:</p>
              <CaseStudyResults
                results={[
                  {
                    title: '26% increase in website leads',
                    description: 'More visitors converting into demo bookings + sales conversations',
                    backgroundColour: '#e8c42f'
                  },
                  {
                    title: '76% increase in average time on site',
                    description: 'Visitors engaging more deeply with the content rather than bouncing',
                    backgroundColour: '#6498c9'
                  },
                  {
                    title: 'Distinctive, illustration-led brand',
                    description: 'An identity that set Simple apart from competitors in a conservative category',
                    backgroundColour: '#F37992'
                  },
                  {
                    title: 'Streamlined site structure',
                    description: 'that made it easy for enterprise buyers to find the product information they needed',
                    backgroundColour: '#599e83'
                  }
                ]}
              />
              <p class="mt-6">
                For a SaaS business competing for enterprise attention, a website that generates 26% more leads is a
                direct contribution to revenue.
              </p>
            </CaseStudySectionText>

            <CaseStudyMetaData
              client={{ name: 'Simple', url: 'https://www.simple.io' }}
              industry={['SaaS']}
              serviceNames={['Discovery + direction', 'Design', 'Development']}
            />
          </div>
        </div>
      </Grid>
    </section>

    {/* Navigation section */}
    <CaseStudyNav
      previousCaseStudy={{ name: 'Previous case study', slug: 'previous-case-study' }}
      nextCaseStudy={{ name: 'Next case study', slug: 'next-case-study' }}
    />

    <ContactForm title="Discuss a similar challenge" displayDescription={false} />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: #d9d9d9;
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
