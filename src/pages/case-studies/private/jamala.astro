---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import mbImage from '@assets/mb.png'
import CaseStudySectionText from '@components/case-studies/case-study/CaseStudySectionText.astro'
import CaseStudyResults from '@components/case-studies/case-study/CaseStudyResults.astro'
import CaseStudyHeader from '@components/case-studies/case-study/CaseStudyHeader.astro'
import CaseStudyToggleButton from '@components/case-studies/case-study/CaseStudyToggleButton.astro'
import CaseStudyMetaData from '@components/case-studies/case-study/CaseStudyMetaData.astro'
import CaseStudyShout from '@components/case-studies/case-study/CaseStudyShout.astro'
import CaseStudyNav from '@components/case-studies/case-study/CaseStudyNav.astro'
import CaseStudyImages from '@components/case-studies/case-study/CaseStudyImages.astro'
import { getCaseStudyNav } from '@data/caseStudies'

import hero from '@assets/case-studies/jamala/hero.webp'
import squareOne from '@assets/case-studies/jamala/squareOne.svg'
import squareTwo from '@assets/case-studies/jamala/squareTwo.webp'
import wideOne from '@assets/case-studies/jamala/wideOne.webp'
import wideTwo from '@assets/case-studies/jamala/wideTwo.webp'

const { previous, next } = getCaseStudyNav('jamala')
---

<Layout
  title="Jamala Property Case Study"
  description="How Pixel Agency helped Jamala Properties run a disciplined digital market test for a specialist childcare
development service, and what the data revealed."
  published={false}
>
  <article id="case-study-page">
    <CaseStudyHeader>
      <span slot="title">Jamala Property</span>
      <span slot="industry">Construction</span>
      <span slot="services">Discovery + direction, Design, Development, Consulting</span>
      <span slot="duration">2 months</span>
    </CaseStudyHeader>

    <CaseStudyToggleButton />

    <!-- Single shell: all images + summary (left pane) / all case study text (right pane) -->
    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <CaseStudyImages
              heroImage={{ src: hero }}
              summary="Jamala Properties, a specialist builder focused on constructing properties for the childcare sector, wanted to test whether their expertise could find a viable market at a national scale."
              squareImages={[{ src: squareOne }, { src: squareTwo }]}
              wideImages={[{ src: wideOne }, { src: wideTwo }]}
            />
          </div>

          <div class="case-study-right-pane min-w-0">
            <CaseStudyShout>A well-executed test can sometimes lead to unexpected insights.</CaseStudyShout>

            <CaseStudySectionText title="The client" noTopMargin={true}>
              <p class="">
                Jamala Properties is a specialist builder focused on designing and constructing properties for the
                childcare sector in Victoria. Born out of Explorers Early Learning (a client who had already experienced
                first-hand what the right digital partner could do), Jamala was established as a separate venture with a
                specific goal: to test whether their childcare construction expertise could find a viable market at a
                national scale.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The problem">
              <p>
                Before committing significant investment to a national expansion, Explorers needed to know whether
                demand existed. The childcare construction sector is highly specialised, and appetite for this kind of
                offering outside Victoria was an open question. Rather than invest heavily and find out the hard way,
                they made a smart decision: build a lean digital presence, run a time-boxed market test, and let the
                data answer the question.
              </p><br />
              <p>
                The experiment had a clear 12-month timeline and a clear success criterion. They needed a trusted
                digital partner to build the anchor for that test and report on the results.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The approach">
              <p>
                Given the experimental nature of the brief, we moved quickly, running a focused discovery phase to
                understand the offering, the target audience, and the metrics that would matter before designing and
                building a mobile-responsive website to carry the Jamala Properties brand.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The solution">
              <p>
                The site was built to be the anchor for an externally managed marketing campaign, designed to drive
                traffic and capture interest from potential clients across Australia. We set up tracking across key
                metrics (unique visitors, CTA clicks, and time on site) and delivered monthly reports to give the
                Explorers team clear, ongoing visibility into how the market was responding.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The results">
              <p>The data told a clear story:</p>
              <CaseStudyResults
                results={[
                  {
                    title: 'Fewer than 100 unique visitors per month',
                    description: 'indicating limited organic or paid demand at a national level',
                    backgroundColour: 'pixel-yellow'
                  },
                  {
                    title: '~2% CTA conversion rate',
                    description: 'Some initial interest, but not sustained',
                    backgroundColour: 'pixel-blue'
                  },
                  {
                    title: 'Zero paying clients',
                    description: 'when costing conversations moved beyond the website, no enquiries converted',
                    backgroundColour: 'pixel-rosy'
                  },
                  {
                    title: 'Full content independence',
                    description: 'for the internal team on day-to-day updates',
                    backgroundColour: 'pixel-teal'
                  }
                ]}
              />

              <div class="mt-6 lg:mt-12"></div>

              <CaseStudyShout>
                For a market test, these results were exactly what they needed to be: clear. The experiment showed that
                national demand for this level of specialisation did not warrant the investment required to pursue it.
                Jamala Properties concluded the venture at the 12-month mark, as planned.
              </CaseStudyShout>

              <p class="mt-6 lg:mt-12">
                The Jamala Properties experiment concluded cleanly and on schedule. For Explorers Early Learning, the
                outcome wasn't a failure. It was a well-executed decision. They had a question, they tested it properly,
                and they got a clear answer without overcommitting resources. That's smart business.
              </p>
            </CaseStudySectionText>

            <CaseStudyMetaData
              client={{ name: 'Jamala Properties', url: '#' }}
              industry={['Construction']}
              serviceNames={['Discovery + direction', 'Design', 'Development', 'Consulting']}
            />
          </div>
        </div>
      </Grid>
    </section>

    {/* Navigation section */}
    <CaseStudyNav previousCaseStudy={previous} nextCaseStudy={next} />

    <ContactForm title="Discuss a similar challenge" displayDescription={false} />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: var(--color-pixel-placeholder-grey);
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
