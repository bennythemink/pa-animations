---
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import CTA from '@components/CTA.astro'
import CaseStudyCard from '@components/case-studies/CaseStudyCard.astro'
import Plus from '@components/signs/Plus.astro'
import { publishedCaseStudies as caseStudies } from '@data/caseStudies'

const allIndustries = [...new Set(caseStudies.flatMap((cs) => cs.industry))].sort()
---

<Layout
  title="Case Studies"
  description="Real digital projects, real outcomes. See how Pixel Agency has helped organisations solve complex challenges through discovery, design, development, and AI."
>
  <!-- Case Studies -->
  <section id="case-studies" class="lg:pb-20">
    <Grid>
      <!-- Heading row -->
      <div class="col-span-full lg:col-start-2 lg:col-span-4">
        <h1 class="text-[18px] lg:text-[40px] leading-[1.04] tracking-[-0.04em] text-pixel-orange">Case Studies</h1>
      </div>
      <div class="col-span-full lg:col-start-7 lg:col-span-5 mt-4 lg:mt-0">
        <p class="font-sans text-3xl lg:text-4xl">
          A selection of the clients we were excited to partner with <Plus size={24} desktopSize={36} /> the projects we were
          proud to deliver results for.
        </p>
      </div>

      {/* industry filters */}
      <div
        id="industry-filters"
        class="col-span-full lg:col-start-2 lg:col-span-10 flex flex-wrap justify-end gap-3 mt-6 lg:mt-36"
      >
        {
          allIndustries.map((ind) => (
            <label class="industry-filter cursor-pointer font-sans font-normal inline-block bg-white px-4 py-2 text-[18px] transition-colors select-none">
              <input type="checkbox" value={ind} class="industry-checkbox sr-only" />
              {ind}
            </label>
          ))
        }
      </div>

      <div class="col-span-full lg:col-start-2 lg:col-span-10 flex justify-end -mt-2">
        <button
          id="clear-filters"
          type="button"
          class="font-sans text-[18px] underline underline-offset-2 hover:opacity-70 transition-opacity hover:cursor-pointer"
          >clear</button
        >
      </div>

      {/* case study cards */}
      <div
        id="case-study-grid"
        class="col-span-full lg:col-start-2 lg:col-span-10 grid grid-cols-1 lg:grid-cols-2 gap-5"
      >
        {
          caseStudies.map((cs) => (
            <CaseStudyCard
              title={cs.title}
              slug={cs.slug}
              industry={cs.industry}
              services={cs.services}
              overview={cs.overview}
              colour={cs.colour}
              image={cs.image}
              imagePosition={cs.imagePosition}
            />
          ))
        }
      </div>
    </Grid>
  </section>

  <!-- Callout -->
  <section id="callout" class="py-16 lg:py-24">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-10 flex flex-col gap-6">
        <p class="font-sans font-normal text-3xl lg:text-[80px] leading-[1.04] tracking-[-0.03em]">
          If you're facing a similar challenge, we'd be happy to talk it through.
        </p>
        <div class="mt-6">
          <CTA label="Discuss a problem" />
        </div>
      </div>
    </Grid>
  </section>

  <style>
    .industry-filter:hover {
      background-color: var(--accent-bgc);
      color: #fff;
    }
    .industry-filter.active {
      background-color: var(--accent-bgc);
      color: #fff;
    }
  </style>

  <script>
    function initIndustryFilters() {
      const checkboxes = document.querySelectorAll<HTMLInputElement>('.industry-checkbox')
      const cards = document.querySelectorAll<HTMLElement>('.case-study-card')

      function applyFilters() {
        const selected = Array.from(checkboxes)
          .filter((cb) => cb.checked)
          .map((cb) => cb.value)

        checkboxes.forEach((cb) => {
          const label = cb.closest('.industry-filter')
          if (label) {
            label.classList.toggle('active', cb.checked)
          }
        })

        cards.forEach((card) => {
          if (selected.length === 0) {
            card.style.display = ''
            return
          }
          const industries: string[] = JSON.parse(card.dataset.industries || '[]')
          const match = selected.some((s) => industries.includes(s))
          card.style.display = match ? '' : 'none'
        })
      }

      checkboxes.forEach((cb) => cb.addEventListener('change', applyFilters))

      const clearBtn = document.querySelector<HTMLButtonElement>('#clear-filters')
      clearBtn?.addEventListener('click', () => {
        checkboxes.forEach((cb) => {
          cb.checked = false
        })
        applyFilters()
      })
    }

    initIndustryFilters()
    document.addEventListener('astro:after-swap', initIndustryFilters)
  </script>
</Layout>
