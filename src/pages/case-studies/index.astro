---
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import Equals from '@components/signs/Equals.astro'
import Plus from '@components/signs/Plus.astro'

interface CaseStudy {
  title: string
  slug: string
  sector: string
  services: string
  overview: string
  colour: string
}

const caseStudies: CaseStudy[] = [
  {
    title: 'Sonata AI',
    slug: 'sonata-ai',
    sector: 'Technology / AI',
    services: 'Discovery, Design, Development',
    overview:
      'A ground-up digital experience built to redefine how AI-powered software is designed, marketed and sold — from positioning through to product interface.',
    colour: 'bg-pixel-pink'
  },
  {
    title: 'Fletcher Insulation',
    slug: 'insulation',
    sector: 'Manufacturing',
    services: 'Discovery, Design, Development',
    overview:
      'A full website rebuild that drove a 40% lift in visitors and 300%+ increase in session time — while cutting support requests by 30%.',
    colour: 'bg-pixel-orange'
  },
  {
    title: 'Better Health Network',
    slug: 'bhn',
    sector: 'Health / Community',
    services: 'Discovery, Design, Development',
    overview:
      'Unified three merging community health organisations online — achieving a 115% increase in total visitors within six months of launch.',
    colour: 'bg-pixel-green'
  },
  {
    title: 'Dare Iced Coffee',
    slug: 'dare',
    sector: 'FMCG',
    services: 'Design, Development',
    overview:
      "Transformed Dare Iced Coffee's digital presence, delivering a 200%+ increase in time on site and a meaningful reduction in support load.",
    colour: 'bg-pixel-red'
  },
  {
    title: 'Explorers Early Learning',
    slug: 'eel',
    sector: 'Education / Childcare',
    services: 'Discovery, Design, Development',
    overview:
      'Redesigned the website to drive 9% more centre tour bookings and a 24% increase in session time from prospective parents.',
    colour: 'bg-pixel-blue'
  },
  {
    title: 'Holmesglen',
    slug: 'holmesglen',
    sector: 'Education',
    services: 'Discovery, Design, Development',
    overview:
      'Built a student-employer platform from the ground up. 1,200+ registered employers and 80+ student job placements in year one.',
    colour: 'bg-pixel-cream'
  },
  {
    title: 'VincentCare',
    slug: 'vincentcare',
    sector: 'Not-for-profit',
    services: 'Discovery, Design, Development',
    overview: "Redesigned VincentCare's website, achieving a 14% increase in donations and 22% longer session times.",
    colour: 'bg-pixel-dark-green'
  },
  {
    title: 'Yoplait',
    slug: 'yoplait',
    sector: 'FMCG',
    services: 'Design, Development',
    overview:
      "Transformed Yoplait Australia's digital presence, delivering 130% more traffic and 150% longer session times.",
    colour: 'bg-pixel-red'
  }
]

const featured = caseStudies[0]
const remaining = caseStudies.slice(1)
---

<Layout
  title="Case Studies"
  description="Real digital projects, real outcomes. See how Pixel Agency has helped organisations solve complex challenges through discovery, design, development, and AI."
>
  <!-- Hero -->
  <section id="hero" class="pt-10 pb-12 lg:pt-16 lg:pb-20">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-10">
        <p
          class="text-2xl lg:text-[40px] leading-[1.15] tracking-[-0.02em] flex flex-wrap items-center gap-x-3 lg:gap-x-4"
        >
          <span>Real organisations</span>
          <Plus size={20} desktopSize={32} />
          <span>Real problems</span>
          <Equals size={20} desktopSize={32} />
          <span>Real outcomes</span>
          <span class="inline-block w-5 h-5 lg:w-8 lg:h-8" style="background-color: var(--accent-bgc);"></span>
        </p>
      </div>
      <div class="col-span-full lg:col-start-4 lg:col-span-6 mt-8 lg:mt-12 text-center">
        <p class="font-serif text-base lg:text-lg leading-[0.76]">
          We work deliberately on the kind of work we believe in — and we're selective about who we work with. The case
          studies here reflect clarity, collaboration, and outcomes our organisation is built to deliver. Beautiful
          things are a trust we take seriously, grounded in the practicality or strategic rigour that makes them work.
        </p>
        <a
          href="/contact"
          class="inline-block mt-6 text-sm underline underline-offset-4 hover:opacity-70 transition-opacity"
        >
          Get in touch
        </a>
      </div>
    </Grid>
  </section>

  <!-- Case Studies -->
  <section id="case-studies" class="pb-12 lg:pb-20">
    <Grid>
      <!-- Heading row -->
      <div class="col-span-full lg:col-start-2 lg:col-span-4">
        <h1 class="text-[40px] leading-[1.04] tracking-[-0.04em] text-pixel-orange">Case Studies</h1>
      </div>
      <div class="col-span-full lg:col-start-7 lg:col-span-5 mt-4 lg:mt-0">
        <p class="font-serif text-base lg:text-lg leading-[0.76]">
          Each project reflects work we were proud to take on — and proud to deliver.
        </p>
      </div>
    </Grid>

    <!-- Featured case study -->
    <div class="grid grid-cols-12 lg:col-start-2 gap-5 px-5 max-w-360 mx-auto w-full mt-8 lg:mt-12">
      <!-- Featured image -->
      <a href={`/case-studies/${featured.slug}`} class="col-span-full lg:col-span-7 relative group">
        <div class="w-full aspect-[4/3] bg-gray-800"></div>
        <div class={`${featured.colour} px-3 py-2`}>
          <p class="text-xs lg:text-sm font-sans">{featured.title}</p>
        </div>
      </a>
      <!-- Featured detail card -->
      <div class="col-span-full lg:col-span-5 bg-pixel-pink p-6 lg:p-8 flex flex-col justify-between">
        <div>
          <p class="font-sans text-xs lg:text-sm uppercase tracking-wide opacity-50 mb-1">data studio | AI / SaaS</p>
          <h2 class="text-2xl lg:text-3xl leading-[1.1] tracking-[-0.02em] mb-6">{featured.title}</h2>
          <div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-4 text-sm lg:text-base font-serif leading-[0.76]">
            <p class="opacity-50">Sector</p>
            <p>{featured.sector}</p>
            <p class="opacity-50">Services</p>
            <p>{featured.services}</p>
            <p class="opacity-50">Overview</p>
            <p>{featured.overview}</p>
          </div>
        </div>
        <a
          href={`/case-studies/${featured.slug}`}
          class="inline-block mt-6 text-xs lg:text-sm font-sans uppercase tracking-wider font-medium hover:opacity-70 transition-opacity"
        >
          View case study
        </a>
      </div>
    </div>
  </section>

  <!-- Callout -->
  <section id="callout" class="py-16 lg:py-24">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-10 flex flex-col gap-6">
        <p class="font-sans font-normal text-3xl lg:text-[80px] leading-[1.04] tracking-[-0.03em]">
          If you're facing a similar challenge, we'd be happy to talk it through.
        </p>
        <a
          href="/contact"
          class="mt-6 font-sans font-normal inline-block w-fit bg-white px-4 py-2 text-base hover:underline"
          >Discuss a problem</a
        >
      </div>
    </Grid>
  </section>
</Layout>
