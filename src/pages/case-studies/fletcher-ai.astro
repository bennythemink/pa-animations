---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import CaseStudySectionText from '@components/case-studies/case-study/CaseStudySectionText.astro'
import CaseStudyResults from '@components/case-studies/case-study/CaseStudyResults.astro'
import CaseStudyHeader from '@components/case-studies/case-study/CaseStudyHeader.astro'
import CaseStudyToggleButton from '@components/case-studies/case-study/CaseStudyToggleButton.astro'
import CaseStudyMetaData from '@components/case-studies/case-study/CaseStudyMetaData.astro'
import CaseStudyShout from '@components/case-studies/case-study/CaseStudyShout.astro'
import CaseStudyNav from '@components/case-studies/case-study/CaseStudyNav.astro'
import CaseStudyImages from '@components/case-studies/case-study/CaseStudyImages.astro'
import { getCaseStudyNav } from '@data/caseStudies'

import hero from '@assets/case-studies/fletcher-dam/hero.webp'
import squareOne from '@assets/case-studies/fletcher-dam/squareOne.svg'
import squareTwo from '@assets/case-studies/fletcher-dam/squareTwo.svg'
import wideOne from '@assets/case-studies/fletcher-dam/wideOne.webp'
import wideTwo from '@assets/case-studies/fletcher-dam/wideTwo.webp'

const { previous, next } = getCaseStudyNav('fletcher-dam')
---

<Layout
  title="Fletcher Insulation + Pixel Assist"
  description="AI and consulting for Fletcher Insulation, an Australian leader in the building and construction insulation products sector. Pixel Agency deployed Pixel Assist, an AI knowledge assistant on insulation.com.au, helping users surface product information instantly and reducing customer support queries during a successful 2% feature-flagged trial."
>
  <article id="case-study-page">
    <CaseStudyHeader>
      <span slot="title">Fletcher Insulation + Pixel Assist</span>
      <span slot="industry">Construction, Manufacturing</span>
      <span slot="services">AI, Pixel Assist</span>
      <span slot="duration">1 month</span>
    </CaseStudyHeader>

    <CaseStudyToggleButton />

    <!-- Single shell: all images + summary (left pane) / all case study text (right pane) -->
    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <CaseStudyImages
              heroImage={{ src: hero }}
              summary="How Pixel Agency deployed Pixel Assist, an AI knowledge assistant, on Fletcher Insulation's website to surface product knowledge in real time for architects, planners, and trade partners, with a feature-flagged rollout that proved the system out on 2% of users before scaling."
              squareImages={[{ src: squareOne }, { src: squareTwo }]}
              wideImages={[{ src: wideOne }, { src: wideTwo }]}
            />
          </div>

          <div class="case-study-right-pane min-w-0">
            <CaseStudyShout>
              An AI knowledge assistant for insulation.com.au, rolled out the careful way.
            </CaseStudyShout>

            <CaseStudySectionText title="The client" noTopMargin={true}>
              <p>
                Fletcher Insulation is one of Australia's leading suppliers of insulation products, serving trades,
                architects, builders, and project teams across the country through insulation.com.au. The site holds a
                large body of technical product knowledge: HTML pages, PDF datasheets, technical documents, and product
                imagery built up over years of being a category leader. The audience visiting that knowledge isn't
                browsing; they're making decisions.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The problem">
              <p>
                The depth of information on insulation.com.au is part of why architects, planners, and trade partners
                come to it. It's also part of what gets in their way. Users trying to find the right product for a
                specific application have to hunt across HTML pages, PDF documents, and images to piece an answer
                together.
              </p><br />
              <p>
                Slow answers cost Fletcher in two ways: support requests pile up where users can't self-serve, and a
                buyer who can't quickly find the right Fletcher product is more likely to drift to a competitor whose
                information is easier to surface. With insulation specifications increasingly driven by performance,
                compliance, and time pressure, frictionless decision-making isn't a nice-to-have.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The approach">
              <p>
                We brought Pixel Assist to Fletcher as a new addition to the ongoing partnership. Pixel Assist is our
                managed AI knowledge assistant: a RAG-based system that learns from a client's existing knowledge, with
                no fine-tuning required, and answers user questions in real time in the client's tone of voice. We
                started with discovery, working with Fletcher to map the knowledge that would feed the system, the kinds
                of questions users actually need answered (product fit, R-values, install methods, application
                suitability), and the brand voice the assistant would need to use so every answer felt unmistakably
                Fletcher.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The solution">
              <p>
                Pixel Assist was deployed on insulation.com.au with a familiar chat interface, but the deployment itself
                was where the care went in. Rather than turn the assistant on for every visitor at once, we used feature
                flagging to expose Pixel Assist to just 2% of users. That gave us a controlled environment to validate
                the system in the wild without putting the wider user base at risk if anything needed adjusting. The
                assistant answers user questions in real time, suggests Fletcher products that fit specific needs, and
                is built to support architects, planners, trade partners, and (in time) internal staff in finding what
                they need quickly.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The results">
              <p>The 2% trial validated what the system could do on the three dimensions Fletcher cared about:</p>
              <CaseStudyResults
                results={[
                  {
                    title: 'A measured fall ',
                    description: 'in customer support requests from users who reached the assistant',
                    backgroundColour: 'pixel-yellow'
                  },
                  {
                    title: 'Questions answered to a high quality',
                    description: "with Fletcher's tone of voice preserved across responses",
                    backgroundColour: 'pixel-blue'
                  },
                  {
                    title: 'No incidents',
                    description:
                      'on the wider user base during the test period, thanks to the feature-flagged exposure',
                    backgroundColour: 'pixel-pink'
                  },
                  {
                    title: 'A proven system',
                    description: 'ready to scale, with confidence on both quality and brand fit',
                    backgroundColour: 'pixel-pink'
                  }
                ]}
              />

              <div class="mt-6 lg:mt-12"></div>

              <CaseStudyShout>
                AI doesn't have to be all or nothing. The smart way in is the careful way.
              </CaseStudyShout>
            </CaseStudySectionText>

            <CaseStudyMetaData
              client={{ name: 'Fletcher Insulation', url: 'https://www.insulation.com.au' }}
              industry={['Construction', 'Manufacturing']}
              serviceNames={['Discovery + direction', 'Design', 'Development']}
            />
          </div>
        </div>
      </Grid>
    </section>

    {/* Navigation section */}
    <CaseStudyNav previousCaseStudy={previous} nextCaseStudy={next} />

    <ContactForm title="Discuss a similar challenge" displayDescription={false} />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: var(--color-pixel-placeholder-grey);
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
