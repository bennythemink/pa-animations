---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import mbImage from '@assets/mb.png'
import CaseStudySectionText from '@components/case-studies/case-study/CaseStudySectionText.astro'
import CaseStudyResults from '@components/case-studies/case-study/CaseStudyResults.astro'
import CaseStudyHeader from '@components/case-studies/case-study/CaseStudyHeader.astro'
import CaseStudyToggleButton from '@components/case-studies/case-study/CaseStudyToggleButton.astro'
import CaseStudyMetaData from '@components/case-studies/case-study/CaseStudyMetaData.astro'
import CaseStudyShout from '@components/case-studies/case-study/CaseStudyShout.astro'
import CaseStudyNav from '@components/case-studies/case-study/CaseStudyNav.astro'
import CaseStudyImages from '@components/case-studies/case-study/CaseStudyImages.astro'
---

<Layout
  title="Plumbing Plus Case Study"
  description="Pixel Agency redesigned Plumbing Plus's trade network website, generating 29% more leads, 38% growth in new
users, and major commercial partnerships within 90 days."
>
  <article id="case-study-page">
    <CaseStudyHeader>
      <span slot="title">Plumbing Plus</span>
      <span slot="industry">Trade Services</span>
      <span slot="services">Discovery + direction, Design, Development, Consulting</span>
      <span slot="duration">2 months</span>
    </CaseStudyHeader>

    <CaseStudyToggleButton />

    <!-- Single shell: all images + summary (left pane) / all case study text (right pane) -->
    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <CaseStudyImages
              heroImage={{ src: mbImage }}
              summary="Plumbing Plus, a leading trade services provider, wanted to enhance their online presence + generate more leads."
              squareImages={[{ src: mbImage }, { src: mbImage }]}
              wideImages={[{ src: mbImage }, { src: mbImage }]}
            />
          </div>

          <div class="case-study-right-pane min-w-0">
            <CaseStudyShout> Leads, leads, and more leads.</CaseStudyShout>

            <CaseStudySectionText title="The client" noTopMargin={true}>
              <p class="">
                Plumbing Plus is Australia's leading independent supplier of bathroom and plumbing products, serving the
                trade market through a national member network of 320 stores built over more than 40 years. Their
                reputation in the industry is built on product range, reliability, and the strength of their independent
                member network.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The problem" textColour="text-pixel-red">
              <p>
                Plumbing Plus's digital presence wasn't keeping pace with the business. Their platform was siloed, the
                experience varied across their member network, the brand lacked cohesion online, and the website wasn't
                working hard enough as a sales tool. For a national network competing for trade customers who value
                speed and simplicity, a fragmented digital experience was costing them conversions. The site needed to
                do more than exist. It needed to actively drive leads and reinforce the Plumbing Plus brand across every
                touchpoint.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The approach" textColour="text-pixel-orange">
              <p>
                We started with extensive user research and profiling to understand how trade customers were actually
                interacting with the brand online: what they were looking for, where they were dropping off, and what
                was getting in the way of conversion. That research shaped every decision that followed.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The solution" textColour="text-pixel-green">
              <p>
                The core challenge was twofold: build a cohesive public-facing website that unified the brand across 320
                independent stores, and deliver a member portal with the complex trade logic needed to support the
                network behind the scenes. We designed and built both: a full WordPress website for the public
                experience, and a custom-built member portal for the network.
              </p><br />
              <p>
                On the public side, we simplified pathways to core calls-to-action and developed a sophisticated product
                schema connecting brands, categories, and suppliers so trade customers could find exactly what they
                needed without friction. On the member side, we built a portal that handled the complex logic required
                to support a national network of independent stores, a tricky piece of work when every store operates
                differently.
              </p><br />
              <p>
                The result was a seamless experience for trade customers and a unified digital platform for the network:
                one that worked as the sales tool the business needed.
              </p>
            </CaseStudySectionText>

            <CaseStudySectionText title="The results" textColour="text-pixel-blue">
              <p>
                The impact was felt quickly. Plumbing Plus secured major new commercial partnerships within the first 90
                days of launch. Beyond that:
              </p>
              <CaseStudyResults
                results={[
                  {
                    title: '11% increase in lead conversions',
                    description: 'more visitors completing the actions that matter',
                    backgroundColour: '#e8c42f'
                  },
                  {
                    title: '18% growth in new users',
                    description: "reaching trade customers who weren't finding them before",
                    backgroundColour: '#6498c9'
                  },
                  {
                    title: '190%+ increase in referral traffic',
                    description: 'driven by ongoing strategy adjustments post-launch',
                    backgroundColour: '#F37992'
                  }
                ]}
              />

              <p class="mt-6 lg:mt-12">
                We stayed close to the data after launch, making regular strategy tweaks and keeping reporting proactive
                so the platform's performance stayed aligned with the business's direction.
              </p>
              <div class="mt-6 lg:mt-12"></div>

              <CaseStudyShout>
                For a national trade network, a website that actively generates leads and partnerships is a growth
                engine.
              </CaseStudyShout>
            </CaseStudySectionText>

            <CaseStudyMetaData
              client={{ name: 'Plumbing Plus', url: 'https://www.plumbingplus.com.au' }}
              industry={['Trade Services']}
              serviceNames={['Discovery + direction', 'Design', 'Development']}
            />
          </div>
        </div>
      </Grid>
    </section>

    {/* Navigation section */}
    <CaseStudyNav
      previousCaseStudy={{ name: 'Previous case study', slug: 'previous-case-study' }}
      nextCaseStudy={{ name: 'Next case study', slug: 'next-case-study' }}
    />

    <ContactForm
      title="Discuss a similar challenge"
      backgroundColor="var(--color-pixel-pink)"
      displayDescription={false}
    />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: #d9d9d9;
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
