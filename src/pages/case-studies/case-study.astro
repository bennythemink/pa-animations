---
import ContactForm from '@components/ContactForm.astro'
import Grid from '@components/Grid.astro'
import Layout from '@layouts/Layout.astro'
import { Image } from 'astro:assets'
import mbImage from '@assets/mb.png'

const caseStudy = {
  title: 'Education provider',
  sector: 'Education',
  services: ['Discovery & Direction', 'Design', 'Development'],
  duration: '6 months',
  intro:
    'The client operates across multiple campuses and serves a large, diverse student base. Their existing digital platform had grown over time and no longer reflected how students or staff actually worked.',
  summary:
    'A modern, scalable digital platform that improved usability, clarified internal ownership, and supported future growth.',
  closing:
    'This project highlighted the value of slowing down early to gain clarity. The initial discovery phase reduced risk, reduced rework, improved decision-making, and ultimately led to a stronger result.',
  client: 'Education Provider',
  acknowledgements: 'Partners listed here',
  team: ['Benny Sheerin, role', 'Team member, role', 'Team member, role'],
  sections: [
    {
      title: 'The problem',
      intro: 'Key challenges included:',
      bullets: [
        'Fragmented systems and inconsistent experiences',
        'Limited visibility over content ownership',
        'Difficulty prioritising improvements'
      ],
      body: 'There was broad agreement that change was needed, but no shared understanding of where to start.'
    },
    {
      title: 'Our approach',
      intro: 'We began with a Discovery & Direction phase to clarify:',
      bullets: ['Core user needs', 'Business constraints', 'Success criteria'],
      body: 'This created alignment across stakeholders and a clear path forward. From there, we worked closely with internal teams through design and development, iterating and refining as we learned more.'
    },
    {
      title: 'The solution',
      intro: 'The final solution included:',
      bullets: [
        'A redesigned information architecture',
        'A clearer content management approach',
        'A modern, maintainable technical foundation'
      ],
      body: 'Design and development decisions were made collaboratively, balancing usability, performance, and long-term support.'
    },
    {
      title: 'The outcome',
      intro: 'The new platform:',
      bullets: [
        'Improved usability for students and staff',
        'Reduced internal friction and rework',
        'Provided a scalable foundation for future initiatives'
      ],
      body: 'Perhaps most importantly, the organisation gained confidence in its digital direction.'
    }
  ]
}
---

<Layout title={caseStudy.title} description={caseStudy.intro}>
  <article id="case-study-page">
    <section class="pt-5 lg:pt-10 pb-8 lg:pb-14">
      <Grid>
        <div class="col-span-full lg:col-start-2 lg:col-span-11">
          <div class="flex flex-col gap-6">
            <div>
              <h1 class="font-sans text-[clamp(3rem,5.5vw,4.875rem)] leading-[0.96] tracking-[-0.04em]">
                {caseStudy.title}
              </h1>
              <div
                class="case-study-meta-actions mt-4 flex w-full flex-wrap items-center gap-4 lg:flex-nowrap lg:justify-between"
              >
                <div
                  class="case-study-meta-row flex flex-1 flex-wrap gap-x-4 gap-y-2 font-sans text-sm leading-[1.3] text-[color-mix(in_oklab,var(--color-black)_55%,transparent)]"
                >
                  <span class="inline-flex flex-wrap gap-1"
                    ><span class="text-[color-mix(in_oklab,var(--color-black)_30%,transparent)]">Sector</span>{
                      caseStudy.sector
                    }</span
                  >
                  <span>
                    <span class="text-[color-mix(in_oklab,var(--color-black)_30%,transparent)]">Services</span>
                    {caseStudy.services.join(' ')}
                  </span>
                  <span class="inline-flex flex-wrap gap-1"
                    ><span class="text-[color-mix(in_oklab,var(--color-black)_30%,transparent)]">Duration</span>{
                      caseStudy.duration
                    }</span
                  >
                </div>

                <button
                  id="case-study-toggle"
                  type="button"
                  class="case-study-toggle group ml-auto inline-flex h-10 w-fit items-center gap-2 bg-(--accent-bgc) px-4 font-sans text-base font-normal text-(--case-study-toggle-text) transition-[color,text-decoration-color,transform] duration-200 hover:underline hover:decoration-current cursor-pointer hover:underline-offset-2"
                  aria-expanded="false"
                  aria-controls="case-study-shell"
                >
                  <span class="case-study-toggle-icon relative h-3.5 w-3.5 shrink-0" aria-hidden="true">
                    <span
                      class="case-study-toggle-icon-bar case-study-toggle-icon-bar-horizontal absolute left-1/2 top-1/2 h-[1.5px] w-full -translate-x-1/2 -translate-y-1/2 bg-current"
                    ></span>
                    <span
                      class="case-study-toggle-icon-bar case-study-toggle-icon-bar-vertical absolute left-1/2 top-1/2 h-[1.5px] w-full -translate-x-1/2 -translate-y-1/2 bg-current"
                    ></span>
                  </span>
                  <span class="case-study-toggle-label">About the project</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </Grid>
    </section>

    <section class="pb-12 lg:pb-18">
      <Grid>
        <div id="case-study-shell" class="case-study-shell col-span-full lg:col-start-2 lg:col-span-11">
          <div class="case-study-left-pane min-w-0 overflow-hidden">
            <div class="case-study-mobile-image-stack grid gap-5">
              <div class="aspect-video w-full overflow-hidden bg-(--case-study-placeholder)">
                <Image src={mbImage} alt="" class="h-full w-full object-cover" />
              </div>
              <div class="grid grid-cols-2 gap-5">
                <div class="aspect-square w-full overflow-hidden bg-(--case-study-placeholder)">
                  <Image src={mbImage} alt="" class="h-full w-full object-cover" />
                </div>
                <div class="aspect-square w-full overflow-hidden bg-(--case-study-placeholder)">
                  <Image src={mbImage} alt="" class="h-full w-full object-cover" />
                </div>
              </div>
              <div class="aspect-16/7 w-full overflow-hidden bg-(--case-study-placeholder)">
                <Image src={mbImage} alt="" class="h-full w-full object-cover" />
              </div>
              <div class="aspect-16/7 w-full overflow-hidden bg-(--case-study-placeholder)">
                <Image src={mbImage} alt="" class="h-full w-full object-cover" />
              </div>
            </div>

            <div class="case-study-desktop-visuals grid gap-5">
              <div class="aspect-video w-full overflow-hidden bg-(--case-study-placeholder)">
                <Image src={mbImage} alt="" class="h-full w-full object-cover" />
              </div>
              <p
                class="case-study-summary-desktop font-sans text-[clamp(2rem,3.3vw,3rem)] leading-[1.02] tracking-[-0.03em] text-black mt-4 max-w-[15ch]"
              >
                {caseStudy.summary}
              </p>
              <div class="grid grid-cols-2 gap-5">
                <div class="aspect-square w-full overflow-hidden bg-(--case-study-placeholder)">
                  <Image src={mbImage} alt="" class="h-full w-full object-cover" />
                </div>
                <div class="aspect-square w-full overflow-hidden bg-(--case-study-placeholder)">
                  <Image src={mbImage} alt="" class="h-full w-full object-cover" />
                </div>
              </div>
              <div class="aspect-16/7 w-full overflow-hidden bg-(--case-study-placeholder)">
                <Image src={mbImage} alt="" class="h-full w-full object-cover" />
              </div>
              <div class="aspect-16/7 w-full overflow-hidden bg-(--case-study-placeholder)">
                <Image src={mbImage} alt="" class="h-full w-full object-cover" />
              </div>
            </div>
          </div>

          <div class="case-study-right-pane min-w-0">
            <p class="font-sans text-[clamp(2rem,4.2vw,3.6rem)] leading-[1.02] tracking-[-0.03em] text-black">
              {caseStudy.intro}
            </p>
            <p
              class="case-study-summary-mobile mt-4 max-w-[15ch] font-sans text-[clamp(2rem,3.3vw,3rem)] leading-[1.02] tracking-[-0.03em] text-black"
            >
              {caseStudy.summary}
            </p>

            <div class="mt-8 grid gap-8 lg:gap-10">
              {
                caseStudy.sections.map((section) => (
                  <div class="case-study-section-block lg:grid lg:grid-cols-[minmax(0,160px)_minmax(0,1fr)] lg:items-start lg:gap-x-5 lg:gap-y-4">
                    <h2 class="mb-3.5 font-sans text-[clamp(1.6rem,2vw,2.15rem)] leading-[1.05] lg:mb-0">
                      {section.title}
                    </h2>
                    <p class="text-[1.0625rem] leading-[1.45] text-[color-mix(in_oklab,var(--color-black)_86%,transparent)] lg:col-2">
                      {section.intro}
                    </p>
                    <ul class="my-3.5 ml-5 grid list-disc gap-[0.35rem] text-[1.0625rem] leading-[1.45] text-[color-mix(in_oklab,var(--color-black)_86%,transparent)] lg:col-2 lg:mb-4 lg:mt-3.5">
                      {section.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                    <p class="text-[1.0625rem] leading-[1.45] text-[color-mix(in_oklab,var(--color-black)_86%,transparent)] lg:col-2">
                      {section.body}
                    </p>
                  </div>
                ))
              }
            </div>

            <p
              class="mt-8 max-w-[18ch] font-sans text-[clamp(2rem,3vw,3.1rem)] leading-[1.02] tracking-[-0.03em] text-black"
            >
              {caseStudy.closing}
            </p>

            <div class="mt-8 grid grid-cols-2 gap-x-4 gap-y-6 pt-4 lg:grid-cols-4">
              <div>
                <p class="mb-[0.35rem] font-sans text-sm text-[color-mix(in_oklab,var(--color-black)_35%,transparent)]">
                  Client
                </p>
                <p class="text-base leading-[1.35] underline underline-offset-[0.15em]">{caseStudy.client}</p>
              </div>
              <div>
                <p class="mb-[0.35rem] font-sans text-sm text-[color-mix(in_oklab,var(--color-black)_35%,transparent)]">
                  Services
                </p>
                {caseStudy.services.map((service) => <p class="text-base leading-[1.35]">{service}</p>)}
              </div>
              <div>
                <p class="mb-[0.35rem] font-sans text-sm text-[color-mix(in_oklab,var(--color-black)_35%,transparent)]">
                  Team
                </p>
                {caseStudy.team.map((member) => <p class="text-base leading-[1.35]">{member}</p>)}
              </div>
              <div>
                <p class="mb-[0.35rem] font-sans text-sm text-[color-mix(in_oklab,var(--color-black)_35%,transparent)]">
                  Acknowledgements
                </p>
                <p class="text-base leading-[1.35]">{caseStudy.acknowledgements}</p>
              </div>
            </div>
          </div>
        </div>
      </Grid>
    </section>

    <section class="pb-6 lg:pb-12 case-study-nav-section">
      <Grid>
        <div
          class="case-study-nav col-span-full grid gap-4 border-t border-(--case-study-border) pt-4 lg:col-start-2 lg:col-span-11 lg:flex lg:items-start lg:justify-between lg:gap-8"
        >
          <a href="#" class="flex min-w-0 flex-col gap-1">
            <span class="font-sans text-[clamp(2rem,3.4vw,3.2rem)] leading-[0.95] tracking-[-0.035em]">
              Previous case study
            </span>
            <span
              class="text-base text-[color-mix(in_oklab,var(--color-black)_32%,transparent)] underline underline-offset-[0.14em]"
            >
              Case study name
            </span>
          </a>
          <a href="#" class="flex min-w-0 flex-col gap-1 text-right lg:items-end">
            <span class="font-sans text-[clamp(2rem,3.4vw,3.2rem)] leading-[0.95] tracking-[-0.035em]">
              Next case study
            </span>
            <span
              class="text-base text-[color-mix(in_oklab,var(--color-black)_32%,transparent)] underline underline-offset-[0.14em]"
            >
              Case study name
            </span>
          </a>
        </div>
      </Grid>
    </section>

    <ContactForm
      title="Discuss a similar challenge"
      backgroundColor="var(--color-pixel-pink)"
      displayDescription={false}
    />
  </article>

  <style>
    #case-study-page {
      --case-study-border: color-mix(in oklab, var(--color-black) 8%, transparent);
      --case-study-placeholder: #d9d9d9;
    }

    .case-study-toggle-icon-bar {
      transform-origin: center;
      transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .case-study-toggle-icon-bar-horizontal {
      transform: translate(-50%, -50%) rotate(0deg);
    }

    .case-study-toggle-icon-bar-vertical {
      transform: translate(-50%, -50%) rotate(90deg);
    }

    .case-study-toggle:hover .case-study-toggle-icon-bar-horizontal {
      transform: translate(-50%, -50%) rotate(90deg);
    }

    .case-study-toggle:hover .case-study-toggle-icon-bar-vertical {
      transform: translate(-50%, -50%) rotate(180deg);
    }

    .case-study-toggle[aria-expanded='true'] .case-study-toggle-icon-bar-horizontal {
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .case-study-toggle[aria-expanded='true'] .case-study-toggle-icon-bar-vertical {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .case-study-toggle[aria-expanded='true']:hover .case-study-toggle-icon-bar-horizontal {
      transform: translate(-50%, -50%) rotate(50deg);
    }

    .case-study-toggle[aria-expanded='true']:hover .case-study-toggle-icon-bar-vertical {
      transform: translate(-50%, -50%) rotate(-50deg);
    }

    .case-study-summary-mobile {
      display: block;
    }

    .case-study-summary-desktop {
      display: none;
    }

    @media (max-width: 1023px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        overflow: clip;
      }

      .case-study-left-pane {
        flex: 0 0 auto;
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 240ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(-2rem);
        pointer-events: none;
      }

      .case-study-right-pane {
        flex: 0 0 auto;
        width: 0;
        max-height: 0;
        opacity: 0;
        overflow: clip;
        transform: translateX(2rem);
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: 100%;
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }

      .case-study-mobile-image-stack {
        display: grid;
      }

      .case-study-desktop-visuals {
        display: none;
      }
    }

    @media (min-width: 1024px) {
      .case-study-shell {
        display: flex;
        gap: 0;
        transition: gap 420ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      #case-study-page[data-panel-state='open'] .case-study-shell {
        gap: 1.25rem;
      }

      .case-study-left-pane,
      .case-study-right-pane {
        flex: 0 0 auto;
        transition:
          width 420ms cubic-bezier(0.22, 1, 0.36, 1),
          max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 260ms ease,
          transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        will-change: width, max-height, opacity, transform;
      }

      .case-study-left-pane {
        width: 100%;
        max-height: 5000px;
      }

      .case-study-right-pane {
        width: 0;
        max-height: 0;
        opacity: 0;
        transform: translateX(2rem);
        overflow: clip;
        pointer-events: none;
      }

      #case-study-page[data-panel-state='open'] .case-study-left-pane {
        width: calc(50% - 0.625rem);
      }

      #case-study-page[data-panel-state='open'] .case-study-right-pane {
        width: calc(50% - 0.625rem);
        max-height: 5000px;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }

      .case-study-mobile-image-stack {
        display: none;
      }

      .case-study-desktop-visuals {
        display: grid;
      }

      .case-study-summary-desktop {
        display: block;
      }

      .case-study-summary-mobile {
        display: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-study-shell,
      .case-study-left-pane,
      .case-study-right-pane {
        transition: none;
      }

      .case-study-toggle,
      .case-study-toggle-icon-bar {
        transition: none;
      }
    }
  </style>

  <script>
    function initCaseStudyPage() {
      const page = document.getElementById('case-study-page')
      const toggle = document.getElementById('case-study-toggle')
      if (!(page instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return
      const pageElement = page
      const toggleButton = toggle

      const mobileMedia = window.matchMedia('(max-width: 1023px)')

      function setToggleTextColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
        const match = accent.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/)
        if (!match) return

        let red = parseInt(match[1], 10) / 255
        let green = parseInt(match[2], 10) / 255
        let blue = parseInt(match[3], 10) / 255

        red = red <= 0.03928 ? red / 12.92 : Math.pow((red + 0.055) / 1.055, 2.4)
        green = green <= 0.03928 ? green / 12.92 : Math.pow((green + 0.055) / 1.055, 2.4)
        blue = blue <= 0.03928 ? blue / 12.92 : Math.pow((blue + 0.055) / 1.055, 2.4)

        const luminance = 0.2126 * red + 0.7152 * green + 0.0722 * blue
        document.documentElement.style.setProperty('--case-study-toggle-text', luminance > 0.4 ? '#000' : '#fff')
      }

      function getDefaultState() {
        return mobileMedia.matches ? 'open' : 'closed'
      }

      if (!pageElement.dataset.panelState) {
        pageElement.dataset.panelState = getDefaultState()
      }

      function syncA11y() {
        const isOpen = pageElement.dataset.panelState === 'open'
        toggleButton.setAttribute('aria-expanded', String(isOpen))
      }

      setToggleTextColor()
      syncA11y()

      toggleButton.addEventListener('click', () => {
        pageElement.dataset.panelState = pageElement.dataset.panelState === 'open' ? 'closed' : 'open'
        syncA11y()
      })
    }

    initCaseStudyPage()
    document.addEventListener('astro:after-swap', initCaseStudyPage)
  </script>
</Layout>
