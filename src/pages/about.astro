---
import Layout from '@layouts/Layout.astro'
import WhoSection from '@components/services/WhoSection.astro'
import FeatureCards from '@components/services/FeatureCards.astro'
import Grid from '@components/Grid.astro'
import Plus from '@components/signs/Plus.astro'
import SectionCards from '@components/SectionCards.astro'

/**
 * WhoSection variables
 */
const whoFor = [
  'Value clarity and thoughtful decision-making over speed for its own sake',
  'Want a trusted partner, not just a vendor who executes and moves on',
  'Care about outcomes, not just whether something shipped'
]

const whoNotFor = [
  'You’re looking for the cheapest or fastest option, regardless of quality',
  'You want execution without discussion, challenge, or honest input'
]

/**
 * FeatureCards variables
 */
const cardsTitle = { text: 'What we believe', colour: 'pixel-green' }
const cards = [
  {
    title: 'Quality',
    description:
      'is not about perfection or polish for its own sake. It’s about doing the work properly — making considered decisions, paying attention to detail, and building things that last. You’ll see this in everything we deliver.'
  },
  {
    title: 'Honesty',
    description:
      'We believe honest conversations lead to better outcomes. We’re upfront about trade-offs, risks, and limitations — and we’d rather be clear early than fix problems later. You’ll always know where things stand.'
  },
  {
    title: 'Partnership',
    description:
      'The best work happens when responsibility is shared. We work with you, not at arm’s length — taking ownership and caring about the result as much as you do. We’re in this together.'
  },
  {
    title: 'Simplicity',
    description:
      'Complex problems don’t need complicated answers. We aim to make things easier to understand, easier to use, and easier to maintain — for everyone involved.'
  },
  {
    title: 'Delight',
    description:
      'Great digital work should feel good to use. We look for moments of clarity, care, and thoughtfulness that make the experience more enjoyable — without getting in the way of what matters.'
  }
]

/**
 * SectionCards variables
 */

const sectionCardsTitle = { text: 'Our process', colour: 'pixel-pink' }
const sectionText = {
  tagline: 'A clear path from uncertainty to outcomes.',
  description: [
    'Our process is designed to reduce risk, build confidence, and create momentum, without unnecessary ceremony. While every engagement is different, most follow a familiar flow.'
  ]
}

const sectionCards = [
  {
    title: 'Discovery & direction',
    description: [
      'We start by understanding the problem, the people involved, and the context around it. This often involves workshops, research, and exploration to get to the heart of what’s needed — without jumping to solutions or commitments too early.'
    ],
    url: '/services/discovery-direction',
    colour: '#63a3d2'
  },
  {
    title: 'Design',
    description: [
      'With a clear direction, we design the experience — whether that’s a brand, a website, an application, or a system. Our designs are grounded in user needs and strategic goals, balancing form and function to create something that works well and feels right.'
    ],
    url: '/services/design',
    colour: '#cab38f'
  },
  {
    title: 'Development',
    description: [
      'We build digital products that are reliable, maintainable, and fit for real-world use. Our development process is careful and deliberate, focused on quality over speed — because we know that how something is built matters just as much as what is built.'
    ],
    url: '/services/development',
    colour: '#e38093'
  },
  {
    title: 'Consulting',
    description: [
      "Not every challenge requires a build. We provide experienced digital leadership to support strategy, delivery, autonomy, and long-term decision-making. Whether that's as a virtual CTO, delivery lead, or trusted advisor, we're here to help you navigate complexity with confidence."
    ],
    url: '/services/digital-consulting',
    colour: '#f09339'
  },
  {
    title: 'AI',
    description: [
      'We help organisations leverage AI to drive innovation, improve efficiency, and make data-driven decisions. Our AI services include strategy, implementation, and ongoing support to ensure successful adoption and measurable impact.'
    ],
    url: '/services/ai',
    colour: '#479f82'
  }
]
---

<Layout
  title="About Us"
  description="Learn how Pixel Agency works. A practitioner-led digital agency focused on clarity, collaboration, and delivering real outcomes through thoughtful design and development."
>
  <section class="pt-10 pb-12 lg:pt-16 lg:pb-20">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-6">
        <h1 class="text-7xl lg:text-[80px] p-0">Senior digital thinking, carefully delivered.</h1>
      </div>
      <div class="col-span-full flex flex-col gap-4 mt-4 lg:mt-0 lg:col-start-8 lg:col-span-4">
        <div class="flex flex-col gap-3 mt-2 lg:mt-0 font-serif text-lg lg:text-2xl leading-[0.76]">
          <p>
            Pixel Agency is a digital design, development, and consulting partner for organisations that need clarity,
            confidence, and outcomes from their digital work.
          </p>
          <p>
            We design and build websites, applications, and systems <Plus desktopSize={28} /> provide the senior guidance
            needed to make good decisions along the way. Whether you’re shaping an idea, navigating complexity, or delivering
            something critical, our role is to help you move forward with purpose and care.
          </p>
          <p>
            We’re practitioners first. That means you work directly with the people doing the thinking and the building,
            not through a sales layer or handovers. The result is better conversations, better decisions, and work that
            holds up over time.
          </p>
        </div>
      </div>
    </Grid>
  </section>

  <SectionCards title={sectionCardsTitle} text={sectionText} cards={sectionCards} displayTextBackground={false} />

  <FeatureCards title={cardsTitle} cards={cards} />

  <WhoSection
    forTitle="We work best with organisations that"
    notForTitle='We’re probably <span class="underline">not</span> the right fit if'
    forItems={whoFor}
    notForItems={whoNotFor}
  />
</Layout>
