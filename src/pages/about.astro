---
import Layout from '@layouts/Layout.astro'
import WhoSection from '@components/services/WhoSection.astro'
import FeatureCards from '@components/services/FeatureCards.astro'
import Grid from '@components/Grid.astro'
import Plus from '@components/signs/Plus.astro'
import SectionCards from '@components/SectionCards.astro'
import { Image } from 'astro:assets'
import aboutImage from '@assets/pa-about-reduced.webp'
import ClientLogos from '@components/home/ClientLogos.astro'
import ContactForm from '@components/ContactForm.astro'
import CaseStudyDrawer from '@components/home/CaseStudyDrawer.astro'

/**
 * WhoSection variables
 */
const whoFor = [
  'Value clarity and thoughtful decision-making over speed for its own sake',
  'Want a trusted partner, not just a vendor who executes and moves on',
  'Care about outcomes, not just whether something shipped'
]

const whoNotFor = [
  'You’re looking for the cheapest or fastest option, regardless of quality',
  'You want execution without discussion, challenge, or honest input'
]

/**
 * FeatureCards variables
 */
const cardsTitle = { text: 'What we believe', colour: 'pixel-green' }
const cards = [
  {
    title: 'Quality',
    description:
      'is not about perfection or polish for its own sake. It’s about doing the work properly, making considered decisions, paying attention to detail, and building things that last. You’ll see this in everything we deliver.'
  },
  {
    title: 'Honesty',
    description:
      'We believe honest conversations lead to better outcomes. We’re upfront about trade-offs, risks, and limitations, and we’d rather be clear early than fix problems later. You’ll always know where things stand.'
  },
  {
    title: 'Partnership',
    description:
      'The best work happens when responsibility is shared. We work with you, not at arm’s length, taking ownership and caring about the result as much as you do. We’re in this together.'
  },
  {
    title: 'Simplicity',
    description:
      'Complex problems don’t need complicated answers. We aim to make things easier to understand, easier to use, and easier to maintain, for everyone involved.'
  },
  {
    title: 'Delight',
    description:
      'Great digital work should feel good to use. We look for moments of clarity, care, and thoughtfulness that make the experience more enjoyable, without getting in the way of what matters.'
  }
]

/**
 * SectionCards variables
 */

const sectionCardsTitle = { text: 'Our process', colour: 'pixel-pink' }
const sectionText = {
  tagline: 'A clear path<br/> from<br/> uncertainty to outcomes.',
  description: [
    'Our process is designed to reduce risk, build confidence, and create momentum, without unnecessary ceremony. While every engagement is different, most follow a familiar flow.'
  ]
}

const sectionCards = [
  {
    title: '1. Discovery + direction',
    description: [
      'Before any solution is shaped, you’ll leave the first phase knowing exactly what problem we’re solving, why it matters, and what success looks like.',
      'Through structured conversations and collaborative workshops, we work with you to unpack the challenge, understand who it affects, and clarify the path forward. No ambiguity carried into delivery.'
    ],
    url: '/services/discovery',
    colour: 'pixel-blue'
  },
  {
    title: '2. Design',
    description: [
      'You’ll see and approve designs that reflect your brand, your users, and your business goals before development begins. Design is where strategy becomes tangible, and where the gap between what was intended and what gets built is closed.'
    ],
    url: '/services/design',
    colour: 'pixel-cream'
  },
  {
    title: '3. Development',
    description: [
      'You’ll stay close to the build throughout. Because designers and developers work closely together, the gap between intention and execution stays small, and the final result stays true to the original vision. We build things that are robust, maintainable, and ready for the real world.'
    ],
    url: '/services/development',
    colour: 'pixel-pink'
  },
  {
    title: '4. Ongoing guidance',
    description: [
      'After launch, you’ll have a team that stays involved, supporting you through consulting, delivery oversight, or virtual CTO-style guidance as your needs evolve. Sometimes that means building more. Other times it means knowing when not to. The goal is always steady progress, supported by experience.'
    ],
    url: '/services/consulting',
    colour: 'pixel-orange'
  }
]
---

<Layout
  title="About Us"
  description="Learn how Pixel Agency works. A practitioner-led digital agency focused on clarity, collaboration, and delivering real outcomes through thoughtful design and development."
>
  <section id="hero" class="pt-10 pb-12 lg:pt-16 lg:pb-20">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-6">
        <h1 class="text-7xl lg:text-[80px] p-0">Senior digital thinking, carefully delivered.</h1>
      </div>
      <div class="col-span-full flex flex-col gap-4 mt-4 lg:mt-0 lg:col-start-8 lg:col-span-4">
        <div class="flex flex-col gap-3 mt-2 lg:mt-0">
          <p>
            Pixel Agency is a digital design, development, and consulting partner for organisations that need clarity,
            confidence, and outcomes from their digital work.
          </p>
          <p>
            We design and build websites, applications, systems, and provide the senior guidance needed to make good
            decisions along the way. Whether you’re shaping an idea, navigating complexity, or delivering something
            critical, our role is to help you move forward with purpose and care.
          </p>
          <p>
            <mark
              style="background: linear-gradient(to top, transparent 20%, var(--accent-bgc) 20%, var(--accent-bgc) 85%, transparent 75%); padding: 0 2px;"
              >We're practitioners first.</mark
            > That means you work directly with the people doing the thinking and the building, not through a sales layer
            or handovers. The result is better conversations, better decisions, and work that holds up over time.
          </p>
        </div>
      </div>
    </Grid>
  </section>

  <Image src={aboutImage} alt="" class="w-full h-[288px] lg:h-[456px] object-cover" widths={[768, 1440, 2560]} />

  <section id="pov" class="py-12 lg:py-20">
    <Grid>
      <div class="col-span-full lg:col-start-2">
        <h2 class="section-header text-pixel-blue">Our POV</h2>
      </div>
      <div class="col-span-full lg:col-start-2 lg:col-span-4 flex flex-col gap-4">
        <h3 class="text-[40px] lg:text-[80px] leading-[1.04] tracking-[-0.04em]">
          Work worth standing behind, with no sales theatre.
        </h3>
      </div>
      <div class="col-span-full lg:col-start-7 lg:col-span-5 flex flex-col gap-6 mt-6 lg:mt-0">
        <p>
          Pixel Agency creates digital work worth standing behind, where the people who shape the promise also design
          and build the outcome, with care for the business and the people who use it. In short, we do not believe in
          the sales theatre, so we have no sales team.
        </p>
        <p>
          We believe too much digital work is shaped by sales theatre, rushed promises, and hand-offs that dilute
          responsibility. The result is work that ships, but no one truly owns, and no one is proud of.
        </p>
        <p>
          We take a different approach. At Pixel Agency, responsibility stays close to the work. We speak honestly,
          challenge ideas that won’t add value, and say no when the fit isn’t right. We prioritise long-term
          partnerships over short-term wins and take pride in delivering work we’re happy to put our name on.
        </p>
        <p>
          This belief is not a positioning exercise, it’s how we operate. It shapes our decisions, our relationships,
          and the quality of what we create.
        </p>
      </div>
    </Grid>
  </section>

  <section id="how" class="py-12 lg:py-20">
    <Grid>
      <div class="col-span-full lg:col-start-2">
        <h2 class="section-header text-pixel-dark-red">How we work</h2>
      </div>
      <div class="col-span-full lg:col-start-2 lg:col-span-4 flex flex-col gap-4">
        <h3 class="text-[40px] lg:text-[80px] leading-[1.04] tracking-[-0.04em]">
          Thoughtful, collaborative, <Plus size={24} desktopSize={84} /> outcome-focused.
        </h3>
      </div>
      <div class="col-span-full lg:col-start-7 lg:col-span-5 flex flex-col gap-6 mt-6 lg:mt-0">
        <p>
          From the first conversation through to delivery, you work directly with experienced designers, developers, and
          digital specialists who are actively involved in your project. No handovers. No junior teams receiving a
          second-hand brief.
        </p>
        <div class="w-full h-[254px] bg-gray-200">Placeholder</div>
        <p>
          We operate as a senior, flexible team, bringing together the right people for each engagement and taking
          ownership beyond the brief. You get clear thinking, honest advice, and a team that adapts as your project
          evolves.
        </p>
      </div>
    </Grid>
  </section>

  <SectionCards title={sectionCardsTitle} text={sectionText} cards={sectionCards} displayTextBackground={false} />

  <section id="team" class="bg-pixel-off-cream overflow-hidden mt-6">
    {/* Content + horizontal scroll area */}
    <div id="team-scroll-wrapper" class="relative max-w-360 mx-auto px-5 pt-16 lg:pt-14">
      <div id="team-scroll-inner" class="flex flex-col pb-16 lg:pb-12">
        <h2 class="section-header text-pixel-orange mb-4 lg:mb-6">Our team</h2>
        <h3 class="text-2xl lg:text-[140px] leading-[0.95] tracking-[-0.03em] lg:whitespace-nowrap pb-6 lg:pb-10">
          Experienced people who care deeply about the work.
        </h3>
        <div class="flex flex-col lg:flex-row lg:gap-5">
          {/* Left: body text — col-span-4 width on desktop */}
          <div id="team-text" class="shrink-0 flex flex-col gap-4 mb-8 lg:mb-0">
            <p>
              Pixel Agency is a team of industry veterans focused on building high-quality digital products that solve
              real business and user problems.
            </p>
            <p>
              We prioritise quality and long-term value over sales targets, which is why you'll work directly with the
              experts delivering your project, not a salesperson. It's a more honest way of working, and one that leads
              to better results.
            </p>
          </div>

          {/* Team member cards */}
          <div id="team-cards" class="flex shrink-0 overflow-x-auto lg:overflow-visible -mx-5 px-5 lg:mx-0 lg:px-0">
            {
              [
                { name: 'Benny', role: 'Principle Nerd', colour: 'bg-pixel-green', image: 'benny' },
                { name: 'Julio', role: 'UX/UI Nerd', colour: 'bg-pixel-blue', image: 'julio' },
                { name: 'Dave', role: 'Web Nerd', colour: 'bg-pixel-red', image: 'dave' },
                { name: 'Alyssa', role: 'Finance Nerd', colour: 'bg-pixel-pink', image: 'alyssa' },
                { name: 'Christiaan', role: 'Web Nerd', colour: 'bg-pixel-yellow', image: 'christiaan' },
                { name: 'Aaron', role: 'Data Nerd', colour: 'bg-pixel-cream', image: 'aaron' },
                { name: 'Harvin', role: 'App Nerd', colour: 'bg-pixel-red', image: 'harvin' },
                { name: 'Johnny', role: 'App Nerd', colour: 'bg-pixel-orange', image: 'jong' },
                { name: 'Stephan', role: 'UX/UI Nerd', colour: 'bg-pixel-light-pink', image: 'stephan' },
                { name: 'Stuart', role: 'Cloud Nerd', colour: 'bg-pixel-green', image: 'stuart' },
                { name: 'Hoang', role: 'AI Nerd', colour: 'bg-pixel-yellow', image: 'hoang' },
                { name: 'Gabriella', role: 'Design Nerd', colour: 'bg-pixel-pink', image: 'gabriella' }
              ].map((member) => (
                <div
                  class={`shrink-0 w-[140px] lg:w-[240px] h-[140px] lg:h-[240px] relative overflow-hidden flex flex-col items-center ${member.colour}`}
                >
                  {member.image && (
                    <img
                      src={`/team/${member.image}.webp`}
                      alt={member.name}
                      class="w-[50%] h-[50%] object-contain mt-3 lg:mt-5"
                    />
                  )}
                  <div class="absolute bottom-0 left-0 right-0 p-3 lg:p-4">
                    <p class="font-sans text-xs lg:text-sm">
                      {member.name}
                      <br />
                      {member.role}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <FeatureCards title={cardsTitle} cards={cards} />

  <section id="experience" class="py-12 lg:py-20">
    <Grid>
      <div class="col-span-full lg:col-start-2">
        <h2 class="text-2xl lg:text-4xl leading-[1.04] tracking-[-0.04em] text-pixel-brown">Our experience</h2>
      </div>
      <div class="col-span-full lg:col-start-2 lg:col-span-4 flex flex-col gap-6">
        <div class="flex flex-col gap-4">
          <p>
            Our team brings over 20 years of experience delivering digital projects across a wide range of industries,
            from TAFE institutes and established businesses in traditional sectors to startups and global organisations
            operating at scale.
          </p>
          <p>
            That breadth means we adapt to your context without losing our standard of care. And it gives us the
            confidence to be selective, honest, and deeply involved, rather than stretched thin or transactional.
          </p>
        </div>
      </div>
      <div class="col-span-full lg:col-start-7 lg:col-span-5 mt-8 lg:mt-0">
        <div class="w-full aspect-[4/3] bg-gray-200">
          <CaseStudyDrawer size="small" />
        </div>
      </div>
    </Grid>
  </section>

  <ClientLogos />

  <WhoSection
    forTitle="We work best with organisations that"
    notForTitle='We’re probably <span class="underline">not</span> the right fit if'
    forItems={whoFor}
    notForItems={whoNotFor}
  />

  <ContactForm />

  <style>
    #team-cards {
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    #team-cards::-webkit-scrollbar {
      display: none;
    }
    @media (min-width: 1024px) {
      #team-scroll-inner {
        padding-left: calc((100% - 11 * 20px) / 12 + 20px);
      }
      #team-text {
        width: calc(4 * (100% - 11 * 20px) / 12 + 3 * 20px);
        margin-right: calc(1 * (100% - 11 * 20px) / 12 + 4.6 * 20px - 20px);
      }
      #team-cards {
        padding-right: calc((100% - 16 * 20px) / 12 + 20px);
      }
    }
  </style>

  <script>
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    import Lenis from 'lenis'

    gsap.registerPlugin(ScrollTrigger)

    // ── Lenis smooth scroll ──
    const lenis = new Lenis()
    lenis.on('scroll', ScrollTrigger.update)
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000)
    })
    gsap.ticker.lagSmoothing(0)

    // ── Horizontal scroll for team section (desktop only) ──
    const ctx = gsap.context(() => {
      ScrollTrigger.matchMedia({
        '(min-width: 1024px)': () => {
          const wrapper = document.getElementById('team-scroll-wrapper')!
          const inner = document.getElementById('team-scroll-inner')!

          // Calculate how far we need to scroll horizontally
          const getScrollAmount = () => inner.scrollWidth - wrapper.offsetWidth
          const pause = 500 // px of scroll distance for the pause

          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: wrapper,
              start: 'top top',
              end: () => `+=${getScrollAmount() + pause * 2}`,
              pin: true,
              scrub: 1,
              invalidateOnRefresh: true
            }
          })

          // Pause at start, then scroll, then pause at end
          tl.to(inner, { x: 0, duration: pause })
          tl.to(inner, { x: () => -getScrollAmount(), duration: getScrollAmount(), ease: 'none' })
          tl.to(inner, { x: () => -getScrollAmount(), duration: pause })
        }
      })
    })

    // Clean up on Astro page transitions
    document.addEventListener(
      'astro:before-swap',
      () => {
        ctx.revert()
        lenis.destroy()
      },
      { once: true }
    )
  </script>
</Layout>
