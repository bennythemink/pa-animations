---
import Layout from '@layouts/Layout.astro'

import HeroSection from '@components/services/HeroSection.astro'
import CaseStudiesSection from '@components/services/CaseStudiesSection.astro'
import WhatWeDoSection from '@components/services/WhatWeDoSection.astro'

import OurApproachSection from '@components/services/OurApproachSection.astro'
import Vector from '@components/signs/Vector.astro'
import Plus from '@components/signs/Plus.astro'
import FeatureCards from '@components/services/FeatureCards.astro'
import WhoSection from '@components/services/WhoSection.astro'

import ContactForm from '@components/ContactForm.astro'

import holmesglen from '@assets/services/education/holmesglen.svg'
import vicUni from '@assets/services/education/vic-uni.svg'
import chisholm from '@assets/services/education/chisholm.svg'
import inclusion from '@assets/services/education/inclusion.svg'
import Grid from '@components/Grid.astro'

/**
 * HeroSection variables
 */
const pageTitle = 'Education'
const tagline = 'Education strategy, compliance and curriculum that is practical and effective.'
const paragraphs = [
  'Our team of highly experienced, formally trained educators know exactly how much care, expertise, and professional judgement goes into building educational systems, frameworks and materials that actually work. We also know how rarely the market delivers it.',
  'Traditional consulting services offer reports that sits on shelves.',
  'We work differently. We combine deep, applied expertise in Vocational Education and Training (VET), schools, compliance, and educational governance to solve complex education challenges.'
]

/**
 * WhatWeDoSection variables
 */
const whatWeConsultOn = [
  'RTO setup',
  'Compliance',
  'Governance frameworks',
  'Education business models',
  'Strategies for growth',
  'New education products',
  'Workforce planning',
  'Project planning, management and delivery',
  'Professional development for Education and Teaching teams'
]

/**
 * ApproachPointsSection variables
 */
const cardsTitle = { text: 'Our process', colour: 'pixel-celestial' }
const cards = [
  {
    title: 'Understand',
    description:
      'we begin by getting a clear picture of your organisation, your learners, your compliance requirements, and what good looks like for you.'
  },
  {
    title: 'Framework',
    description:
      'we map out the structure of the content; units, assessments, or programs, and share it with you before any writing begins.'
  },
  {
    title: 'Review',
    description:
      'you provide feedback on the framework and solution map, so the final content reflects your context and requirements.'
  },
  {
    title: 'Create',
    description:
      'we write and build the material to TAFE compliance standards, with the care and rigour the subject matter deserves.'
  }
]

/**
 * WhoSection variables
 */
const whoFor = [
  'RTOs and TAFEs that need high-quality, compliant learning material they can actually use',
  'Education providers strengthening their governance frameworks and policies',
  'New RTOs seeking advice on setup and compliance',
  'Teams needing professional development content that respects the expertise of the people receiving it'
]

const whoNotFor = [
  'Organisations whose primary requirement is the lowest possible cost, regardless of quality or usability',
  'Providers looking for content that simply ticks a compliance box rather than genuinely supports learning'
]
---

<Layout
  title="Education Resources + Consulting Services"
  description="High-quality, compliant learning material, including courses, units, and assessments, for RTOs and TAFEs, designed to genuinely support learners and meet your specific requirements."
>
  <HeroSection title={pageTitle} tagline={tagline} paragraphs={paragraphs} stack={true} />

  <Grid>
    <h2 class="lg:col-start-2 col-span-full text-lg lg:text-4xl text-pixel-rosy">Our team has worked with:</h2>
  </Grid>
  <Grid>
    <img src={holmesglen.src} alt="Holmesglen" class="col-span-3" />
    <img src={chisholm.src} alt="Chisholm" class="col-span-3" />
    <img src={inclusion.src} alt="Inclusion" class="col-span-3" />
    <img src={vicUni.src} alt="Victoria University" class="col-span-3" />
  </Grid>

  <WhatWeDoSection
    title="We help organisations think about how education is delivered, structured + scaled:"
    items={whatWeConsultOn}
  />

  <OurApproachSection>
    <p>We don't start creating until we understand what you + your learners need from the material.</p>
  </OurApproachSection>

  <FeatureCards title={cardsTitle} cards={cards} />

  <OurApproachSection label="Our difference" labelColour="pixel-teal">
    We don't produce content that passes a checklist. We produce resources you are proud to deliver.
  </OurApproachSection>

  <WhoSection forItems={whoFor} notForItems={whoNotFor} />

  <ContactForm title="Let's talk about what you're trying to achieve." />
</Layout>
