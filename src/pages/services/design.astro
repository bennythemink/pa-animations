---
import Layout from '@layouts/Layout.astro'
import Grid from '@components/Grid.astro'
import ContactForm from '@components/ContactForm.astro'
import Vector from '@components/signs/Vector.astro'
import WhoSection from '@components/services/WhoSection.astro'
import OurApproachSection from '@components/services/OurApproachSection.astro'
import ApproachPointsSection from '@components/services/ApproachPointsSection.astro'

const whoFor = [
  'Organisations that want their digital presence to work harder for their users and their business',
  'Teams building new digital products or platforms who need design that holds up end-to-end',
  'Businesses that want design balancing form and function — not one at the expense of the other'
]

const whoNotFor = [
  'Projects where the design is already complete and ready for development',
  'Engagements where usability and user outcomes are secondary to speed or cost'
]
---

<Layout
  title="Design"
  description="Digital experiences designed for the people who use them, not just the screens they're on."
>
  {/* ── Hero ── */}
  <section class="pt-10 pb-12 lg:pt-16 lg:pb-20">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-5">
        <h1 class="text-7xl lg:text-[140px] p-0">Design</h1>
      </div>
      <div class="col-span-full lg:col-start-7 lg:col-span-5 flex flex-col gap-4 mt-4 lg:mt-6">
        <h2 class="text-lg lg:text-3xl">
          Digital experiences designed for the people who use them, not just the screens they're on.
        </h2>
        <div class="flex flex-col gap-3 mt-2 text-lg leading-[0.76]">
          <p>
            Good design is more than how something looks. It's how clearly it communicates, how easily it's used, and
            how well it supports the outcome you're trying to achieve.
          </p>
          <p>
            We design brands, websites, and applications that balance clarity, usability, and personality — grounded in
            how real people use digital products, and proud to put our name on the result.
          </p>
        </div>
      </div>
    </Grid>
  </section>

  {/* ── Case studies ── */}
  <section class="pb-16 lg:pb-24">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-4 flex flex-col gap-2">
        <a href="/case-studies/eel" class="underline underline-offset-2 hover:no-underline"
          ><div class="w-full aspect-[4/3]" style="background-color: #d4834a;"></div></a
        >
        <div class="flex items-center justify-between font-sans text-xs">
          <a href="/case-studies/eel" class="underline underline-offset-2 hover:no-underline">Case study</a>
          <span class="text-black/40">Explorers Early Learning</span>
        </div>
      </div>

      <div class="col-span-full lg:col-start-6 lg:col-span-7 flex flex-col gap-2 mt-6 lg:mt-0">
        <a href="/case-studies/simple" class="underline underline-offset-2 hover:no-underline"
          ><div class="w-full aspect-[4/3]" style="background-color: #1e2235;"></div>
        </a>

        <div class="flex items-center justify-between font-sans text-xs">
          <a href="/case-studies/simple" class="underline underline-offset-2 hover:no-underline">Case study</a>
          <span class="text-black/40">Simple.io</span>
        </div>
      </div>
    </Grid>
  </section>

  {/* ── We design ── */}
  <section class="py-12 lg:py-20">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-4">
        <h2 style="font-size: clamp(2rem, 5vw, 4rem);">We design:</h2>
      </div>
      <ul
        class="col-span-full lg:col-start-7 lg:col-span-6 flex flex-col justify-center gap-3 font-sans text-lg lg:text-2xl mt-6 lg:mt-0"
      >
        <li class="flex items-center gap-3 border-b-2 border-[#e6e2df] py-2 lg:py-4">
          <span class="shrink-0 w-[12px] h-[12px]" style="background-color: var(--accent-bgc);"></span>
          Brands and identities
        </li>
        <li class="flex items-center gap-3 border-b-2 border-[#e6e2df] py-2 lg:py-4">
          <span class="shrink-0 w-[12px] h-[12px]" style="background-color: var(--accent-bgc);"></span>
          Websites and digital products
        </li>
        <li class="flex items-center gap-3 border-b-2 border-[#e6e2df] py-2 lg:py-4">
          <span class="shrink-0 w-[12px] h-[12px]" style="background-color: var(--accent-bgc);"></span>
          Applications and platforms
        </li>
      </ul>
    </Grid>
  </section>

  {/* ── Our approach ── */}
  <OurApproachSection>
    Every design decision we make is deliberate <Vector size={28} desktopSize={80} /> in service of the people using the product
    and the outcomes it needs to deliver.
  </OurApproachSection>

  <ApproachPointsSection
    title={{ text: 'What we believe', colour: 'pixel-green' }}
    ,
    cards={[
      { title: 'Grounded', description: "in your users' needs and the strategy behind the work" },
      { title: 'Focused', description: 'on clarity and ease of use, not visual complexity' },
      {
        title: 'Expressive',
        description: 'without being distracting, personality in service of purpose'
      },
      { title: 'Considered', description: 'from end-to-end, not just at the surface' }
    ]}
  />

  {/* ── Who this is for / not for ── */}
  <WhoSection forItems={whoFor} notForItems={whoNotFor} />

  {/* ── CTA + Form ── */}
  <Grid>
    <ContactForm title="Let's talk about what you're trying to achieve." />
  </Grid>
</Layout>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  let ctx: gsap.Context | null = null

  function init() {
    ctx?.revert()
    ctx = null

    const approachSection = document.getElementById('approach-section')
    const approachText = document.getElementById('approach-text')
    const approachPoints = document.getElementById('approach-points')
    const cardGrounded = document.getElementById('card-grounded')
    const cardFocused = document.getElementById('card-focused')
    const cardExpressive = document.getElementById('card-expressive')
    const cardConsidered = document.getElementById('card-considered')
    if (!approachSection || !approachText) return

    // Equalise card heights on desktop only
    const cards = [cardGrounded, cardFocused, cardExpressive, cardConsidered].filter(Boolean) as HTMLElement[]
    cards.forEach((c) => (c.style.height = ''))
    if (window.innerWidth >= 1024) {
      const maxH = Math.max(...cards.map((c) => c.offsetHeight))
      cards.forEach((c) => (c.style.height = `${maxH}px`))
    }

    ctx = gsap.context(() => {
      // Approach points: clip-path reveal animations
      if (approachPoints && cardGrounded && cardFocused && cardExpressive && cardConsidered) {
        gsap.set(cardGrounded, { clipPath: 'inset(0% 0% 100% 0%)' })
        gsap.set(cardFocused, { clipPath: 'inset(100% 0% 0% 0%)' })
        gsap.set(cardExpressive, { clipPath: 'inset(0% 100% 0% 0%)' })
        gsap.set(cardConsidered, { clipPath: 'inset(0% 0% 0% 100%)' })

        gsap.to(cardGrounded, {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 0.9,
          ease: 'power2.out',
          scrollTrigger: { trigger: cardGrounded, start: 'top 85%', once: true }
        })
        gsap.to(cardFocused, {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 0.9,
          ease: 'power2.out',
          scrollTrigger: { trigger: cardFocused, start: 'top 85%', once: true }
        })
        gsap.to(cardExpressive, {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 0.9,
          ease: 'power2.out',
          scrollTrigger: { trigger: cardExpressive, start: 'top 85%', once: true }
        })
        gsap.to(cardConsidered, {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 0.9,
          ease: 'power2.out',
          scrollTrigger: { trigger: cardConsidered, start: 'top 85%', once: true }
        })
      }
    })

    ScrollTrigger.refresh()
  }

  // Call immediately for initial page load (astro:page-load may have already fired)
  init()

  window.addEventListener('resize', init)

  // Re-init on subsequent navigations via ClientRouter
  document.addEventListener('astro:page-load', init)
  document.addEventListener('astro:before-swap', () => {
    ctx?.revert()
    ctx = null
  })
</script>
