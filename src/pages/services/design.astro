---
import Layout from '@layouts/Layout.astro'
import Grid from '@components/Grid.astro'
import HeroSection from '@components/services/HeroSection.astro'
import ContactForm from '@components/ContactForm.astro'
import Vector from '@components/signs/Vector.astro'
import WhoSection from '@components/services/WhoSection.astro'
import OurApproachSection from '@components/services/OurApproachSection.astro'

import mbImage from '@assets/mb.png'
import iphoneImage from '@assets/iphone.png'
import CaseStudiesSection from '@components/services/CaseStudiesSection.astro'
import WhatWeDoSection from '@components/services/WhatWeDoSection.astro'

import FeatureCards from '@components/services/FeatureCards.astro'

/**
 * HeroSection variables
 */
const pageTitle = 'Design'
const tagline = "Digital experiences designed for the people who use them, not just the screens they're on."
const paragraphs = [
  "Good design is more than how something looks. It's how clearly it communicates, how easily it's used, and how well it supports the outcome you're trying to achieve.",
  'We design brands, websites, and applications that balance clarity, usability, and personality, grounded in how real people use digital products, and proud to put our name on the result.'
]

/**
 * CaseStudiesSection variables
 */

const first = {
  title: 'Explorers Early Learning',
  link: '/case-studies/eel',
  image: mbImage
}

const second = {
  title: 'Insulation.com.au',
  link: '/case-studies/insulation',
  image: iphoneImage
}

/**
 * WhatWeDoSection variables
 */
const whatWeBuild = ['Brands & identities', 'Websites & digital products', 'Applications & platforms']

/**
 * FeatureCards variables
 */
const cardsTitle = { text: 'Our design is', colour: 'pixel-blue' }
const cards = [
  { title: 'Grounded', description: "in your users' needs and the strategy behind the work" },
  { title: 'Focused', description: 'on clarity and ease of use, not visual complexity' },
  {
    title: 'Expressive',
    description: 'without being distracting, personality in service of purpose'
  },
  { title: 'Considered', description: 'from end-to-end, not just at the surface' }
]

/**
 * WhoSection variables
 */
const whoFor = [
  'Organisations that want their digital presence to work harder for their users and their business',
  'Teams building new digital products or platforms who need design that holds up end-to-end',
  'Businesses that want design balancing form and function — not one at the expense of the other'
]

const whoNotFor = [
  'Projects where the design is already complete and ready for development',
  'Engagements where usability and user outcomes are secondary to speed or cost'
]
---

<Layout
  title="Design"
  description="Digital experiences designed for the people who use them, not just the screens they're on."
>
  <HeroSection title={pageTitle} tagline={tagline} paragraphs={paragraphs} />

  <CaseStudiesSection first={first} second={second} />

  <WhatWeDoSection title="We design:" items={whatWeBuild} />

  {/* ── Our approach ── */}
  <OurApproachSection>
    Every design decision we make is deliberate <Vector size={28} desktopSize={80} /> in service of the people using the product
    and the outcomes it needs to deliver.
  </OurApproachSection>

  <FeatureCards title={cardsTitle} cards={cards} />

  {/* ── Who this is for / not for ── */}
  <WhoSection forItems={whoFor} notForItems={whoNotFor} />

  {/* ── CTA + Form ── */}
  <Grid>
    <ContactForm title="Let's talk about what you're trying to achieve." />
  </Grid>
</Layout>
