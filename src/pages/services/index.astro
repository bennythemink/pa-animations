---
import Layout from '@layouts/Layout.astro'
import Grid from '@components/Grid.astro'
import Equals from '@components/signs/Equals.astro'
import CTA from '@components/CTA.astro'
import { resolvePixelColour } from '@config/colours'

import { Image } from 'astro:assets'
import servicesHero from '@assets/pa-services-placeholder.png'

const services = [
  {
    name: 'Discovery + direction',
    href: '/services/discovery',
    tagline: 'Clarity before commitment.',
    description:
      'For organisations that know something needs to change, but need help defining the problem, the solution, and the investment required. Discovery and direction helps establish shared understanding, reduce uncertainty, and create a clear, defensible path forward, before committing to delivery.',
    bg: 'pixel-celestial'
  },
  {
    name: 'Design',
    href: '/services/design',
    tagline: 'Human-centred digital experiences.',
    description:
      'We design brands, websites, and applications that are clear, considered, and enjoyable to use, balancing visual expression with usability and purpose. Design translates strategy into something tangible, aligning user needs with business goals.',
    bg: 'pixel-fawn'
  },
  {
    name: 'Development',
    href: '/services/development',
    tagline: 'Reliable, scalable digital solutions.',
    description:
      'From websites to applications and custom systems, we build digital products that are robust, maintainable, and fit for real-world use. Development is where ideas become working solutions, built carefully, not rushed.',
    bg: 'pixel-rosy'
  },
  {
    name: 'AI',
    href: '/services/ai',
    tagline: 'Practical AI strategy and implementation.',
    description:
      'We help organisations leverage AI to drive innovation, improve efficiency, and make data-driven decisions. Our AI services include strategy, implementation, and ongoing support to ensure successful adoption and measurable impact.',
    bg: 'pixel-teal'
  },
  {
    name: 'Consulting',
    href: '/services/consulting',
    tagline: 'Strategy, leadership, and clarity at every stage.',
    description:
      "Not every challenge requires a build. We provide experienced digital leadership to support strategy, delivery, autonomy, and long-term decision-making. Digital Consulting helps organisations navigate complexity with confidence, whether that's as a virtual CTO, delivery lead, or trusted advisor.",
    bg: 'pixel-fire'
  }
]
---

<Layout
  title="Digital Services for Clear, Outcome-Focused Delivery"
  description="Explore Pixel Agency’s digital services: from discovery and design to development, consulting and AI. A senior digital partner helping organisations move from uncertainty to outcomes."
>
  {/* ── Hero ── */}
  <section class="pt-10 pb-8 lg:pt-16 lg:pb-20">
    <Grid>
      <div class="col-span-full lg:col-start-2 lg:col-span-9">
        <h2 style="font-size: clamp(2.5rem, 6vw, 5.5rem);">Wherever you're starting from, there's a path forward.</h2>
      </div>
    </Grid>
  </section>

  {/* ── Hero image ── */}
  <div class="w-full">
    <Image src={servicesHero} alt="A tablet displaying a data areas interface" class="w-full block object-cover" />
  </div>

  {/* ── Intro + services list ── */}
  <section class="py-12 lg:py-20">
    <Grid>
      {/* Left: body copy */}
      <div id="services-intro" class="col-span-full lg:col-start-2 lg:col-span-4 flex flex-col gap-4 font-serif">
        {
          /* Invisible spacer — matches height of "Our services" label to align first paragraph with first service link */
        }
        <p aria-hidden="true" class="font-sans text-xs tracking-widest mb-4 hidden lg:block invisible">Our services</p>
        <p>
          Digital projects rarely follow a straight line. Some start with a clear brief. Others start with a problem
          that needs unpacking. Most land somewhere in between.
        </p>
        <p>
          Our services are designed to meet you where you are, helping you move from uncertainty to clarity, and from
          ideas to outcomes you're proud of. You can engage us at any stage, for a single service or across multiple
          phases, depending on what you need.
        </p>
        <p>
          Whichever path you take, the people responsible for the outcome are the same people doing the work. No
          hand-offs.
        </p>
        <CTA label="Let's talk about your needs" />
      </div>

      {/* Right: services list */}
      <div id="services-list" class="col-span-full lg:col-start-7 lg:col-span-6 flex flex-col mt-6 lg:mt-0">
        <h1 class="font-sans text-base tracking-widest text-black/50 mb-4">Our services</h1>
        {
          services.map((s) => (
            <a
              href={s.href}
              class="service-link flex items-center justify-between border-b border-black/20 py-4 font-sans"
              style="font-size: clamp(1.25rem, 2.5vw, 1.75rem);"
            >
              <span>{s.name}</span>
              <span aria-hidden="true" class="arrow ml-4 shrink-0">
                →
              </span>
            </a>
          ))
        }
      </div>
    </Grid>
  </section>

  {/* ── How our services work together ── */}
  <section>
    <Grid>
      {/* Left: platinum background text block */}
      <div
        id="services-blurb"
        class="col-span-full lg:col-start-1 lg:col-span-6 lg:self-start lg:sticky lg:top-34 lg:grid lg:grid-cols-subgrid"
        style="background-color: var(--color-pixel-platinum);"
      >
        {/* Inner content inset to match services-intro left edge */}
        <div class="col-span-full lg:col-start-2 lg:col-span-5 flex flex-col gap-6 p-10 lg:py-16 lg:pr-16 lg:pl-0">
          <p
            class="font-sans font-normal text-[18px] lg:text-[40px]"
            style="color: var(--color-pixel-teal); letter-spacing: 0; line-height: 1.1;"
          >
            How our services work together
          </p>
          <h2 class="text-3xl lg:text-[80px]">
            From uncertainty<br />to outcomes.
          </h2>
          <div class="flex flex-col gap-4 font-serif mt-3.5 lg:mt-12">
            <p>
              Most digital work fails long before anything is built, often due to unclear direction, rushed decisions,
              or a lack of experienced guidance early on.
            </p>
            <p>
              Our approach is intentionally structured to reduce that risk. We help clients clarify the problem first,
              design solutions that make sense for real users, build them properly, and provide ongoing guidance when
              decisions continue beyond launch.
            </p>
            <p>
              Not every project requires every service. This framework simply reflects how strong digital outcomes are
              typically achieved.
            </p>
            <p>
              We keep responsibility close to the work, so decisions are made by the people who will ultimately stand
              behind the result.
            </p>
          </div>
        </div>
      </div>

      {/* Right: service cards — horizontal scroll on mobile, stacked on desktop */}
      <div id="service-cards" class="col-span-full lg:col-start-7 lg:col-span-6">
        <div
          class="flex items-stretch overflow-x-auto snap-x snap-mandatory lg:flex-col lg:overflow-x-clip w-[calc(100vw-20px)] lg:w-auto pr-5 lg:pr-0 gap-3 lg:gap-5 pb-6 lg:pb-0"
        >
          {
            services.map((s) => (
              <div
                class="shrink-0 snap-start w-[300px] min-h-[300px] lg:w-auto lg:h-[464px] flex flex-col pt-5 px-5 lg:px-8 pb-5 justify-between"
                style={`background-color: ${resolvePixelColour(s.bg)};`}
              >
                <div class="flex items-start justify-between gap-4">
                  <h3 class="text-[40px]">{s.name}</h3>
                  <a
                    href={s.href}
                    class="hidden lg:inline font-sans text-sm underline underline-offset-2 hover:no-underline transition-all shrink-0"
                  >
                    Learn more
                  </a>
                </div>
                <div class="pt-4 flex flex-col gap-3">
                  <h4 class="font-sans text-2xl lg:text-3xl font-normal text-white" style="opacity: 0.8;">
                    {s.tagline}
                  </h4>
                  <p class="font-serif max-w-[540px]" style="opacity: 0.7;">
                    {s.description}
                  </p>
                  <a href={s.href} class="lg:hidden font-sans text-sm underline underline-offset-2 self-start">
                    Learn more
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </Grid>
  </section>

  {/* ── CTA ── */}
  <section class="py-16 lg:py-24">
    <Grid>
      {/* Left: headline */}
      <div class="col-span-full lg:col-start-2 lg:col-span-6">
        <h2 class="text-3xl lg:text-[40px] leading-tight">
          Not sure where to start? <br />
          <Equals /> That's exactly where we help.
        </h2>
      </div>

      {/* Right: body + CTA link */}
      <div class="col-span-full lg:col-start-8 lg:col-span-5 flex flex-col justify-center gap-6">
        <p class="font-serif">
          If you're facing a digital challenge, exploring an idea, or unsure where to begin, we're always happy to talk
          it through. No sales pitch, just practical discussion and honest advice about what your situation actually
          needs.
        </p>
        <div class="mt-6">
          <CTA label="Let's find a path forward →" />
        </div>

        <!-- <a href="/contact" class="font-sans self-start underline underline-offset-2 hover:no-underline transition-all">
          Let's find a path forward →
        </a> -->
      </div>
    </Grid>
  </section>
</Layout>

<style>
  .service-link {
    transition: color 0.25s ease;
  }
  .service-link .arrow {
    color: var(--color-pixel-brown);
    transition: color 0.25s ease;
  }
  .service-link:hover,
  .service-link:hover .arrow {
    color: var(--accent-bgc);
  }
</style>
