---
import ContactForm from '@components/ContactForm.astro'
import HeroSection from '@components/services/HeroSection.astro'
import Layout from '@layouts/Layout.astro'

import CaseStudiesSection from '@components/services/CaseStudiesSection.astro'
import WhatWeDoSection from '@components/services/WhatWeDoSection.astro'
import OurApproachSection from '@components/services/OurApproachSection.astro'
import Plus from '@components/signs/Plus.astro'
import FeatureCards from '@components/services/FeatureCards.astro'
import WhoSection from '@components/services/WhoSection.astro'
import Callout from '@components/Callout.astro'

import fletcher from '@assets/case-studies/fletcher-ai/fourThree.webp'
import sonata from '@assets/case-studies/sonata-ai/fourThree.webp'

/**
 * HeroSection variables
 */
const pageTitle = 'AI'
const tagline = 'Practical AI, delivered by the people doing the work.'
const paragraphs = [
  "AI is changing how digital products are built and how businesses operate. The hard part for most organisations is working out where it actually fits, what's worth investing in, and how to build something that holds up once the novelty wears off.",
  "Our AI service covers strategy and advisory, custom builds, and workflow automation. The work is grounded in your real business problems, shaped by people who've delivered complex digital systems before, and honest about what AI can and can't do today."
]

/**
 * CaseStudiesSection variables
 */

const first = {
  title: 'Insulation.com.au AI Assistant',
  link: '/case-studies/fletcher-ai',
  image: fletcher
}

const second = {
  title: 'Acoustic Risk AI Risk Assessment Tool',
  link: '/case-studies/sonata-ai',
  image: sonata
}

/**
 * WhatWeDoSection variables
 */
const aiServices = [
  'AI strategy and senior advisory',
  'Custom AI-powered tools, copilots, and features',
  'Workflow automation and intelligent agents'
]

/**
 * FeatureCards variables
 */
const cardsTitle = { text: 'Our AI services is', colour: 'pixel-celestial' }
const cards = [
  {
    title: 'Grounded',
    description: 'in your real business problem, not a solution looking for one.'
  },
  {
    title: 'Honest',
    description: "about what AI can and can't do today, including the trade-offs, risks, and limitations."
  },
  {
    title: 'Sensible',
    description:
      "in its technical foundations, so the solution is reliable, maintainable, and doesn't break the first time the underlying model changes"
  },
  {
    title: 'Focused',
    description: 'on outcomes you can measure, so the investment is justified, and the impact is clear.'
  }
]

/**
 * WhoSection variables
 */
const whoFor = [
  'Organisations that know AI is relevant to them but need help figuring out where and how',
  'Teams looking for honest guidance before committing to significant AI investment',
  'Businesses that want AI solutions built properly, not prototypes dressed up as products'
]

const whoNotFor = [
  "Projects driven by 'we need an AI story' rather than a real problem to solve",
  'Teams looking for the cheapest possible build, regardless of whether it holds up over time',
  'Organisations wanting validation of a pre-chosen AI solution, rather than honest assessment'
]
---

<Layout
  title="AI Strategy, Custom AI Builds & Automation"
  description="Practical AI strategy and implementation to drive innovation, improve efficiency, and make data-driven decisions. Leveraging AI for measurable impact."
>
  <HeroSection title={pageTitle} tagline={tagline} paragraphs={paragraphs} />
  <CaseStudiesSection first={first} second={second} />

  <WhatWeDoSection title="Our AI services:" items={aiServices} />

  <Callout
    calloutText="Looking for a fully-managed, AI-powered knowledge assistant for your website? See our dedicated product, Pixel Assist."
    ctaText="Let's take a look →"
  />

  <div class="my-12 lg:my-20"></div>

  <OurApproachSection>
    <p>
      We focus on practical AI solutions that deliver real value, not just flashy demos. Our approach is grounded in
      understanding your unique challenges <Plus size={28} desktopSize={64} /> goals. We design AI implementations that are
      aligned with your long-term vision.
    </p>
  </OurApproachSection>

  <FeatureCards title={cardsTitle} cards={cards} />

  <OurApproachSection label="Our goal" labelColour="pixel-teal">
    We don't chase trends. We build AI solutions that do a specific job well, and we stay involved to make sure they
    keep doing it.
  </OurApproachSection>

  <WhoSection forItems={whoFor} notForItems={whoNotFor} />

  <ContactForm title="Let's talk about what you're trying to achieve." />
</Layout>
