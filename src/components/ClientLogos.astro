---
interface ClientLogo {
  src: string
  name: string
  industry?: string
  services?: string[]
  description?: string
  url?: string
}

interface Props {
  speed?: 'slow' | 'normal' | 'fast'
  interactive?: boolean
  clients?: ClientLogo[]
}

const { speed = 'normal', interactive = true, clients } = Astro.props

