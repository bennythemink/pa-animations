---
interface Props {
  size?: number
  desktopSize?: number
}
const { size = 24, desktopSize = 32 } = Astro.props
---

<span id="equal-sign" class="sign inline-flex items-center justify-center align-middle leading-none mb-2">
  <svg
    width="276"
    height="276"
    viewBox="0 0 276 276"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full"
  >
    <path
      d="M275.999 0V276H0V0H275.999ZM68.9648 160.634V180.507H205.824V160.634H68.9648ZM68.9648 102.187V122.059H205.824V102.187H68.9648Z"
      fill="var(--accent-bgc)"></path>
  </svg>
</span>

<style define:vars={{ size, desktopSize }}>
  .sign {
    width: calc(var(--size) * 1px);
    height: calc(var(--size) * 1px);
  }
  @media (min-width: 1024px) {
    .sign {
      width: calc(var(--desktopSize) * 1px);
      height: calc(var(--desktopSize) * 1px);
    }
  }
</style>
