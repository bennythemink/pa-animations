---
interface Props {
  size?: number
  desktopSize?: number
}
const { size = 24, desktopSize = 32 } = Astro.props
---

<span class="sign inline-flex items-center justify-center align-middle leading-none mb-2">
  <svg
    width="276"
    height="276"
    viewBox="0 0 276 276"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full"
  >
    <path
      d="M275.999 0V276H0V0H275.999ZM127.119 53.6123V124.397H60.749V147.428H127.119V218.212H152.987V147.428H219.358V124.397H152.987V53.6123H127.119Z"
      fill="var(--accent-bgc)"></path>
  </svg>
</span>

<style define:vars={{ size, desktopSize }}>
  .sign {
    width: calc(var(--size) * 1px);
    height: calc(var(--size) * 1px);
  }
  @media (min-width: 1024px) {
    .sign {
      width: calc(var(--desktopSize) * 1px);
      height: calc(var(--desktopSize) * 1px);
    }
  }
</style>
