const logoData = clients ?? defaultClients
---

<div
  class="client-logos-marquee overflow-hidden relative my-6 lg:my-12 h-8 select-none"
  data-speed={speed}
  data-interactive={interactive ? 'true' : 'false'}
>
  <div class="marquee-track flex items-center" aria-label="Client logos">
    {
      logoData.map((client, i) => (
        <button
          type="button"
          class="marquee-item group shrink-0 px-4 lg:px-6 cursor-pointer appearance-none bg-transparent border-0 "
          data-links={JSON.stringify(client.links || [])}
          data-name={client.name}
          data-industry={JSON.stringify(
            Array.isArray(client.industry) ? client.industry : client.industry ? [client.industry] : []
          )}
          data-services={JSON.stringify(client.services || [])}
          data-description={client.description || ''}
          aria-label={client.name}
        >
          <img
            src={client.src}
            alt={client.name}
            class="h-5 lg:h-7 w-auto max-w-none object-contain pointer-events-none grayscale transition duration-300 ease-in-out group-hover:grayscale-0"
            loading="eager"
            decoding="async"
          />
        </button>
      ))
    }
  </div>

  <!-- Popup -->
  <div
    class="logo-popup fixed z-50 hidden px-6 py-5 shadow-lg max-w-xs pointer-events-auto"
    role="dialog"
    aria-hidden="true"
  >
    <p class="popup-name font-sans text-lg font-medium text-white mb-3"></p>
    <div class="popup-details grid gap-y-2 font-sans text-lg text-white" style="grid-template-columns: auto 1fr;">
      <span class="text-white/50">Sector</span>
      <span class="popup-industry-value flex flex-wrap items-center gap-2"></span>
      <span class="text-white/50">Services</span>
      <span class="popup-services-row flex flex-wrap items-center gap-2"></span>
      <span class="text-white/50">Overview</span>
      <span class="popup-description text-white/90 leading-snug"></span>
      <span class="popup-case-studies-row contents hidden"
        ><span class="text-white/50">Case studies</span>
        <span class="popup-links flex font-sans text-lg flex-wrap gap-x-4 gap-y-1"></span></span
      >
    </div>
  </div>
</div>

<style>
  .client-logos-marquee {
    --marquee-gap: 0px;
  }

  .marquee-track {
    gap: var(--marquee-gap);
    will-change: transform;
  }

  .marquee-item:focus-visible {
    outline: 2px solid var(--accent-bgc, #63a3d2);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .logo-popup {
    border-radius: 0;
  }

  .popup-details {
    column-gap: 12px;
  }

  .popup-services-row .svc {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 3px;
    padding: 2px 8px;
  }
</style>

<script>
  const SPEEDS: Record<string, number> = {
    slow: 0.3,
    normal: 0.6,
    fast: 1.2
  }

  interface MarqueeInstance {
    raf: number
    resizeHandler: () => void
    clickHandler: (e: Event) => void
    outsideClickHandler: (e: Event) => void
    escHandler: (e: KeyboardEvent) => void
  }

  let instances: MarqueeInstance[] = []

  function initMarquee(container: HTMLElement): MarqueeInstance {
    const track = container.querySelector<HTMLElement>('.marquee-track')!
    const popup = container.querySelector<HTMLElement>('.logo-popup')!
    const speed = SPEEDS[container.dataset.speed || 'normal'] || SPEEDS.normal
    const interactive = container.dataset.interactive === 'true'

    const items = Array.from(track.querySelectorAll<HTMLElement>('.marquee-item'))

    // Wrap originals in a measurable container so we get exact set width
    const setWrapper = document.createElement('div')
    setWrapper.style.display = 'flex'
    setWrapper.style.alignItems = 'center'
    setWrapper.style.flexShrink = '0'
    items.forEach((item) => setWrapper.appendChild(item))
    track.prepend(setWrapper)

    // Wait for all images inside the set to load before measuring
    const imgs = Array.from(setWrapper.querySelectorAll<HTMLImageElement>('img'))
    const imgLoaded = imgs.map((img) =>
      img.complete
        ? Promise.resolve()
        : new Promise<void>((res) => {
            img.onload = () => res()
            img.onerror = () => res()
          })
    )

    let x = 0
    let raf = 0
    let paused = false
    let setWidth = 0

    function tick() {
      if (!paused && setWidth > 0) {
        x -= speed
        if (Math.abs(x) >= setWidth) {
          x += setWidth
        }
        track.style.transform = `translate3d(${x}px, 0, 0)`
      }
      raf = requestAnimationFrame(tick)
    }

    function buildClones() {
      // Remove any existing clones
      track.querySelectorAll<HTMLElement>('.marquee-clone').forEach((el) => el.remove())

      setWidth = setWrapper.offsetWidth
      if (setWidth === 0) return

      const clonesNeeded = Math.ceil((window.innerWidth * 2) / setWidth) + 1
      for (let c = 0; c < clonesNeeded; c++) {
        const clone = setWrapper.cloneNode(true) as HTMLElement
        clone.classList.add('marquee-clone')
        clone.setAttribute('aria-hidden', 'true')
        track.appendChild(clone)
      }
    }

    Promise.all(imgLoaded).then(() => {
      buildClones()
    })

    // Start animation immediately — it'll just wait until setWidth > 0
    raf = requestAnimationFrame(tick)

    let hideTimer: ReturnType<typeof setTimeout> | null = null

    function scheduleHide() {
      if (hideTimer) clearTimeout(hideTimer)
      hideTimer = setTimeout(() => {
        paused = false
        hidePopup()
      }, 100)
    }

    function cancelHide() {
      if (hideTimer) {
        clearTimeout(hideTimer)
        hideTimer = null
      }
    }

    // Pause on hover (marquee and popup)
    container.addEventListener('mouseenter', () => {
      cancelHide()
      paused = true
    })
    container.addEventListener('mouseleave', () => {
      scheduleHide()
    })
    popup.addEventListener('mouseenter', () => {
      cancelHide()
      paused = true
    })
    popup.addEventListener('mouseleave', () => {
      scheduleHide()
    })

    // Show popup on hover over logo
    container.addEventListener('mouseover', (e) => {
      if (!interactive) return
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.marquee-item')
      if (!btn) return
      cancelHide()
      paused = true
      showPopup(btn)
    })

    // Popup logic
    function showPopup(btn: HTMLElement) {
      // Reset all logos to grayscale, then reveal tapped logo (originals + clones)
      track.querySelectorAll<HTMLImageElement>('.marquee-item img').forEach((img) => img.classList.add('grayscale'))
      track.querySelectorAll<HTMLElement>('.marquee-item').forEach((el) => {
        if (el.dataset.name === btn.dataset.name) {
          el.querySelector('img')?.classList.remove('grayscale')
        }
      })

      const name = btn.dataset.name || ''
      const industries: string[] = JSON.parse(btn.dataset.industry || '[]')
      const services: string[] = JSON.parse(btn.dataset.services || '[]')
      const description = btn.dataset.description || ''

      popup.querySelector('.popup-name')!.textContent = name

      const industryValue = popup.querySelector('.popup-industry-value')!
      industryValue.textContent = ''
      industries.forEach((ind) => {
        const span = document.createElement('span')
        span.className = 'svc'
        span.textContent = ind
        industryValue.appendChild(span)
      })

      const servicesRow = popup.querySelector('.popup-services-row')!
      // Remove old service spans (keep the label)
      servicesRow.querySelectorAll('.svc').forEach((el) => el.remove())
      services.forEach((s) => {
        const span = document.createElement('span')
        span.className = 'svc'
        span.textContent = s
        servicesRow.appendChild(span)
      })

      popup.querySelector('.popup-description')!.textContent = description

      // Show/hide case study links
      const caseStudiesRow = popup.querySelector<HTMLElement>('.popup-case-studies-row')!
      const linksContainer = popup.querySelector<HTMLElement>('.popup-links')!
      linksContainer.innerHTML = ''
      const links: { url: string; title?: string }[] = JSON.parse(btn.dataset.links || '[]')
      if (links.length > 0) {
        links.forEach((link) => {
          const a = document.createElement('a')
          a.href = link.url
          a.textContent = link.title || 'See more'
          a.className = ' text-white underline'
          linksContainer.appendChild(a)
        })
        caseStudiesRow.classList.remove('hidden')
      } else {
        caseStudiesRow.classList.add('hidden')
      }

      // Use accent colour
      const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent-bgc').trim()
      popup.style.backgroundColor = accent || '#63a3d2'

      // Position near clicked item
      const rect = btn.getBoundingClientRect()
      popup.classList.remove('hidden')
      popup.setAttribute('aria-hidden', 'false')

      const popupRect = popup.getBoundingClientRect()
      let left = rect.left + rect.width / 2 - popupRect.width / 2
      let top = rect.top - popupRect.height - 10

      // Keep within viewport
      if (left < 8) left = 8
      if (left + popupRect.width > window.innerWidth - 8) left = window.innerWidth - 8 - popupRect.width
      if (top < 8) {
        top = rect.bottom + 10
      }

      popup.style.left = `${left}px`
      popup.style.top = `${top}px`
    }

    function hidePopup() {
      track.querySelectorAll<HTMLImageElement>('.marquee-item img').forEach((img) => img.classList.add('grayscale'))
      popup.classList.add('hidden')
      popup.setAttribute('aria-hidden', 'true')
    }

    function clickHandler(e: Event) {
      if (!interactive) return
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.marquee-item')
      if (!btn) return

      // Toggle popup on click/tap (primarily for mobile)
      if (!popup.classList.contains('hidden')) {
        const currentName = popup.querySelector('.popup-name')!.textContent
        if (currentName === btn.dataset.name) {
          hidePopup()
          paused = false
          return
        }
      }
      paused = true
      showPopup(btn)
    }

    function outsideClickHandler(e: Event) {
      if (
        !popup.classList.contains('hidden') &&
        !popup.contains(e.target as Node) &&
        !(e.target as HTMLElement).closest('.marquee-item')
      ) {
        hidePopup()
      }
    }

    function escHandler(e: KeyboardEvent) {
      if (e.key === 'Escape') hidePopup()
    }

    container.addEventListener('click', clickHandler)
    document.addEventListener('click', outsideClickHandler)
    document.addEventListener('keydown', escHandler)

    function resizeHandler() {
      hidePopup()
    }

    window.addEventListener('resize', resizeHandler)

    return { raf, resizeHandler, clickHandler, outsideClickHandler, escHandler }
  }

  function init() {
    // Cleanup previous instances
    instances.forEach(({ raf, resizeHandler, outsideClickHandler, escHandler }) => {
      cancelAnimationFrame(raf)
      window.removeEventListener('resize', resizeHandler)
      document.removeEventListener('click', outsideClickHandler)
      document.removeEventListener('keydown', escHandler)
    })
    instances = []

    document.querySelectorAll<HTMLElement>('.client-logos-marquee').forEach((el) => {
      instances.push(initMarquee(el))
    })
  }

  requestAnimationFrame(() => init())

  document.addEventListener('astro:page-load', () => requestAnimationFrame(() => init()))
  document.addEventListener('astro:before-swap', () => {
    instances.forEach(({ raf, resizeHandler, outsideClickHandler, escHandler }) => {
      cancelAnimationFrame(raf)
      window.removeEventListener('resize', resizeHandler)
      document.removeEventListener('click', outsideClickHandler)
      document.removeEventListener('keydown', escHandler)
    })
    instances = []
  })
</script>
