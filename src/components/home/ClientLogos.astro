---
interface CaseStudyLink {
  url: string
  title?: string
}

interface ClientLogo {
  src: string
  name: string
  industry?: string | string[]
  services?: string[]
  description?: string
  links?: CaseStudyLink[]
}

interface Props {
  speed?: 'slow' | 'normal' | 'fast'
  interactive?: boolean
  clients?: ClientLogo[]
}

