---
interface Props {
  position?: 'sticky' | 'fixed'
}

const { position = 'sticky' } = Astro.props

const serviceLinks = [
  { label: 'Discovery + direction', href: '/services/discovery' },
  { label: 'Design', href: '/services/design' },
  { label: 'Development', href: '/services/development' },
  { label: 'Consulting', href: '/services/consulting' },
  { label: 'AI', href: '/services/ai' }
]

const navLinks = [
  { label: 'Services', href: '/services', hasDropdown: true },
  { label: 'Pixel Assist', href: '/pixel-assist' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' }
]
---

{/* ── Sticky header ── */}
<header class={`${position === 'fixed' ? 'fixed left-0 right-0' : 'sticky'} top-0 z-40 pt-5`}>
  <div class="grid grid-cols-12 gap-5 px-5 max-w-360 mx-auto w-full">
    {/* div-A: spans full grid, flex space-between for logo + nav */}
    <div class="col-start-1 col-span-full flex items-start justify-between">
      {/* Logo: P + A stacked, linked to homepage */}
      <a href="/" class="flex flex-col" aria-label="Pixel Agency homepage">
        <img src="/Letters/P.svg" alt="" aria-hidden="true" width="276" height="276" class="lg:w-12 w-6" />
        <img
          src="/Letters/A.svg"
          alt=""
          aria-hidden="true"
          width="276"
          height="276"
          class="lg:w-12 w-6 mt-0.5 lg:mt-1"
        />
      </a>

      {/* div-B: wraps desktop nav links */}
      <div class="hidden lg:block">
        <nav
          class="flex items-start gap-6 font-sans font-normal p-2"
          style="background-color: rgb(255 255 255 / 33%);"
          aria-label="Main navigation"
        >
          {
            navLinks.map((link) =>
              link.hasDropdown ? (
                <div class="relative" id="services-dropdown-wrapper">
                  <a
                    href={link.href}
                    id="services-dropdown-btn"
                    class="nav-link underline underline-offset-2 hover:no-underline transition-all flex items-center gap-1"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls="services-dropdown"
                  >
                    {link.label}
                  </a>
                  <ul
                    id="services-dropdown"
                    role="menu"
                    hidden
                    class="absolute top-full left-0 flex flex-col pt-3 pb-2 font-sans font-normal whitespace-nowrap"
                    style="background-color: rgb(255 255 255 / 95%); backdrop-filter: blur(4px);"
                  >
                    {serviceLinks.map((s) => (
                      <li role="none">
                        <a
                          href={s.href}
                          role="menuitem"
                          class="sub-link block px-4 py-1.5 hover:underline underline-offset-2 transition-colors"
                        >
                          {s.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ) : (
                <a href={link.href} class="nav-link underline underline-offset-2 hover:no-underline transition-all">
                  {link.label}
                </a>
              )
            )
          }
        </nav>
      </div>

      {/* Mobile menu trigger — hidden on desktop */}
      <button
        id="menu-open"
        class="lg:hidden font-sans font-normal p-1.5 hover:cursor-pointer"
        style="background-color: rgb(255 255 255 / 33%);"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menu
      </button>
    </div>
  </div>
</header>

{/* ── Mobile full-screen overlay ── */}
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Site navigation"
  aria-modal="true"
  hidden
  class="fixed inset-0 z-50 flex flex-col px-5 pt-5 pb-10"
  style="background-color: var(--accent-bgc);"
>
  {/* Overlay header row: logo + close button */}
  <div class="flex items-start justify-between shrink-0">
    <a href="/" class="flex flex-col" aria-label="Pixel Agency homepage">
      <img src="/Letters/P.svg" alt="" aria-hidden="true" width="276" height="276" class="w-6" />
      <img src="/Letters/A.svg" alt="" aria-hidden="true" width="276" height="276" class="w-6 mt-0.5" />
    </a>
    <button id="menu-close" class="font-sans font-normal p-1.5 hover:cursor-pointer" aria-label="Close navigation menu">
      Close
    </button>
  </div>

  {/* Nav links — centred vertically in remaining space */}
  <nav class="flex flex-col justify-center flex-1 gap-4" aria-label="Main navigation">
    {
      navLinks.map((link) => (
        <div>
          <a
            href={link.href}
            class="font-sans font-normal text-black"
            style="font-size: clamp(2.5rem, 12vw, 5rem); line-height: 0.85; letter-spacing: -0.03em;"
          >
            {link.label}
          </a>
          {link.hasDropdown && (
            <ul class="flex flex-col gap-1 mt-2 ml-6">
              {serviceLinks.map((s) => (
                <li>
                  <a
                    href={s.href}
                    class="sub-link font-sans font-normal text-black/70 transition-colors"
                    style="font-size: clamp(1rem, 4vw, 1.5rem); line-height: 1.2;"
                  >
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))
    }
  </nav>
</div>

<script>
  import { gsap } from 'gsap'

  const overlay = document.getElementById('mobile-menu')!
  const openBtn = document.getElementById('menu-open')!
  const closeBtn = document.getElementById('menu-close')!
  const navItems = overlay.querySelectorAll('nav a')

  function openMenu() {
    overlay.hidden = false
    document.body.style.overflow = 'hidden'
    openBtn.setAttribute('aria-expanded', 'true')

    gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' })
    gsap.fromTo(
      navItems,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out', stagger: 0.07, delay: 0.1 }
    )
  }

  function closeMenu() {
    openBtn.setAttribute('aria-expanded', 'false')
    gsap.to(overlay, {
      opacity: 0,
      duration: 0.25,
      ease: 'power2.in',
      onComplete: () => {
        overlay.hidden = true
        document.body.style.overflow = ''
      }
    })
  }

  // ── Desktop services dropdown ──────────────────────────
  const dropdownBtn = document.getElementById('services-dropdown-btn') as HTMLAnchorElement | null
  const dropdown = document.getElementById('services-dropdown') as HTMLUListElement | null
  const dropdownWrapper = document.getElementById('services-dropdown-wrapper') as HTMLElement | null

  if (dropdownBtn && dropdown && dropdownWrapper) {
    let closeTimer: ReturnType<typeof setTimeout> | null = null

    function openDropdown() {
      if (closeTimer) {
        clearTimeout(closeTimer)
        closeTimer = null
      }
      dropdown!.hidden = false
      dropdownBtn!.setAttribute('aria-expanded', 'true')
    }
    function closeDropdown() {
      closeTimer = setTimeout(() => {
        dropdown!.hidden = true
        dropdownBtn!.setAttribute('aria-expanded', 'false')
      }, 150)
    }

    dropdownWrapper.addEventListener('mouseenter', openDropdown)
    dropdownWrapper.addEventListener('mouseleave', closeDropdown)

    // Close when a dropdown link is clicked
    dropdown.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        if (closeTimer) {
          clearTimeout(closeTimer)
          closeTimer = null
        }
        dropdown!.hidden = true
        dropdownBtn!.setAttribute('aria-expanded', 'false')
      })
    )

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!dropdownWrapper.contains(e.target as Node)) closeDropdown()
    })
  }

  // ── Mobile menu ──────────────────────────────────────────
  openBtn.addEventListener('click', openMenu)
  closeBtn.addEventListener('click', closeMenu)

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.hidden) closeMenu()
  })

  // Close when a nav link is followed (closes overlay before navigation)
  navItems.forEach((link) => {
    link.addEventListener('click', () => closeMenu())
  })
</script>

<style>
  .nav-link {
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--accent-bgc);
  }
  .sub-link {
    transition: color 0.2s ease;
  }
  .sub-link:hover {
    color: var(--accent-bgc);
  }
</style>
