---
import { siteConfig } from '@config/site'

/** Name-to-hex lookup matching --color-pixel-* tokens in global.css */
const PIXEL_COLORS: Record<string, string> = {
  'pixel-red': '#e9504c',
  'pixel-dark-red': '#8c291c',
  'pixel-blue': '#63a3d2',
  'pixel-dark-blue': '#386b92',
  'pixel-light-blue': '#dfe9fd',
  'pixel-green': '#479f82',
  'pixel-dark-green': '#2a6351',
  'pixel-orange': '#f09339',
  'pixel-light-orange': '#f4b865',
  'pixel-pink': '#e38093',
  'pixel-light-pink': '#ecc9d9',
  'pixel-yellow': '#f5c844',
  'pixel-light-yellow': '#fcebad',
  'pixel-cream': '#cab38f',
  'pixel-light-cream': '#eae7e4',
  'pixel-off-cream': '#ebe7e4',
  'pixel-off-white': '#f5f3f2',
  'pixel-brown': '#c9b58d'
}

/** Resolve a pixel-* name or pass through a raw hex value */
function resolveColour(value: string): string {
  return PIXEL_COLORS[value] ?? value
}

interface LogoColourPair {
  p: string
  a: string
  weight: number
}

const logoColourPairs: LogoColourPair[] = [
  { p: 'pixel-blue', a: 'pixel-red', weight: 3 },
  { p: 'pixel-red', a: 'pixel-blue', weight: 3 },
  { p: 'pixel-pink', a: 'pixel-green', weight: 3 },
  { p: 'pixel-blue', a: 'pixel-pink', weight: 3 },
  { p: 'pixel-green', a: 'pixel-pink', weight: 2 },
  { p: 'pixel-green', a: 'pixel-orange', weight: 2 },
  { p: 'pixel-red', a: 'pixel-green', weight: 2 },
  { p: 'pixel-pink', a: 'pixel-blue', weight: 2 },
  { p: 'pixel-orange', a: 'pixel-green', weight: 1 },
  { p: 'pixel-orange', a: 'pixel-brown', weight: 1 }
]

const resolvedPairs = logoColourPairs.map(({ p, a, weight }) => ({
  p: resolveColour(p),
  a: resolveColour(a),
  weight
}))

interface Props {
  position?: 'sticky' | 'fixed'
  /** Override the random logo colour pair. Accepts pixel-* names or hex values. */
  logoColors?: { p: string; a: string }
}

const { position = 'sticky', logoColors } = Astro.props

const resolvedOverride = logoColors ? { p: resolveColour(logoColors.p), a: resolveColour(logoColors.a) } : undefined

const serviceLinks = [
  { label: 'Discovery + direction', href: '/services/discovery' },
  { label: 'Design', href: '/services/design' },
  { label: 'Development', href: '/services/development' },
  { label: 'AI', href: '/services/ai' },
  { label: 'Consulting', href: '/services/consulting' }
]

const navLinks = [
  { label: 'Services', href: '/services', hasDropdown: true },
  { label: 'Pixel Assist', href: '/pixel-assist' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' }
]
---

{/* ── Sticky header ── */}
<header class={`${position === 'fixed' ? 'fixed left-0 right-0' : 'sticky'} top-0 z-40 pt-5`}>
  <div class="grid grid-cols-12 gap-5 px-5 max-w-360 mx-auto w-full">
    {/* div-A: spans full grid, flex space-between for logo + nav */}
    <div class="col-start-1 col-span-full flex items-start justify-between">
      {/* Logo: P + A stacked, linked to homepage */}
      <a
        href="/"
        class="flex flex-col"
        aria-label="Pixel Agency homepage"
        id="logo-link"
        data-logo-override={resolvedOverride ? JSON.stringify(resolvedOverride) : undefined}
      >
        <svg
          id="logo-p"
          width="276"
          height="276"
          viewBox="0 0 276 276"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 lg:w-[52px] lg:h-[52px]"
        >
          <path
            d="M275.998 185.158L219.987 185.167C185.103 188.816 157.911 218.312 157.91 254.162V276H0V80.3775H76.0742C91.1097 80.3779 101.728 102.462 101.728 117.498C101.728 145.934 124.78 168.987 153.217 168.987C181.654 168.987 204.707 145.934 204.707 117.498C204.707 89.0608 181.654 66.0081 153.217 66.0081H0V0H276L275.998 185.158Z"
            fill="var(--logo-p-color, #FD3F44)"></path>
        </svg>
        <svg
          id="logo-a"
          width="276"
          height="276"
          viewBox="0 0 276 276"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 lg:w-[52px] lg:h-[52px] mt-0.5 lg:mt-1"
        >
          <path
            d="M276 275.998L174.35 276V196.297C174.349 192.329 171.133 189.114 167.166 189.113C163.197 189.113 159.98 192.329 159.979 196.297V276L0 275.998V138.001H167.166C195.607 138 218.664 114.943 218.664 86.5014C218.663 58.0601 195.607 35.0039 167.166 35.0035C138.724 35.0035 115.666 58.0599 115.666 86.5014C115.666 101.539 105.046 123.628 90.0082 123.629H0V0H276V275.998Z"
            fill="var(--logo-a-color, #4BA5D7)"></path>
        </svg>
      </a>

      {/* div-B: wraps desktop nav links */}
      <div class="hidden lg:block">
        <nav
          class="flex items-start gap-6 font-sans font-normal p-2"
          style="background-color: rgb(255 255 255 / 95%);"
          aria-label="Main navigation"
        >
          {
            navLinks.map((link) =>
              link.hasDropdown ? (
                <div class="relative" id="services-dropdown-wrapper">
                  <a
                    href={link.href}
                    id="services-dropdown-btn"
                    class="nav-link underline underline-offset-2 hover:no-underline transition-all flex items-center gap-1"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls="services-dropdown"
                  >
                    {link.label}
                  </a>
                  <ul
                    id="services-dropdown"
                    role="menu"
                    hidden
                    class="absolute top-full left-0 flex flex-col pt-3 pb-2 font-sans font-normal whitespace-nowrap"
                    style="background-color: rgb(255 255 255 / 95%); backdrop-filter: blur(4px);"
                  >
                    {serviceLinks.map((s) => (
                      <li role="none">
                        <a
                          href={s.href}
                          role="menuitem"
                          class="sub-link block px-4 py-1.5 hover:underline underline-offset-2 transition-colors"
                        >
                          {s.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ) : (
                <a href={link.href} class="nav-link underline underline-offset-2 hover:no-underline transition-all">
                  {link.label}
                </a>
              )
            )
          }
        </nav>
      </div>

      {/* Mobile menu trigger — hidden on desktop */}
      <button
        id="menu-open"
        class="lg:hidden font-sans font-normal p-1.5 hover:cursor-pointer"
        style="background-color: rgb(255 255 255 / 95%);"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menu
      </button>
    </div>
  </div>
</header>

{/* ── Mobile full-screen overlay ── */}
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Site navigation"
  aria-modal="true"
  hidden
  class="fixed inset-0 z-50 flex flex-col px-5 pt-5 pb-10"
  style="background-color: var(--accent-bgc);"
>
  {/* Overlay header row: logo + close button */}
  <div class="flex items-start justify-between shrink-0">
    <a href="/" class="flex flex-col font-sans text-2xl font-normal" aria-label="Pixel Agency homepage"
      >Pixel Agency
    </a>
    <button
      id="menu-close"
      class="font-sans font-normal p-1.5 hover:cursor-pointer underline underline-offset-2 text-black/50"
      aria-label="Close navigation menu"
    >
      Close
    </button>
  </div>

  {/* Nav links — centred vertically in remaining space */}
  <nav class="flex flex-col justify-center flex-1 gap-4" aria-label="Main navigation">
    {
      navLinks.map((link) => (
        <div>
          <a
            href={link.href}
            class="font-sans font-normal text-black text-3xl hover:underline underline-offset-2"
            style="line-height: 0.85; letter-spacing: -0.03em;"
          >
            {link.label}
          </a>
          {link.hasDropdown && (
            <ul class="flex flex-col gap-1 mt-2 ml-8">
              {serviceLinks.map((s) => (
                <li>
                  <a
                    href={s.href}
                    class="font-sans font-normal text-xl text-black/70 hover:underline underline-offset-2 "
                    style="line-height: 1.2;"
                  >
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))
    }
  </nav>

  {/* Footer info */}
  <div class="shrink-0 flex flex-col gap-6 font-sans font-normal text-black text-base">
    <div class="flex flex-col gap-1">
      <p>
        <span class="font-medium">Call</span>
        <a href={`tel:${siteConfig.phone}`} class="hover:underline underline-offset-2">{siteConfig.phone}</a>
      </p>
      <p>
        <span class="font-medium">Email</span>
        <a href={`mailto:${siteConfig.email}`} class="hover:underline underline-offset-2">{siteConfig.email}</a>
      </p>
    </div>
    <div class="flex flex-col gap-0.5">
      <p class="font-medium">Melbourne, Australia</p>
      <p>AEDT</p>
    </div>
    <p class="text-sm">&copy; {new Date().getFullYear()} Pixel Agency. All Rights Reserved.</p>
  </div>
</div>

{/* ── Logo colour picker — runs synchronously to avoid flash ── */}
<script define:vars={{ pairs: resolvedPairs }} is:inline>
  function pickLogoColors() {
    var logo = document.getElementById('logo-link')
    if (!logo) return

    var override = logo.dataset.logoOverride
    var pColor, aColor

    if (override) {
      var parsed = JSON.parse(override)
      pColor = parsed.p
      aColor = parsed.a
    } else {
      var totalWeight = 0
      for (var i = 0; i < pairs.length; i++) totalWeight += pairs[i].weight
      var r = Math.random() * totalWeight
      var cumulative = 0
      var picked = pairs[0]
      for (var i = 0; i < pairs.length; i++) {
        cumulative += pairs[i].weight
        if (r < cumulative) {
          picked = pairs[i]
          break
        }
      }
      pColor = picked.p
      aColor = picked.a
    }

    document.documentElement.style.setProperty('--logo-p-color', pColor)
    document.documentElement.style.setProperty('--logo-a-color', aColor)
  }
  pickLogoColors()
  document.addEventListener('astro:after-swap', pickLogoColors)
</script>

<script>
  import { gsap } from 'gsap'

  const overlay = document.getElementById('mobile-menu')!
  const openBtn = document.getElementById('menu-open')!
  const closeBtn = document.getElementById('menu-close')!
  const navItems = overlay.querySelectorAll('nav a')

  function openMenu() {
    overlay.hidden = false
    document.body.style.overflow = 'hidden'
    openBtn.setAttribute('aria-expanded', 'true')

    gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' })
  }

  function closeMenu() {
    openBtn.setAttribute('aria-expanded', 'false')
    gsap.to(overlay, {
      opacity: 0,
      duration: 0.25,
      ease: 'power2.in',
      onComplete: () => {
        overlay.hidden = true
        document.body.style.overflow = ''
      }
    })
  }

  // ── Desktop services dropdown ──────────────────────────
  const dropdownBtn = document.getElementById('services-dropdown-btn') as HTMLAnchorElement | null
  const dropdown = document.getElementById('services-dropdown') as HTMLUListElement | null
  const dropdownWrapper = document.getElementById('services-dropdown-wrapper') as HTMLElement | null

  if (dropdownBtn && dropdown && dropdownWrapper) {
    let closeTimer: ReturnType<typeof setTimeout> | null = null

    function openDropdown() {
      if (closeTimer) {
        clearTimeout(closeTimer)
        closeTimer = null
      }
      dropdown!.hidden = false
      dropdownBtn!.setAttribute('aria-expanded', 'true')
    }
    function closeDropdown() {
      closeTimer = setTimeout(() => {
        dropdown!.hidden = true
        dropdownBtn!.setAttribute('aria-expanded', 'false')
      }, 150)
    }

    dropdownWrapper.addEventListener('mouseenter', openDropdown)
    dropdownWrapper.addEventListener('mouseleave', closeDropdown)

    // Close when a dropdown link is clicked
    dropdown.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        if (closeTimer) {
          clearTimeout(closeTimer)
          closeTimer = null
        }
        dropdown!.hidden = true
        dropdownBtn!.setAttribute('aria-expanded', 'false')
      })
    )

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!dropdownWrapper.contains(e.target as Node)) closeDropdown()
    })
  }

  // ── Mobile menu ──────────────────────────────────────────
  openBtn.addEventListener('click', openMenu)
  closeBtn.addEventListener('click', closeMenu)

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.hidden) closeMenu()
  })

  // Close when a nav link is followed (closes overlay before navigation)
  navItems.forEach((link) => {
    link.addEventListener('click', () => closeMenu())
  })
</script>

<style>
  .nav-link {
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--accent-bgc);
  }
  .sub-link {
    transition: color 0.2s ease;
  }
  .sub-link:hover {
    color: var(--accent-bgc);
  }
</style>
