---
import Grid from '@components/Grid.astro'

interface Props {
  title: string
  tagline: string
  paragraphs: string[]
  /** When true, the tagline/body column drops to the next row on desktop */
  stack?: boolean
}

const { title, tagline, paragraphs, stack = false } = Astro.props
---

<section class="pt-10 pb-12 lg:pt-16 lg:pb-20">
  <Grid>
    <!-- <div class={`col-span-full lg:col-start-2 lg:col-span-5 ${stack ? 'lg:col-span-11' : ''}`}> -->
    <div class={`col-span-full lg:col-start-2 lg:col-span-full`}>
      <h1 class="text-7xl lg:text-[140px] p-0">{title}</h1>
    </div>
    <div
      class={`col-span-full flex flex-col gap-4 mt-4 ${
        stack ? 'lg:col-start-7 lg:col-span-5 lg:row-start-2 lg:mt-6' : 'lg:col-start-7 lg:col-span-5 lg:mt-6'
      }`}
    >
      <h2 class="text-lg lg:text-3xl leading-[1.04]">{tagline}</h2>
      <div class="flex flex-col gap-3 mt-2">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </Grid>
</section>
