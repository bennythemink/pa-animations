---
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'

interface Card {
  title: string
  description: string
  /** Hex colour OR a pixel colour var name e.g. 'pixel-blue', 'pixel-light-pink' */
  colour?: string
}

interface SectionTitle {
  text: string
  /** Hex colour OR a pixel colour var name e.g. 'pixel-blue', 'pixel-light-pink' */
  colour?: string
}

interface Props {
  title?: SectionTitle
  cards: Card[]
  style?: 'default' | 'left-aligned'
}

const { title, cards, style = 'default' } = Astro.props

// Read --color-pixel-* values from global.css — single source of truth
const cssText = readFileSync(resolve(process.cwd(), 'src/styles/global.css'), 'utf-8')
const pixelColourMap: Record<string, string> = {}
for (const [, name, hex] of cssText.matchAll(/--color-(pixel-[a-z-]+):\s*(#[0-9a-fA-F]{3,8})/g)) {
  pixelColourMap[name] = hex
}
// Exclude colours that are too light to use as card backgrounds
const EXCLUDED_COLOURS = new Set(['#f5f3f2'])
const pixelColourValues = Object.values(pixelColourMap).filter((hex) => !EXCLUDED_COLOURS.has(hex))

// Resolve a colour string: var name → hex, hex passthrough, unknown → null
function resolveColour(raw: string): string | null {
  if (pixelColourMap[raw]) return pixelColourMap[raw]
  if (/^#[0-9a-fA-F]{3,8}$/.test(raw)) return raw
  return null
}

// Auto-placement: 1 card per row by default, randomly pairing two cards on a row.
// If a title is present, the first card pairs with it at row 1 col 7 and
// subsequent rows use the normal algorithm.
interface LayoutCard extends Card {
  colour: string
  colStart: number
  colSpan: number
  rowStart: number
  solo: boolean
}

const layoutCards: LayoutCard[] = []
let idx = 0
let rowNum = 1

if (title && cards.length > 0) {
  // Title occupies row 1 col 2; first card pairs with it at row 1 col 7
  layoutCards.push({
    ...cards[0],
    colour: '',
    colStart: 7,
    colSpan: 5,
    rowStart: 1,
    solo: false
  })
  idx = 1
  rowNum = 2
}

// Pre-decide which rows will be pairs using a ~30% chance, ensuring at least
// one pair when there are ≥4 remaining cards so the layout stays varied.
const remainingOnEntry = cards.length - idx
const pairRows = new Set<number>()
{
  let r = rowNum
  let i = idx
  while (i < cards.length) {
    const rem = cards.length - i
    if (rem >= 2 && Math.random() < 0.3) {
      pairRows.add(r)
      i += 2
    } else {
      i += 1
    }
    r++
  }
  // If no pairs were picked and there were enough cards, force one random pair row
  if (pairRows.size === 0 && remainingOnEntry >= 4) {
    // Pick a random row index that has ≥2 cards ahead of it
    let checkRow = rowNum
    let checkIdx = idx
    const eligible: number[] = []
    while (checkIdx < cards.length) {
      if (cards.length - checkIdx >= 2) eligible.push(checkRow)
      checkIdx += 1
      checkRow++
    }
    if (eligible.length > 0) {
      pairRows.add(eligible[Math.floor(Math.random() * eligible.length)])
    }
  }
}

while (idx < cards.length) {
  const remaining = cards.length - idx
  const makePair = remaining >= 2 && pairRows.has(rowNum)

  if (makePair) {
    layoutCards.push({
      ...cards[idx],
      colour: '',
      colStart: 2,
      colSpan: 5,
      rowStart: rowNum,
      solo: false
    })
    layoutCards.push({
      ...cards[idx + 1],
      colour: '',
      colStart: 7,
      colSpan: 5,
      rowStart: rowNum,
      solo: false
    })
    idx += 2
  } else {
    const colStart = rowNum % 2 === 1 ? 2 : 7
    layoutCards.push({
      ...cards[idx],
      colour: '',
      colStart,
      colSpan: 5,
      rowStart: rowNum,
      solo: true
    })
    idx += 1
  }
  rowNum++
}

// Resolve title colour if provided
const titleColour = title?.colour ? (resolveColour(title.colour) ?? 'inherit') : 'inherit'

const uid = Math.random().toString(36).slice(2, 8)
---

<section
  id="approach-points"
  data-approach-section
  data-colour-pool={JSON.stringify(pixelColourValues)}
  class="py-12 lg:py-20"
>
  <div class="grid grid-cols-12 px-5 max-w-360 mx-auto w-full">
    {
      title && (
        <div class="title-cell col-span-full mb-8 lg:mb-0" style="--title-row: 1;">
          <h2 class="text-2xl lg:text-4xl font-sans font-light" style={`color: ${titleColour};`}>
            {title.text}
          </h2>
        </div>
      )
    }
    {
      layoutCards.map((card, i) => (
        <div
          id={`${uid}-card-${i}`}
          data-approach-card
          data-solo={card.solo ? 'true' : undefined}
          class="approach-card col-span-full grid grid-cols-1 lg:grid-cols-5 gap-x-[20px] p-[12px] lg:p-[30px] min-h-[200px]"
          style={`--col-start: ${card.colStart}; --col-span: ${card.colSpan}; --row-start: ${card.rowStart};`}
        >
          {style === 'left-aligned' ? (
            <>
              <p class="lg:col-span-5 font-sans text-4xl lg:text-5xl">{card.title}</p>
              <p class="lg:col-span-3 lg:row-start-2 mt-6 lg:mt-12">{card.description}</p>
            </>
          ) : (
            <>
              <p class="lg:col-start-1 lg:col-span-4 font-sans text-4xl lg:text-5xl">{card.title}</p>
              <p class="lg:col-start-3 lg:col-span-3 lg:row-start-2 text-right mt-6 lg:mt-12">{card.description}</p>
            </>
          )}
        </div>
      ))
    }
  </div>
</section>

<style>
  /* Hide cards before JS inits so they never flash visible */
  .approach-card {
    clip-path: inset(100% 0% 0% 0%);
  }

  @media (min-width: 1024px) {
    .approach-card {
      grid-column: var(--col-start) / span var(--col-span);
      grid-row: var(--row-start);
    }
    .title-cell {
      grid-column: 2 / span 5;
      grid-row: var(--title-row);
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const CLIP_DIRECTIONS = [
    'inset(0% 0% 100% 0%)',
    'inset(100% 0% 0% 0%)',
    'inset(0% 100% 0% 0%)',
    'inset(0% 0% 0% 100%)'
  ]

  type Instance = { ctx: gsap.Context; resizeHandler: () => void }
  let instances: Instance[] = []

  function equaliseHeights(cards: HTMLElement[]) {
    cards.forEach((c) => (c.style.height = ''))
    if (window.innerWidth >= 1024) {
      const maxH = Math.max(...cards.map((c) => c.offsetHeight))
      cards.forEach((c) => (c.style.height = `${maxH}px`))
    }
  }

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr]
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1))
      ;[a[i], a[j]] = [a[j], a[i]]
    }
    return a
  }

  function assignRandomColours(section: HTMLElement, cards: HTMLElement[]) {
    const pool: string[] = JSON.parse(section.dataset.colourPool || '[]')
    if (pool.length === 0) return
    const used = new Set<string>()
    cards.forEach((card) => {
      const available = pool.filter((c) => !used.has(c))
      const pick = available.length > 0 ? available : pool
      const colour = pick[Math.floor(Math.random() * pick.length)]
      used.add(colour)
      card.style.backgroundColor = colour
    })
  }

  function initSection(section: HTMLElement): Instance {
    const cards = Array.from(section.querySelectorAll<HTMLElement>('[data-approach-card]'))

    // Assign random background colours on each page load
    assignRandomColours(section, cards)

    // Randomise col-start for solo cards, guaranteeing at least one in each column
    const soloCards = cards.filter((c) => c.dataset.solo === 'true')
    if (soloCards.length > 0) {
      // Assign randomly first
      const starts = soloCards.map(() => (Math.random() < 0.5 ? '2' : '7'))
      // If all ended up the same column, flip one random card to the other
      const allSame = starts.every((s) => s === starts[0])
      if (allSame && soloCards.length > 1) {
        const flipIdx = Math.floor(Math.random() * soloCards.length)
        starts[flipIdx] = starts[0] === '2' ? '7' : '2'
      }
      soloCards.forEach((card, i) => card.style.setProperty('--col-start', starts[i]))
    }

    equaliseHeights(cards)

    // Shuffle clip directions so each page load gets a different assignment
    const directions = shuffle(CLIP_DIRECTIONS)

    // Set clip-path immediately (before any ScrollTrigger measures positions)
    cards.forEach((card, i) => {
      card.style.clipPath = directions[i % directions.length]
    })

    const ctx = gsap.context(() => {
      cards.forEach((card, i) => {
        gsap.to(card, {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 0.9,
          ease: 'power2.out',
          scrollTrigger: { trigger: card, start: 'top 85%', once: true, invalidateOnRefresh: true }
        })
      })
    })

    const resizeHandler = () => equaliseHeights(cards)
    window.addEventListener('resize', resizeHandler)
    return { ctx, resizeHandler }
  }

  function init() {
    instances.forEach(({ ctx, resizeHandler }) => {
      ctx.revert()
      window.removeEventListener('resize', resizeHandler)
    })
    instances = []

    document.querySelectorAll<HTMLElement>('[data-approach-section]').forEach((section) => {
      instances.push(initSection(section))
    })

    ScrollTrigger.refresh()
  }

  requestAnimationFrame(() => init())

  document.addEventListener('astro:page-load', () => requestAnimationFrame(() => init()))
  document.addEventListener('astro:before-swap', () => {
    instances.forEach(({ ctx, resizeHandler }) => {
      ctx.revert()
      window.removeEventListener('resize', resizeHandler)
    })
    instances = []
  })
</script>
