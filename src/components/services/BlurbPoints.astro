---
import Grid from '@components/Grid.astro'

interface Props {
  id?: string
  title?: string
  labelColor?: string
  rightColumnTitle: string
  bulletPoints: string[]
}

const { id = 'who', title, labelColor = 'text-pixel-red', rightColumnTitle, bulletPoints } = Astro.props
---

<section id={id} class="py-16 lg:py-24">
  <Grid>
    <div class="col-span-12 lg:col-start-2 lg:col-span-4">
      <h2 class={`font-sans font-normal lg:text-4xl ${labelColor} mb-6 lg:mb-10`}>{title}</h2>
      <div class="lg:text-[24px]">
        <slot />
      </div>
    </div>

    <div class="col-span-12 lg:col-span-5 lg:col-start-8 mt-10 lg:mt-0">
      <p class="font-sans font-normal text-[20px] lg:text-[30px] tracking-[-0.04em] mb-6 lg:mb-10">
        {rightColumnTitle}
      </p>
      <ul class="flex flex-col gap-5 lg:gap-7">
        {
          bulletPoints.map((item) => (
            <li class="flex items-start gap-3 font-sans font-normal text-[20px] lg:text-2xl leading-[1.2] lg:leading-[1.28] tracking-[-0.04em]">
              <span
                class="shrink-0 w-[12px] h-[12px] mt-[5px] lg:mt-[10px]"
                style={`background-color: var(--color-${labelColor.replace('text-', '')})`}
              />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </Grid>
</section>
