---
import Grid from '@components/Grid.astro'

interface Props {
  forItems: string[]
  notForItems: string[]
  forTitle?: string
  notForTitle?: string
}

const {
  forItems,
  notForItems,
  forTitle = 'Who this is for',
  notForTitle = 'Who this is <span class="underline">not</span> for'
} = Astro.props
---

<section id="who" class="mb-6">
  <Grid>
    {/* Who this is for */}
    <div class="col-span-full lg:col-start-2 lg:col-span-5 p-8 bg-white">
      <div class="flex flex-col lg:grid lg:grid-cols-2 lg:gap-8 h-full">
        <h3 class="text-xl lg:text-3xl 2xl:text-4xl mb-6 lg:mb-0 font-light leading-none" set:html={forTitle} />
        <ul class="flex flex-col">
          {
            forItems.map((item, i) => (
              <li class={`${i < forItems.length - 1 ? 'border-b border-black/20' : ''} ${i === 0 ? 'pb-3' : 'py-3'}`}>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {/* Who this is not for */}
    <div
      class="col-span-full lg:col-start-7 lg:col-span-5 p-8 mt-5 lg:mt-0"
      style="background-color: var(--color-pixel-light-cream);"
    >
      <div class="flex flex-col lg:grid lg:grid-cols-2 lg:gap-8 h-full">
        <h3 class="text-xl lg:text-3xl 2xl:text-4xl mb-6 lg:mb-0 font-light leading-none" set:html={notForTitle} />
        <ul class="flex flex-col">
          {
            notForItems.map((item, i) => (
              <li
                class={`${i < notForItems.length - 1 ? 'border-b border-black/20' : ''} ${i === 0 ? 'pb-3' : 'py-3'}`}
              >
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Grid>
</section>
