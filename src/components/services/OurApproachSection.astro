---
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'
import Grid from '@components/Grid.astro'

interface Props {
  /** Optional label above the heading. Defaults to 'Our approach'. */
  label?: string
  /** Hex colour or pixel var name (e.g. 'pixel-poppy') for the label text. Defaults to pixel-poppy. */
  labelColour?: string
}

const { label = 'Our approach', labelColour = 'pixel-poppy' } = Astro.props

// Resolve colour — same pattern as ApproachPointsSection
const cssText = readFileSync(resolve(process.cwd(), 'src/styles/global.css'), 'utf-8')
const pixelColourMap: Record<string, string> = {}
for (const [, name, hex] of cssText.matchAll(/--color-(pixel-[a-z-]+):\s*(#[0-9a-fA-F]{3,8})/g)) {
  pixelColourMap[name] = hex
}
function resolveColour(raw: string): string {
  if (pixelColourMap[raw]) return pixelColourMap[raw]
  if (/^#[0-9a-fA-F]{3,8}$/.test(raw)) return raw
  return raw
}
const resolvedLabelColour = resolveColour(labelColour)
---

<section id="approach-section" class="pb-12 lg:pb-20">
  <Grid>
    <div class="col-span-full lg:col-start-2 lg:col-span-10 flex flex-col gap-5">
      <p class="font-sans font-normal text-lg lg:text-4xl" style={`color: ${resolvedLabelColour};`}>{label}</p>
      <h2 id="approach-text" class="text-3xl lg:text-7xl leading-none">
        <slot />
      </h2>
    </div>
  </Grid>
</section>
