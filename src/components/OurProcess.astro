<style>
  .process-rect {
    opacity: 0;
  }
  .process-rect[data-color='red'] {
    background-color: var(--color-pixel-red);
  }
  .process-rect[data-color='dark-red'] {
    background-color: var(--color-pixel-dark-red);
  }
  .process-rect[data-color='blue'] {
    background-color: var(--color-pixel-blue);
  }
  .process-rect[data-color='dark-blue'] {
    background-color: var(--color-pixel-dark-blue);
  }
  .process-rect[data-color='green'] {
    background-color: var(--color-pixel-green);
  }
  .process-rect[data-color='dark-green'] {
    background-color: var(--color-pixel-dark-green);
  }
  .process-rect[data-color='orange'] {
    background-color: var(--color-pixel-orange);
  }
  .process-rect[data-color='light-orange'] {
