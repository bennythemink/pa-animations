---
import Grid from '@components/Grid.astro'
import type { FlowFieldOptions } from '@scripts/flow-field.ts'
import { siteConfig } from '@config/site'

interface Props {
  flowFieldColor?: FlowFieldOptions['color']
}

const { flowFieldColor } = Astro.props
const year = new Date().getFullYear()
---

<footer class="bg-pixel-off-white">
  {/* ── Row 1: Content grid ────────────────────────────────── */}
  <div class="py-10">
    <Grid>
      {
        /* Copyright + Privacy links — single grid item keeps them adjacent on desktop.
           Mobile: order-3, privacy on top, copyright on bottom (flex-col-reverse).
           Desktop: col 2–4 row 1, copyright on top, privacy below (lg:flex-col). */
      }
      <div
        class="col-span-full order-3 flex flex-col-reverse gap-3 text-base sm:text-lg lg:col-start-2 lg:col-span-3 lg:row-start-1 lg:flex-col lg:self-start"
      >
        <p class="text-black/40 lg:text-black leading-none font-sans text-base">
          © {year} Pixel Agency. All Rights Reserved.
        </p>
        <ul class="flex flex-col font-sans text-base">
          <li>
            <a href="/privacy-policy" class="text-black/40 hover:text-black transition-colors">Privacy Policy</a>
          </li>
          <li>
            <a href="/terms-and-conditions" class="text-black/40 hover:text-black transition-colors"
              >Terms &amp; Conditions</a
            >
          </li>
          <li>
            <a href="/sitemap" class="text-black/40 hover:text-black transition-colors">Site Map</a>
          </li>
        </ul>
      </div>

      {/* Nav links — mobile: 1st row left (col-span-6); desktop: col 11–12 row 1 */}
      <div
        id="footer-nav-links"
        class="col-span-6 order-1 flex flex-col gap-1 text-base font-sans font-normal sm:text-lg lg:col-start-11 lg:col-span-2 lg:row-start-1 lg:order-1 lg:self-start"
      >
        <a href="/services" class="footer-nav-link hover:underline underline-offset-2">Services</a>
        <a href="/pixel-assist" class="footer-nav-link hover:underline underline-offset-2">Pixel Assist</a>
        <a href="/case-studies" class="footer-nav-link hover:underline underline-offset-2">Case Studies</a>
        <a href="/about" class="footer-nav-link hover:underline underline-offset-2">About</a>
        <a href="/contact" class="footer-nav-link hover:underline underline-offset-2">Contact</a>
      </div>

      {/* Melbourne/AEDT — mobile: 1st row right (col-span-6, text-right); desktop: col 2–4 row 3 */}
      <div
        class="col-span-6 order-1 text-right font-sans text-base lg:col-start-2 lg:col-span-3 lg:row-start-2 lg:order-3 lg:text-left"
      >
        <p class="font-semibold">Melbourne, Australia</p>
        <p class="text-black/60">AEDT</p>
      </div>

      {/* Contact block — mobile: 2nd row; desktop: col 5–7 row 1 */}
      <div
        class="col-span-full order-2 mt-[28px] flex flex-col gap-3 font-serif text-base sm:text-lg lg:col-start-5 lg:col-span-3 lg:row-start-1 lg:order-1 lg:self-start lg:mt-0"
      >
        <p class="leading-none font-serif text-2xl">
          We'd love to chat, here is<br />how you can reach us:
        </p>
        <ul class="flex flex-col gap-1">
          <li>
            <span class="font-semibold font-sans text-base">Email</span>{' '}
            <a href={`mailto:${siteConfig.email}`} class="hover:underline underline-offset-2 font-sans text-base"
              >{siteConfig.email}</a
            >
          </li>
          <li>
            <span class="font-semibold font-sans text-base">Call</span>{' '}
            <a
              href={`tel:${siteConfig.phone}`}
              class="hover:underline cursor-pointer underline-offset-2 font-sans text-base">{siteConfig.phone}</a
            >
          </li>
          <li><a href="#" class="hover:underline underline-offset-2 font-sans text-base">LinkedIn</a></li>
        </ul>
      </div>
    </Grid>
  </div>

  {/* ── Row 2: Pixel Agency display text ──────────────────── */}
  <a
    href="/"
    class="block text-center font-sans font-normal leading-none my-10 text-black no-underline"
    style="font-size: clamp(80px, 17vw, 246px);"
  >
    Pixel Agency
  </a>

  {/* ── Row 3: Flow field canvas ───────────────────────────── */}
  <div class="overflow-x-clip overflow-y-clip h-50 lg:h-100">
    <div class="-ml-[30px] w-[calc(100%+30px)] h-[calc(100%+30px)]">
      <canvas id="footer-flow" data-color={flowFieldColor || undefined} class="block w-full h-full"></canvas>
    </div>
  </div>
</footer>

<style>
  .footer-nav-link {
    transition: color 0.2s ease;
  }
  .footer-nav-link:hover {
    color: var(--accent-bgc);
  }
</style>

<script>
  import { initFlowField } from '@scripts/flow-field.ts'
  import type { FlowFieldOptions } from '@scripts/flow-field.ts'
  const canvas = document.getElementById('footer-flow') as HTMLCanvasElement
  // Explicit prop wins → random accent colour → default 'blue'
  const color = (canvas.dataset.color ||
    document.documentElement.dataset.accentColor ||
    'pixel-blue') as FlowFieldOptions['color']
  initFlowField({ canvasId: 'footer-flow', color, padding: { top: 80 } })
</script>
