---

<div class="case-study-left-pane min-w-0 overflow-hidden">
  <!-- First image -->
  <div class="grid grid-cols-2 lg:grid-cols-12 gap-5">
    <div class="col-span-2 lg:col-span-12 aspect-video overflow-hidden bg-(--case-study-placeholder)">
      <Image src={mbImage} alt="" class="h-full w-full object-cover" />
    </div>
  </div>

  <!-- Summary: shown on all breakpoints -->
  <div class="grid grid-cols-12 gap-5">
    <p
      class="case-study-summary-desktop font-sans text-[clamp(2rem,3.3vw,3rem)] leading-[1.02] tracking-[-0.03em] text-black my-12 lg:my-16"
    >
      How a discovery-led portal helped connect overlooked talent with local businesses. And placed over 80 students
      into employment.
    </p>
  </div>

  <!-- Remaining images -->
  <div class="grid grid-cols-2 lg:grid-cols-12 gap-5">
    <div class="lg:col-span-6 aspect-square overflow-hidden bg-(--case-study-placeholder)">
      <Image src={mbImage} alt="" class="h-full w-full object-cover" />
    </div>
    <div class="lg:col-span-6 aspect-square overflow-hidden bg-(--case-study-placeholder)">
      <Image src={mbImage} alt="" class="h-full w-full object-cover" />
    </div>
    <div class="col-span-2 lg:col-span-12 aspect-16/7 overflow-hidden bg-(--case-study-placeholder)">
      <Image src={mbImage} alt="" class="h-full w-full object-cover" />
    </div>
    <div class="col-span-2 lg:col-span-12 aspect-16/7 overflow-hidden bg-(--case-study-placeholder)">
      <Image src={mbImage} alt="" class="h-full w-full object-cover" />
    </div>
  </div>
</div>
