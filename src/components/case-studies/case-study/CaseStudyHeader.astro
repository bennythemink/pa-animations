---
import Grid from '@components/Grid.astro'
---

<section class="pt-5 lg:pt-10 pb-8 lg:pb-14">
  <Grid>
    <div class="col-span-full lg:col-start-2 lg:col-span-11">
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="font-sans text-[clamp(3rem,5.5vw,4.875rem)] leading-[0.96] tracking-[-0.04em]">
            <slot name="title" />
          </h1>
          <div class="case-study-meta-actions mt-4 flex w-full flex-wrap items-center gap-4 lg:flex-nowrap">
            <div
              class="case-study-meta-row flex flex-1 flex-wrap gap-x-4 gap-y-2 font-sans text-sm leading-[1.3] text-[color-mix(in_oklab,var(--color-black)_55%,transparent)]"
            >
              <span class="inline-flex flex-wrap gap-1"
                ><span class="text-[color-mix(in_oklab,var(--color-black)_30%,transparent)]">Sector</span><slot
                  name="sector"
                /></span
              >
              <span>
                <span class="text-[color-mix(in_oklab,var(--color-black)_30%,transparent)]">Services</span>
                <slot name="services" />
              </span>
              <span class="inline-flex flex-wrap gap-1"
                ><span class="text-[color-mix(in_oklab,var(--color-black)_30%,transparent)]">Duration</span><slot
                  name="duration"
                /></span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </Grid>
</section>
