---
interface Result {
  title: string
  description: string
  backgroundColour: string
}

interface Props {
  results?: Result[]
}

const { results = [] } = Astro.props as Props
---

<div class="results-grid mt-6" style={`--result-count: ${results.length}`}>
  {
    results.map((result) => (
      <div class="results-card" style={`background-color: ${result.backgroundColour}`}>
        <p class="font-sans text-[clamp(1.5rem,2.5vw,2rem)] leading-[1.05] tracking-[-0.03em] p-4 pb-0 lg:p-5 lg:pb-0">
          {result.title}
        </p>
        <p class="font-sans text-sm leading-[1.3] p-4 pt-6 lg:p-5 lg:pt-6">{result.description}</p>
      </div>
    ))
  }
</div>

<style>
  .results-grid {
    display: grid;
    grid-template-columns: repeat(var(--result-count), 1fr);
  }

  @media (max-width: 480px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  .results-card {
    display: grid;
    grid-row: span 2;
    grid-template-rows: subgrid;
  }
</style>
