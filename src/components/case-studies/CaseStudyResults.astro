---
interface Result {
  title: string
  description: string
  backgroundColour: string
}

interface Props {
  results?: Result[]
}

const { results = [] } = Astro.props as Props
---

<div class="flex flex-wrap mt-6">
  {
    results.map((result) => (
      <div class="flex min-w-[160px] flex-1 flex-col p-4 lg:p-5" style={`background-color: ${result.backgroundColour}`}>
        <p class="font-sans text-[clamp(1.5rem,2.5vw,2rem)] leading-[1.05] tracking-[-0.03em] flex-1">{result.title}</p>
        <p class="font-sans text-sm leading-[1.3] mt-6">{result.description}</p>
      </div>
    ))
  }
</div>
